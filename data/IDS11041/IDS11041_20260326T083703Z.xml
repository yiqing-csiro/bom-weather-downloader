    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-26T19:07:04+10:30" end-time-local="2026-03-26T19:07:04+10:30" start-time-utc="2026-03-26T08:37:04Z" end-time-utc="2026-03-26T08:37:04Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">An upper level trough over southeast SA will continue to move eastwards, as a high pressure system starts to build southwest of the Bight. The high will become established south of SA by Friday, then moving eastwards over the weekend to be centred over the Tasman Sea on Monday. A low pressure system well to the south will link to a trough over the far west late Monday and into Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW015" description="Mount Lofty Ranges" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-26T15:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-26T04:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower about the southern Fleurieu Peninsula, near zero chance elsewhere. Winds southerly 25 to 40 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower in the south, near zero chance elsewhere. Winds southerly 25 to 35 km/h. Overnight temperatures falling to between 10 and 13 with daytime temperatures reaching between 16 and 19.</text>
                <text type="fire_danger">High</text>
                <text type="uv_alert">Sun protection 10:10am to 4:20pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-28T00:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-27T13:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower in the south in the morning and early afternoon. Near zero chance of rain elsewhere. Winds southerly 15 to 25 km/h turning southeasterly during the morning. Overnight temperatures falling to between 9 and 13 with daytime temperatures reaching between 18 and 21.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds southeasterly 15 to 20 km/h becoming light during the morning then becoming east to southeasterly 15 to 20 km/h during the evening. Overnight temperatures falling to between 10 and 13 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-30T00:00:00+10:30" end-time-local="2026-03-31T00:00:00+10:30" start-time-utc="2026-03-29T13:30:00Z" end-time-utc="2026-03-30T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to northeasterly 15 to 20 km/h tending north to northeasterly during the morning then becoming light during the afternoon. Overnight temperatures falling to around 14 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
