        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-20T21:17:55+09:30" end-time-local="2026-05-20T21:17:55+09:30" start-time-utc="2026-05-20T11:47:55Z" end-time-utc="2026-05-20T11:47:55Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over SA will remain dominant as it slowly moves east and into the Tasman Sea on Friday. A cold front move across across South Australia over the weekend, followed by another high pressure system.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW015" description="Mount Lofty Ranges" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-20T21:00:00+09:30" end-time-local="2026-05-21T00:00:00+09:30" start-time-utc="2026-05-20T11:30:00Z" end-time-utc="2026-05-20T14:30:00Z">
                <text type="forecast">Mostly clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-21T00:00:00+09:30" end-time-local="2026-05-22T00:00:00+09:30" start-time-utc="2026-05-20T14:30:00Z" end-time-utc="2026-05-21T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Light winds. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching around 18.</text>
                <text type="uv_alert">Sun protection 10:50am to 1:20pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-22T00:00:00+09:30" end-time-local="2026-05-23T00:00:00+09:30" start-time-utc="2026-05-21T14:30:00Z" end-time-utc="2026-05-22T14:30:00Z">
                <text type="forecast">Becoming cloudy. Light winds becoming northerly 15 to 20 km/h in the morning then becoming light in the early afternoon. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching between 16 and 20.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-23T00:00:00+09:30" end-time-local="2026-05-24T00:00:00+09:30" start-time-utc="2026-05-22T14:30:00Z" end-time-utc="2026-05-23T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower, most likely in the evening. Winds northeasterly 15 to 20 km/h turning northerly during the morning. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching between 17 and 20.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-24T00:00:00+09:30" end-time-local="2026-05-25T00:00:00+09:30" start-time-utc="2026-05-23T14:30:00Z" end-time-utc="2026-05-24T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers. Light winds becoming west to southwesterly 15 to 20 km/h during the morning then tending south to southwesterly 15 to 25 km/h during the day. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching between 15 and 18.</text>
            </forecast-period>
        </area>
