    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-22T09:16:33+09:30" end-time-local="2026-05-22T09:16:33+09:30" start-time-utc="2026-05-21T23:46:33Z" end-time-utc="2026-05-21T23:46:33Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over southeastern SA will remain dominant as it slowly moves east and into the Tasman Sea today. A cold front move across across South Australia over the weekend. A low pressure system develops and lingers near the southeast early next week whilst a ridge high pressure builds over the west.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW015" description="Mount Lofty Ranges" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-22T00:00:00+09:30" end-time-local="2026-05-23T00:00:00+09:30" start-time-utc="2026-05-21T14:30:00Z" end-time-utc="2026-05-22T14:30:00Z">
                <text type="forecast">Becoming cloudy. Winds northerly 15 to 20 km/h becoming light in the early afternoon. Daytime maximum temperatures between 16 and 20.</text>
                <text type="uv_alert">Sun protection 11:00am to 1:10pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-23T00:00:00+09:30" end-time-local="2026-05-24T00:00:00+09:30" start-time-utc="2026-05-22T14:30:00Z" end-time-utc="2026-05-23T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. Winds north to northeasterly 15 to 20 km/h becoming light in the early afternoon then becoming north to northeasterly 15 to 20 km/h in the evening. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching between 17 and 20.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-24T00:00:00+09:30" end-time-local="2026-05-25T00:00:00+09:30" start-time-utc="2026-05-23T14:30:00Z" end-time-utc="2026-05-24T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely in the afternoon and evening. Winds northerly 15 to 25 km/h tending northwesterly during the day then becoming light during the afternoon. Overnight temperatures falling to around 11 with daytime temperatures reaching between 15 and 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-25T00:00:00+09:30" end-time-local="2026-05-26T00:00:00+09:30" start-time-utc="2026-05-24T14:30:00Z" end-time-utc="2026-05-25T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers. Light winds becoming east to southeasterly 15 to 20 km/h during the morning then tending south to southeasterly during the day. Overnight temperatures falling to between 8 and 11 with daytime temperatures reaching between 15 and 18.</text>
            </forecast-period>
        </area>
