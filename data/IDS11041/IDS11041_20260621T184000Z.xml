    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-22T04:10:01+09:30" end-time-local="2026-06-22T04:10:01+09:30" start-time-utc="2026-06-21T18:40:01Z" end-time-utc="2026-06-21T18:40:01Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system centred south of SA will move slowly eastwards today to be centred over NSW later in the day. A cold front will move across southern coastal districts late Tuesday or early Wednesday then a new high will move across waters to the south mid-week to be centred over Tasmania on Thursday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW015" description="Mount Lofty Ranges" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-22T00:00:00+09:30" end-time-local="2026-06-23T00:00:00+09:30" start-time-utc="2026-06-21T14:30:00Z" end-time-utc="2026-06-22T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning frost. Slight chance of a shower about the southern Fleurieu Peninsula, near zero chance elsewhere. Light winds becoming northwesterly 15 to 20 km/h in the middle of the day then becoming light in the early afternoon. Daytime maximum temperatures between 11 and 15.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-23T00:00:00+09:30" end-time-local="2026-06-24T00:00:00+09:30" start-time-utc="2026-06-22T14:30:00Z" end-time-utc="2026-06-23T14:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming northwesterly 15 to 20 km/h in the morning then becoming light in the early afternoon. Overnight temperatures falling to between 4 and 8 with daytime temperatures reaching around 14.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-24T00:00:00+09:30" end-time-local="2026-06-25T00:00:00+09:30" start-time-utc="2026-06-23T14:30:00Z" end-time-utc="2026-06-24T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Slight chance of a shower in the south, near zero chance elsewhere. Light winds. Overnight temperatures falling to between 4 and 7 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-25T00:00:00+09:30" end-time-local="2026-06-26T00:00:00+09:30" start-time-utc="2026-06-24T14:30:00Z" end-time-utc="2026-06-25T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Light winds. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching around 14.</text>
            </forecast-period>
        </area>
