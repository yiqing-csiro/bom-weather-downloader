    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-29T09:16:26+09:30" end-time-local="2026-05-29T09:16:26+09:30" start-time-utc="2026-05-28T23:46:26Z" end-time-utc="2026-05-28T23:46:26Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A series of cold fronts moving across the south today and on Saturday. A weak high pressure system moves across from west on Sunday, followed by a significant low pressure system moving south of the Bight Monday and into western Bass Strait on Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW015" description="Mount Lofty Ranges" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-29T00:00:00+09:30" end-time-local="2026-05-30T00:00:00+09:30" start-time-utc="2026-05-28T14:30:00Z" end-time-utc="2026-05-29T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers. Winds northwesterly 20 to 30 km/h turning westerly 15 to 25 km/h in the evening. Daytime maximum temperatures between 15 and 18.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-30T00:00:00+09:30" end-time-local="2026-05-31T00:00:00+09:30" start-time-utc="2026-05-29T14:30:00Z" end-time-utc="2026-05-30T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely in the morning and afternoon. Winds westerly 20 to 30 km/h. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching between 13 and 17.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-31T00:00:00+09:30" end-time-local="2026-06-01T00:00:00+09:30" start-time-utc="2026-05-30T14:30:00Z" end-time-utc="2026-05-31T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers. Winds westerly 20 to 30 km/h becoming light during the afternoon. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching between 13 and 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-01T00:00:00+09:30" end-time-local="2026-06-02T00:00:00+09:30" start-time-utc="2026-05-31T14:30:00Z" end-time-utc="2026-06-01T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. The chance of a thunderstorm in the afternoon and evening. Winds northerly 15 to 25 km/h increasing to 25 to 35 km/h during the morning then turning northwesterly 25 to 40 km/h during the evening. Overnight temperatures falling to around 9 with daytime temperatures reaching between 17 and 20.</text>
            </forecast-period>
        </area>
