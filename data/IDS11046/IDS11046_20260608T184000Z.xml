    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-09T04:10:25+09:30" end-time-local="2026-06-09T04:10:25+09:30" start-time-utc="2026-06-08T18:40:25Z" end-time-utc="2026-06-08T18:40:25Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over the Tasman Sea is responsible for northerly winds across South Australia ahead of a weakening cold front mid-week. A second cold front expected late in the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW006" description="Riverland" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-09T00:00:00+09:30" end-time-local="2026-06-10T00:00:00+09:30" start-time-utc="2026-06-08T14:30:00Z" end-time-utc="2026-06-09T14:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming northeasterly 15 to 25 km/h in the morning then tending northerly in the middle of the day. Daytime maximum temperatures in the low 20s.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-10T00:00:00+09:30" end-time-local="2026-06-11T00:00:00+09:30" start-time-utc="2026-06-09T14:30:00Z" end-time-utc="2026-06-10T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the early morning. Winds north to northwesterly 15 to 20 km/h turning westerly in the late morning then becoming light in the early afternoon. Overnight temperatures falling to around 11 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-11T00:00:00+09:30" end-time-local="2026-06-12T00:00:00+09:30" start-time-utc="2026-06-10T14:30:00Z" end-time-utc="2026-06-11T14:30:00Z">
                <text type="forecast">The chance of morning fog. Mostly sunny afternoon. Light winds. Overnight temperatures falling to around 7 with daytime temperatures reaching around 20.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-12T00:00:00+09:30" end-time-local="2026-06-13T00:00:00+09:30" start-time-utc="2026-06-11T14:30:00Z" end-time-utc="2026-06-12T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower, most likely in the evening. Light winds becoming northerly 15 to 25 km/h during the morning. Overnight temperatures falling to around 10 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
        </area>
