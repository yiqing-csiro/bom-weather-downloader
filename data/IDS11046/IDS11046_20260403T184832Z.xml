    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-04T05:18:33+10:30" end-time-local="2026-04-04T05:18:33+10:30" start-time-utc="2026-04-03T18:48:33Z" end-time-utc="2026-04-03T18:48:33Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system southeast of the Bight will continue to move southeastwards to be centred southeast of Tasmania by Sunday allowing a trough over WA to link to a weak front south of the Bight moving over western and southern parts of SA later Sunday into Monday. Another high pressure system is expected to follow early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW006" description="Riverland" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-04T00:00:00+10:30" end-time-local="2026-04-05T00:00:00+10:30" start-time-utc="2026-04-03T13:30:00Z" end-time-utc="2026-04-04T13:30:00Z">
                <text type="forecast">Sunny. Winds southeasterly 15 to 20 km/h becoming light in the early morning then becoming east to southeasterly 15 to 20 km/h in the morning. Daytime maximum temperatures in the mid 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 4:10pm, UV Index predicted to reach 7 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-05T00:00:00+10:30" end-time-local="2026-04-06T00:00:00+09:30" start-time-utc="2026-04-04T13:30:00Z" end-time-utc="2026-04-05T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the late afternoon and evening. Light winds. Overnight temperatures falling to around 12 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-06T00:00:00+09:30" end-time-local="2026-04-07T00:00:00+09:30" start-time-utc="2026-04-05T14:30:00Z" end-time-utc="2026-04-06T14:30:00Z">
                <text type="forecast">Medium chance of showers, most likely in the morning. Mostly sunny day. Winds north to northeasterly 15 to 25 km/h shifting west to southwesterly 20 to 30 km/h during the afternoon. Overnight temperatures falling to around 16 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-07T00:00:00+09:30" end-time-local="2026-04-08T00:00:00+09:30" start-time-utc="2026-04-06T14:30:00Z" end-time-utc="2026-04-07T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Light winds becoming southwesterly 15 to 20 km/h during the morning then becoming light during the evening. Overnight temperatures falling to around 15 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
