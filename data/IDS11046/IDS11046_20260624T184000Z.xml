        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-25T04:10:25+09:30" end-time-local="2026-06-25T04:10:25+09:30" start-time-utc="2026-06-24T18:40:25Z" end-time-utc="2026-06-24T18:40:25Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of SA is forecast to be centred over Tasmania later today. The high will continue to extend a ridge over SA through to Saturday then a low pressure trough is expected to reach far western areas of the state on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW006" description="Riverland" type="public-district" parent-aac="SA_FA001">
            <warning-summary type="frost_warning" start-time-local="2026-06-24T15:00:00+09:30" end-time-local="2026-06-25T15:00:00+09:30" start-time-utc="2026-06-24T05:30:00Z" end-time-utc="2026-06-25T05:30:00Z">Frost Warning for Thursday morning</warning-summary>
            <forecast-period index="0" start-time-local="2026-06-25T00:00:00+09:30" end-time-local="2026-06-26T00:00:00+09:30" start-time-utc="2026-06-24T14:30:00Z" end-time-utc="2026-06-25T14:30:00Z">
                <text type="forecast">Partly cloudy. Patches of frost and the chance of fog this morning. Light winds becoming southeasterly 15 to 20 km/h in the early afternoon then becoming light in the late afternoon. Daytime maximum temperatures around 17.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-26T00:00:00+09:30" end-time-local="2026-06-27T00:00:00+09:30" start-time-utc="2026-06-25T14:30:00Z" end-time-utc="2026-06-26T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Light winds. Overnight temperatures falling to around 5 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-27T00:00:00+09:30" end-time-local="2026-06-28T00:00:00+09:30" start-time-utc="2026-06-26T14:30:00Z" end-time-utc="2026-06-27T14:30:00Z">
                <text type="forecast">Cloudy. The chance of morning fog. Slight chance of a shower. Light winds becoming easterly 15 to 20 km/h during the day then becoming light during the afternoon. Overnight temperatures falling to around 5 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-28T00:00:00+09:30" end-time-local="2026-06-29T00:00:00+09:30" start-time-utc="2026-06-27T14:30:00Z" end-time-utc="2026-06-28T14:30:00Z">
                <text type="forecast">Cloudy. The chance of morning fog in the west. Medium chance of showers, most likely in the afternoon and evening. Light winds becoming northeasterly 15 to 20 km/h during the morning then becoming light during the afternoon. Overnight temperatures falling to around 7 with daytime temperatures reaching around 17.</text>
            </forecast-period>
