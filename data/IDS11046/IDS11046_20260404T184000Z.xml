    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-05T04:10:25+09:30" end-time-local="2026-04-05T04:10:25+09:30" start-time-utc="2026-04-04T18:40:25Z" end-time-utc="2026-04-04T18:40:25Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system centred just south of Tasmania will move southeastwards during Sunday. This will allow a trough over WA to link to a weak front south of the Bight then move over western and southern parts of SA later Sunday into Monday. Another high pressure system is expected to follow early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW006" description="Riverland" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-05T00:00:00+10:30" end-time-local="2026-04-06T00:00:00+09:30" start-time-utc="2026-04-04T13:30:00Z" end-time-utc="2026-04-05T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower later tonight. Light winds. Daytime maximum temperatures in the mid to high 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:10am to 3:00pm, UV Index predicted to reach 7 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-06T00:00:00+09:30" end-time-local="2026-04-07T00:00:00+09:30" start-time-utc="2026-04-05T14:30:00Z" end-time-utc="2026-04-06T14:30:00Z">
                <text type="forecast">Medium chance of showers, most likely in the early morning. Mostly sunny day. Light winds becoming north to northwesterly 15 to 25 km/h in the morning then tending northwest to southwesterly 20 to 30 km/h in the middle of the day. Overnight temperatures falling to around 16 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-07T00:00:00+09:30" end-time-local="2026-04-08T00:00:00+09:30" start-time-utc="2026-04-06T14:30:00Z" end-time-utc="2026-04-07T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Winds southwesterly 15 to 25 km/h turning southerly 15 to 20 km/h during the afternoon. Overnight temperatures falling to around 16 with daytime temperatures reaching the mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-08T00:00:00+09:30" end-time-local="2026-04-09T00:00:00+09:30" start-time-utc="2026-04-07T14:30:00Z" end-time-utc="2026-04-08T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower, most likely in the morning and afternoon. Light winds. Overnight temperatures falling to around 11 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
