            <forecast-period index="3" start-time-local="2026-04-22T00:00:00+09:30" end-time-local="2026-04-23T00:00:00+09:30" start-time-utc="2026-04-21T14:30:00Z" end-time-utc="2026-04-22T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds. Overnight temperatures falling to around 14 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-23T00:00:00+09:30" end-time-local="2026-04-24T00:00:00+09:30" start-time-utc="2026-04-22T14:30:00Z" end-time-utc="2026-04-23T14:30:00Z">
                <text type="forecast">The chance of morning fog. Sunny afternoon. Light winds becoming north to northeasterly 15 to 20 km/h during the day then becoming light during the afternoon. Overnight temperatures falling to around 10 with daytime temperatures reaching the high 20s.</text>
            </forecast-period>
