            <forecast-period index="3" start-time-local="2026-04-20T00:00:00+09:30" end-time-local="2026-04-21T00:00:00+09:30" start-time-utc="2026-04-19T14:30:00Z" end-time-utc="2026-04-20T14:30:00Z">
                <text type="forecast">Cloud clearing. Light winds. Overnight temperatures falling to around 10 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-21T00:00:00+09:30" end-time-local="2026-04-22T00:00:00+09:30" start-time-utc="2026-04-20T14:30:00Z" end-time-utc="2026-04-21T14:30:00Z">
                <text type="forecast">The chance of morning fog. Sunny day. Light winds becoming northerly 15 to 20 km/h during the morning then tending northeasterly during the afternoon. Overnight temperatures falling to around 9 with daytime temperatures reaching the high 20s.</text>
            </forecast-period>
