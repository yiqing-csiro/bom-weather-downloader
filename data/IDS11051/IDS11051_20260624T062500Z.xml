            <forecast-period index="3" start-time-local="2026-06-27T00:00:00+09:30" end-time-local="2026-06-28T00:00:00+09:30" start-time-utc="2026-06-26T14:30:00Z" end-time-utc="2026-06-27T14:30:00Z">
