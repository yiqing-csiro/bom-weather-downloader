    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-06T04:10:50+09:30" end-time-local="2026-05-06T04:10:50+09:30" start-time-utc="2026-05-05T18:40:50Z" end-time-utc="2026-05-05T18:40:50Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure over SA will weaken briefly as a cold front crosses the southeast on Wednesday afternoon. The ridge will begin to re-establish in the wake of the front and stabilise over SA with the strong high pressure centre moving into the Bight over the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW011" description="Eastern Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-06T00:00:00+09:30" end-time-local="2026-05-07T00:00:00+09:30" start-time-utc="2026-05-05T14:30:00Z" end-time-utc="2026-05-06T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. High chance of showers in the south, medium chance elsewhere. Light winds becoming southwesterly 20 to 30 km/h in the morning then tending southerly in the late afternoon. Daytime maximum temperatures between 18 and 21.</text>
                <text type="uv_alert">Sun protection 10:30am to 2:00pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-07T00:00:00+09:30" end-time-local="2026-05-08T00:00:00+09:30" start-time-utc="2026-05-06T14:30:00Z" end-time-utc="2026-05-07T14:30:00Z">
                <text type="forecast">Cloudy. Winds southerly 20 to 30 km/h. Overnight temperatures falling to around 10 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers near the coast, slight chance elsewhere. Winds southwesterly 15 to 20 km/h turning southerly 20 to 30 km/h during the morning. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-09T00:00:00+09:30" end-time-local="2026-05-10T00:00:00+09:30" start-time-utc="2026-05-08T14:30:00Z" end-time-utc="2026-05-09T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, most likely in the morning. Winds south to southeasterly 15 to 25 km/h. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching between 17 and 20.</text>
            </forecast-period>
        </area>
