    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-22T09:21:13+10:30" end-time-local="2026-03-22T09:21:13+10:30" start-time-utc="2026-03-21T22:51:13Z" end-time-utc="2026-03-21T22:51:13Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over the Tasman sea, extends a ridge over southern SA. A broad trough moves over SA early next week, then a cold front clips the southeast and an upper trough moves up over SA Wednesday and Thursday. A new ridge develops south of the Bight mid next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW011" description="Eastern Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-22T00:00:00+10:30" end-time-local="2026-03-23T00:00:00+10:30" start-time-utc="2026-03-21T13:30:00Z" end-time-utc="2026-03-22T13:30:00Z">
                <text type="forecast">Sunny. Light winds becoming east to southeasterly 15 to 20 km/h in the early afternoon. Daytime maximum temperatures around 30.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 4:40pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-23T00:00:00+10:30" end-time-local="2026-03-24T00:00:00+10:30" start-time-utc="2026-03-22T13:30:00Z" end-time-utc="2026-03-23T13:30:00Z">
                <text type="forecast">Sunny. Winds northeast to southeasterly 15 to 20 km/h tending north to northeasterly in the morning then becoming light in the evening. Overnight temperatures falling to around 18 with daytime temperatures reaching the low 30s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-24T00:00:00+10:30" end-time-local="2026-03-25T00:00:00+10:30" start-time-utc="2026-03-23T13:30:00Z" end-time-utc="2026-03-24T13:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming west to northwesterly 15 to 20 km/h during the morning then tending southeast to southwesterly during the afternoon. Overnight temperatures falling to around 19 with daytime temperatures reaching the low 30s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-25T00:00:00+10:30" end-time-local="2026-03-26T00:00:00+10:30" start-time-utc="2026-03-24T13:30:00Z" end-time-utc="2026-03-25T13:30:00Z">
                <text type="forecast">Mostly sunny morning. Slight chance of a shower, most likely in the afternoon. The chance of a thunderstorm in the afternoon. Light winds becoming southwesterly 15 to 25 km/h during the morning then tending southerly 20 to 30 km/h during the afternoon. Overnight temperatures falling to around 19 with daytime temperatures reaching 26 to 31.</text>
            </forecast-period>
        </area>
