    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-19T21:18:50+09:30" end-time-local="2026-07-19T21:18:50+09:30" start-time-utc="2026-07-19T11:48:50Z" end-time-utc="2026-07-19T11:48:50Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over Victoria extends a ridge over South Australia, with the ridge expected to weaken during Tuesday. A trough will develop in the west on Tuesday, ahead of a cold front that is expected to extend over southern parts during Wednesday. Another ridge will extend over the west of the state later Wednesday, with a high centre expected to build over the Bight by Thursday evening.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW011" description="Eastern Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-19T21:00:00+09:30" end-time-local="2026-07-20T00:00:00+09:30" start-time-utc="2026-07-19T11:30:00Z" end-time-utc="2026-07-19T14:30:00Z">
                <text type="forecast">Clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-20T00:00:00+09:30" end-time-local="2026-07-21T00:00:00+09:30" start-time-utc="2026-07-19T14:30:00Z" end-time-utc="2026-07-20T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds north to northwesterly 15 to 20 km/h becoming light in the early afternoon. Overnight temperatures falling to around 6 with daytime temperatures reaching around 18.</text>
                <text type="uv_alert">Sun protection 11:00am to 1:50pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-21T00:00:00+09:30" end-time-local="2026-07-22T00:00:00+09:30" start-time-utc="2026-07-20T14:30:00Z" end-time-utc="2026-07-21T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds becoming northwesterly 15 to 20 km/h in the morning then becoming light in the late afternoon. Overnight temperatures falling to around 6 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-22T00:00:00+09:30" end-time-local="2026-07-23T00:00:00+09:30" start-time-utc="2026-07-21T14:30:00Z" end-time-utc="2026-07-22T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Medium chance of showers, most likely in the afternoon. Light winds becoming southwesterly 15 to 25 km/h during the morning then becoming light during the evening. Overnight temperatures falling to around 6 with daytime temperatures reaching between 15 and 18.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-23T00:00:00+09:30" end-time-local="2026-07-24T00:00:00+09:30" start-time-utc="2026-07-22T14:30:00Z" end-time-utc="2026-07-23T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers near the coast, slight chance elsewhere. Light winds becoming southerly 15 to 25 km/h during the morning then becoming light during the evening. Overnight temperatures falling to between 3 and 6 with daytime temperatures reaching around 14.</text>
            </forecast-period>
        </area>
