        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-07T04:10:49+09:30" end-time-local="2026-05-07T04:10:49+09:30" start-time-utc="2026-05-06T18:40:49Z" end-time-utc="2026-05-06T18:40:49Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system will move slowly eastwards across the Great Australian Bight during the next few days. The high will then move eastwards early next week to be centred southeast of Tasmania late Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW011" description="Eastern Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-07T00:00:00+09:30" end-time-local="2026-05-08T00:00:00+09:30" start-time-utc="2026-05-06T14:30:00Z" end-time-utc="2026-05-07T14:30:00Z">
                <text type="forecast">Cloudy. Winds southerly 20 to 30 km/h. Daytime maximum temperatures between 15 and 18.</text>
                <text type="uv_alert">Sun protection 10:40am to 1:50pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. Light winds becoming southwesterly 15 to 20 km/h in the early morning then tending southerly 20 to 30 km/h in the morning. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-09T00:00:00+09:30" end-time-local="2026-05-10T00:00:00+09:30" start-time-utc="2026-05-08T14:30:00Z" end-time-utc="2026-05-09T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, most likely in the morning and afternoon. Winds southerly 15 to 20 km/h increasing to 25 km/h before turning southeasterly 15 to 20 km/h during the day. Overnight temperatures falling to around 10 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-10T00:00:00+09:30" end-time-local="2026-05-11T00:00:00+09:30" start-time-utc="2026-05-09T14:30:00Z" end-time-utc="2026-05-10T14:30:00Z">
                <text type="forecast">Cloudy. The chance of morning fog. Medium chance of showers in the south, slight chance elsewhere. Light winds becoming southeasterly 15 to 20 km/h during the afternoon then becoming light during the evening. Overnight temperatures falling to around 10 with daytime temperatures reaching around 19.</text>
            </forecast-period>
        </area>
