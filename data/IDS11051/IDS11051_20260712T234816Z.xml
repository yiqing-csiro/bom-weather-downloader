        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-13T09:18:17+09:30" end-time-local="2026-07-13T09:18:17+09:30" start-time-utc="2026-07-12T23:48:17Z" end-time-utc="2026-07-12T23:48:17Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure lies over northern SA. A cold front will pass across southeastern SA today before a strong high pressure system moves east mid week and begins to dominate the weather pattern.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW011" description="Eastern Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-13T00:00:00+09:30" end-time-local="2026-07-14T00:00:00+09:30" start-time-utc="2026-07-12T14:30:00Z" end-time-utc="2026-07-13T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, becoming less likely in the late afternoon and evening. Winds northwesterly 15 to 20 km/h turning westerly 20 to 30 km/h in the morning then decreasing to 15 to 20 km/h in the late afternoon. Daytime maximum temperatures between 15 and 18.</text>
                <text type="uv_alert">Sun protection 11:40am to 1:10pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-14T00:00:00+09:30" end-time-local="2026-07-15T00:00:00+09:30" start-time-utc="2026-07-13T14:30:00Z" end-time-utc="2026-07-14T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the late morning and afternoon. Winds westerly 15 to 20 km/h tending southwesterly in the middle of the day then becoming light in the late afternoon. Overnight temperatures falling to around 8 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-15T00:00:00+09:30" end-time-local="2026-07-16T00:00:00+09:30" start-time-utc="2026-07-14T14:30:00Z" end-time-utc="2026-07-15T14:30:00Z">
                <text type="forecast">The chance of morning fog. Mostly sunny afternoon. Light winds. Overnight temperatures falling to between 4 and 7 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-16T00:00:00+09:30" end-time-local="2026-07-17T00:00:00+09:30" start-time-utc="2026-07-15T14:30:00Z" end-time-utc="2026-07-16T14:30:00Z">
                <text type="forecast">The chance of morning fog. Sunny afternoon. Light winds. Overnight temperatures falling to around 5 with daytime temperatures reaching around 17.</text>
            </forecast-period>
        </area>
