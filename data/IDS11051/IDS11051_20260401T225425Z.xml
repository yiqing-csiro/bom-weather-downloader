    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-02T09:24:25+10:30" end-time-local="2026-04-02T09:24:25+10:30" start-time-utc="2026-04-01T22:54:25Z" end-time-utc="2026-04-01T22:54:25Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system sin the Bight extends a ridge over SA. The tail end of a cold front will brush the southeast of SA later Thursday. The high is forecast to move east on Friday to be southeast of Tasmania by Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW011" description="Eastern Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-02T00:00:00+10:30" end-time-local="2026-04-03T00:00:00+10:30" start-time-utc="2026-04-01T13:30:00Z" end-time-utc="2026-04-02T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds south to southeasterly 20 to 30 km/h. Daytime maximum temperatures in the low to mid 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:20am to 4:20pm, UV Index predicted to reach 7 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-03T00:00:00+10:30" end-time-local="2026-04-04T00:00:00+10:30" start-time-utc="2026-04-02T13:30:00Z" end-time-utc="2026-04-03T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to around 14 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-04T00:00:00+10:30" end-time-local="2026-04-05T00:00:00+10:30" start-time-utc="2026-04-03T13:30:00Z" end-time-utc="2026-04-04T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to southeasterly 15 to 25 km/h turning north to northeasterly 15 to 20 km/h during the morning then tending east to northeasterly during the evening. Overnight temperatures falling to around 15 with daytime temperatures reaching the high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-05T00:00:00+10:30" end-time-local="2026-04-06T00:00:00+09:30" start-time-utc="2026-04-04T13:30:00Z" end-time-utc="2026-04-05T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Winds north to northeasterly 15 to 25 km/h tending north to northwesterly during the day then becoming light during the evening. Overnight temperatures falling to around 18 with daytime temperatures reaching the low 30s.</text>
            </forecast-period>
        </area>
