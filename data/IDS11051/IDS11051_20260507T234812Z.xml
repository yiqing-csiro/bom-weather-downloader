        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-08T09:18:13+09:30" end-time-local="2026-05-08T09:18:13+09:30" start-time-utc="2026-05-07T23:48:13Z" end-time-utc="2026-05-07T23:48:13Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of Western Australia will move slowly eastwards south of the Bight during the next few days. The high will then move eastwards early next week to be centred southeast of Tasmania late Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW011" description="Eastern Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers near the coast, slight chance elsewhere. Winds southerly 20 to 30 km/h. Daytime maximum temperatures around 18.</text>
                <text type="uv_alert">Sun protection 10:50am to 1:40pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-09T00:00:00+09:30" end-time-local="2026-05-10T00:00:00+09:30" start-time-utc="2026-05-08T14:30:00Z" end-time-utc="2026-05-09T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers. Winds southerly 15 to 25 km/h. Overnight temperatures falling to around 11 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-10T00:00:00+09:30" end-time-local="2026-05-11T00:00:00+09:30" start-time-utc="2026-05-09T14:30:00Z" end-time-utc="2026-05-10T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers in the south, slight chance elsewhere. The chance of morning fog. Light winds becoming southeasterly 15 to 20 km/h during the morning then becoming light during the evening. Overnight temperatures falling to around 12 with daytime temperatures reaching around 19.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-11T00:00:00+09:30" end-time-local="2026-05-12T00:00:00+09:30" start-time-utc="2026-05-10T14:30:00Z" end-time-utc="2026-05-11T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the south, near zero chance elsewhere. Winds east to southeasterly 15 to 20 km/h tending south to southeasterly during the afternoon then tending east to southeasterly during the evening. Overnight temperatures falling to around 10 with daytime temperatures reaching around 20.</text>
            </forecast-period>
        </area>
