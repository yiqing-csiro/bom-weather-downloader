        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-18T04:10:12+09:30" end-time-local="2026-06-18T04:10:12+09:30" start-time-utc="2026-06-17T18:40:12Z" end-time-utc="2026-06-17T18:40:12Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A cold front over the east of South Australia will move clear of the state by midday today. A second cold front will move across the west this afternoon reaching central and eastern parts early Friday morning. A cooler, fresh southerly flow following the second front will gradually ease as a high pressure system drifts in from the west for the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW003" description="Kangaroo Island" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-18T00:00:00+09:30" end-time-local="2026-06-19T00:00:00+09:30" start-time-utc="2026-06-17T14:30:00Z" end-time-utc="2026-06-18T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers, most likely late this afternoon and evening. The chance of a thunderstorm during the morning and afternoon. Winds north to northwesterly 25 to 40 km/h turning west to southwesterly 25 to 35 km/h in the evening. Daytime maximum temperatures around 14.</text>
                <text type="uv_alert">##</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-19T00:00:00+09:30" end-time-local="2026-06-20T00:00:00+09:30" start-time-utc="2026-06-18T14:30:00Z" end-time-utc="2026-06-19T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds southwesterly 25 to 35 km/h turning southerly 20 to 30 km/h in the late afternoon. Overnight temperatures falling to around 9 with daytime temperatures reaching around 14.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-20T00:00:00+09:30" end-time-local="2026-06-21T00:00:00+09:30" start-time-utc="2026-06-19T14:30:00Z" end-time-utc="2026-06-20T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers. Winds southerly 20 to 30 km/h becoming light during the evening. Overnight temperatures falling to around 8 with daytime temperatures reaching around 14.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-21T00:00:00+09:30" end-time-local="2026-06-22T00:00:00+09:30" start-time-utc="2026-06-20T14:30:00Z" end-time-utc="2026-06-21T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers. Light winds. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching around 14.</text>
            </forecast-period>
