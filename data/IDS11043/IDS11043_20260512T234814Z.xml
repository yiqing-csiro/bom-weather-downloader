        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-13T09:18:15+09:30" end-time-local="2026-05-13T09:18:15+09:30" start-time-utc="2026-05-12T23:48:15Z" end-time-utc="2026-05-12T23:48:15Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system in the Tasman Sea is slowly moving east. A trough of low pressure lies across the northeast and will remain near stationary. A cold front will move east across the Southern Ocean over the weekend, with the trough also starting to move east ahead of it.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW003" description="Kangaroo Island" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-13T00:00:00+09:30" end-time-local="2026-05-14T00:00:00+09:30" start-time-utc="2026-05-12T14:30:00Z" end-time-utc="2026-05-13T14:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming northeasterly 15 to 20 km/h in the late evening. Daytime maximum temperatures in the low 20s.</text>
                <text type="uv_alert">Sun protection 11:20am to 1:10pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-14T00:00:00+09:30" end-time-local="2026-05-15T00:00:00+09:30" start-time-utc="2026-05-13T14:30:00Z" end-time-utc="2026-05-14T14:30:00Z">
                <text type="forecast">Sunny. Winds north to northeasterly 15 to 20 km/h becoming light in the early afternoon then becoming northeasterly 15 to 20 km/h in the late evening. Overnight temperatures falling to around 12 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-15T00:00:00+09:30" end-time-local="2026-05-16T00:00:00+09:30" start-time-utc="2026-05-14T14:30:00Z" end-time-utc="2026-05-15T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds northeasterly 15 to 25 km/h turning northerly during the morning. Overnight temperatures falling to around 14 with daytime temperatures reaching between 18 and 21.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-16T00:00:00+09:30" end-time-local="2026-05-17T00:00:00+09:30" start-time-utc="2026-05-15T14:30:00Z" end-time-utc="2026-05-16T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely in the morning. Winds northerly 15 to 25 km/h tending northwesterly 15 to 20 km/h during the day then becoming light during the afternoon. Overnight temperatures falling to around 13 with daytime temperatures reaching around 19.</text>
            </forecast-period>
        </area>
