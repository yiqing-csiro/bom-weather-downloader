        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-16T04:10:15+09:30" end-time-local="2026-05-16T04:10:15+09:30" start-time-utc="2026-05-15T18:40:15Z" end-time-utc="2026-05-15T18:40:15Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system in the Tasman Sea continues to move east. A cold front and trough will move over SA on the weekend. Another cold front will move over the south early next week, followed by a high pressure system.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW003" description="Kangaroo Island" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-16T00:00:00+09:30" end-time-local="2026-05-17T00:00:00+09:30" start-time-utc="2026-05-15T14:30:00Z" end-time-utc="2026-05-16T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers, becoming less likely this afternoon. The chance of a thunderstorm during the morning and afternoon. Winds northerly 15 to 25 km/h tending northwesterly in the early morning then becoming light in the early afternoon. Daytime maximum temperatures around 20.</text>
                <text type="uv_alert">Sun protection 12:30pm to 1:30pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-17T00:00:00+09:30" end-time-local="2026-05-18T00:00:00+09:30" start-time-utc="2026-05-16T14:30:00Z" end-time-utc="2026-05-17T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Medium chance of showers, most likely in the late morning and afternoon. Light winds. Overnight temperatures falling to around 11 with daytime temperatures reaching around 19.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-18T00:00:00+09:30" end-time-local="2026-05-19T00:00:00+09:30" start-time-utc="2026-05-17T14:30:00Z" end-time-utc="2026-05-18T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. High chance of showers, most likely in the afternoon and evening. Light winds becoming west to northwesterly 15 to 20 km/h during the morning. Overnight temperatures falling to around 8 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-19T00:00:00+09:30" end-time-local="2026-05-20T00:00:00+09:30" start-time-utc="2026-05-18T14:30:00Z" end-time-utc="2026-05-19T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers. Winds westerly 15 to 20 km/h turning southwesterly 15 to 25 km/h during the morning. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching around 18.</text>
            </forecast-period>
        </area>
