        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-01T21:17:42+09:30" end-time-local="2026-07-01T21:17:42+09:30" start-time-utc="2026-07-01T11:47:42Z" end-time-utc="2026-07-01T11:47:42Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A series of low pressure systems passing over waters to the south will extend cold fronts that will cross over SA through to the end of the week. A high pressure system is then forecast to move into the Bight from late Friday and extend a ridge across the state over the weekend, as it slowly moves southeastwards towards Tasmania.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW003" description="Kangaroo Island" type="public-district" parent-aac="SA_FA001">
            <warning-summary type="sheep_graziers_warning" start-time-local="2026-07-01T16:34:00+09:30" end-time-local="2026-07-03T00:00:00+09:30" start-time-utc="2026-07-01T07:04:00Z" end-time-utc="2026-07-02T14:30:00Z">Warning to Sheep Graziers</warning-summary>
            <forecast-period index="0" start-time-local="2026-07-01T21:00:00+09:30" end-time-local="2026-07-02T00:00:00+09:30" start-time-utc="2026-07-01T11:30:00Z" end-time-utc="2026-07-01T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds northwesterly 35 to 50 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-02T00:00:00+09:30" end-time-local="2026-07-03T00:00:00+09:30" start-time-utc="2026-07-01T14:30:00Z" end-time-utc="2026-07-02T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely in the early morning. The chance of a thunderstorm in the morning. Damaging winds possible during the morning. Winds northwesterly 35 to 50 km/h turning westerly 30 to 45 km/h before dawn. Overnight temperatures falling to around 9 with daytime temperatures reaching around 13.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 1 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-03T00:00:00+09:30" end-time-local="2026-07-04T00:00:00+09:30" start-time-utc="2026-07-02T14:30:00Z" end-time-utc="2026-07-03T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, most likely in the early morning. Winds westerly 25 to 40 km/h tending southwesterly before dawn then becoming light in the late afternoon. Overnight temperatures falling to around 8 with daytime temperatures reaching around 14.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-04T00:00:00+09:30" end-time-local="2026-07-05T00:00:00+09:30" start-time-utc="2026-07-03T14:30:00Z" end-time-utc="2026-07-04T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers. Light winds becoming south to southeasterly 15 to 20 km/h during the day then becoming light during the evening. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-05T00:00:00+09:30" end-time-local="2026-07-06T00:00:00+09:30" start-time-utc="2026-07-04T14:30:00Z" end-time-utc="2026-07-05T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower in the morning. Winds southeasterly 15 to 20 km/h tending easterly 15 to 25 km/h during the morning. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching around 14.</text>
            </forecast-period>
