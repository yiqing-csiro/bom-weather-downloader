        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-03T04:10:11+09:30" end-time-local="2026-07-03T04:10:11+09:30" start-time-utc="2026-07-02T18:40:11Z" end-time-utc="2026-07-02T18:40:11Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A cold front and post-frontal trough move to the east of SA today making way for a high pressure system moving in from the west. The high will dominate the weather pattern over the weekend as it slowly moves east, reaching the Tasman Sea by Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW003" description="Kangaroo Island" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-03T00:00:00+09:30" end-time-local="2026-07-04T00:00:00+09:30" start-time-utc="2026-07-02T14:30:00Z" end-time-utc="2026-07-03T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, becoming less likely this morning. Winds west to southwesterly 25 to 40 km/h becoming southwesterly 20 to 30 km/h in the early morning then becoming west to southwesterly and light in the evening. Daytime maximum temperatures around 14.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-04T00:00:00+09:30" end-time-local="2026-07-05T00:00:00+09:30" start-time-utc="2026-07-03T14:30:00Z" end-time-utc="2026-07-04T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers. Light winds becoming south to southeasterly 15 to 20 km/h in the middle of the day then becoming light in the evening. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-05T00:00:00+09:30" end-time-local="2026-07-06T00:00:00+09:30" start-time-utc="2026-07-04T14:30:00Z" end-time-utc="2026-07-05T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower in the morning. Light winds becoming easterly 15 to 25 km/h during the morning then becoming light during the evening. Overnight temperatures falling to around 8 with daytime temperatures reaching around 14.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-06T00:00:00+09:30" end-time-local="2026-07-07T00:00:00+09:30" start-time-utc="2026-07-05T14:30:00Z" end-time-utc="2026-07-06T14:30:00Z">
                <text type="forecast">Cloudy. Light winds. Overnight temperatures falling to around 7 with daytime temperatures reaching around 13.</text>
            </forecast-period>
