        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-24T05:36:57+09:30" end-time-local="2026-07-24T05:36:57+09:30" start-time-utc="2026-07-23T20:06:57Z" end-time-utc="2026-07-23T20:06:57Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure is building over South Australia, with the associated high centre expected to lie over the Bight during Friday and Saturday. The high will move north over South Australia on Sunday, with a trough to build over the west of the State later Sunday ahead of a cold front to move over the Bight late Monday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW003" description="Kangaroo Island" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-24T00:00:00+09:30" end-time-local="2026-07-25T00:00:00+09:30" start-time-utc="2026-07-23T14:30:00Z" end-time-utc="2026-07-24T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower, most likely at night. Light winds becoming westerly 15 to 25 km/h in the morning. Daytime maximum temperatures around 14.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-25T00:00:00+09:30" end-time-local="2026-07-26T00:00:00+09:30" start-time-utc="2026-07-24T14:30:00Z" end-time-utc="2026-07-25T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the late morning and afternoon. Winds west to southwesterly 15 to 25 km/h. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-26T00:00:00+09:30" end-time-local="2026-07-27T00:00:00+09:30" start-time-utc="2026-07-25T14:30:00Z" end-time-utc="2026-07-26T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the afternoon and evening. Winds west to southwesterly 15 to 20 km/h turning northwesterly during the day. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-27T00:00:00+09:30" end-time-local="2026-07-28T00:00:00+09:30" start-time-utc="2026-07-26T14:30:00Z" end-time-utc="2026-07-27T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the afternoon and evening. Winds northerly 15 to 25 km/h increasing to 25 to 35 km/h during the morning then tending northwesterly 25 to 40 km/h during the day. Overnight temperatures falling to around 9 with daytime temperatures reaching around 16.</text>
            </forecast-period>
