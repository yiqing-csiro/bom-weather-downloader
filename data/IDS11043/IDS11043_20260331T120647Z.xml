    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-31T22:36:47+10:30" end-time-local="2026-03-31T22:36:47+10:30" start-time-utc="2026-03-31T12:06:47Z" end-time-utc="2026-03-31T12:06:47Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A trough over western SA, links to a low pressure system well south of the Bight. The low and associated trough continue to move southeastwards, with the trough reaching central parts late Tuesday and then pushing into the northeast of SA on Wednesday. A high pressure system is expected to become established south of the Bight late in the week, after a weak front clips the southeast late Thursday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW003" description="Kangaroo Island" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-31T22:34:40+10:30" end-time-local="2026-04-01T00:00:00+10:30" start-time-utc="2026-03-31T12:04:40Z" end-time-utc="2026-03-31T13:30:00Z">
                <text type="forecast">Cloudy. High chance of showers. The chance of a thunderstorm. Winds northwesterly 15 to 25 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-01T00:00:00+10:30" end-time-local="2026-04-02T00:00:00+10:30" start-time-utc="2026-03-31T13:30:00Z" end-time-utc="2026-04-01T13:30:00Z">
                <text type="forecast">Slight chance of a shower in the early morning. Mostly sunny day. Winds westerly 15 to 25 km/h becoming light in the evening. Overnight temperatures falling to around 14 with daytime temperatures reaching the low to mid 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:30am to 4:10pm, UV Index predicted to reach 6 [High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-02T00:00:00+10:30" end-time-local="2026-04-03T00:00:00+10:30" start-time-utc="2026-04-01T13:30:00Z" end-time-utc="2026-04-02T13:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Light winds becoming west to southwesterly 15 to 20 km/h in the middle of the day then tending south to southwesterly 15 to 25 km/h in the early afternoon. Overnight temperatures falling to around 11 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-03T00:00:00+10:30" end-time-local="2026-04-04T00:00:00+10:30" start-time-utc="2026-04-02T13:30:00Z" end-time-utc="2026-04-03T13:30:00Z">
                <text type="forecast">Cloudy. The chance of morning fog. Slight chance of a shower, most likely in the morning and afternoon. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to around 12 with daytime temperatures reaching around 20.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-04T00:00:00+10:30" end-time-local="2026-04-05T00:00:00+10:30" start-time-utc="2026-04-03T13:30:00Z" end-time-utc="2026-04-04T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds southeasterly 15 to 25 km/h turning easterly 20 to 30 km/h during the morning. Overnight temperatures falling to around 12 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
        </area>
