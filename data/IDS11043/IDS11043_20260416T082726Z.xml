    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-16T17:57:26+09:30" end-time-local="2026-04-16T17:57:26+09:30" start-time-utc="2026-04-16T08:27:26Z" end-time-utc="2026-04-16T08:27:26Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of the Bight extends a ridge over SA. The high will move east during Friday and Saturday ahead of a weakening trough that is expected to brush the west and south on the weekend. The high is forecast to be over the Tasman Sea by Monday, extending a ridge over South Australia through until Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW003" description="Kangaroo Island" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-16T15:00:00+09:30" end-time-local="2026-04-17T00:00:00+09:30" start-time-utc="2026-04-16T05:30:00Z" end-time-utc="2026-04-16T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the south, near zero chance elsewhere. Winds southwesterly 15 to 25 km/h becoming light in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-17T00:00:00+09:30" end-time-local="2026-04-18T00:00:00+09:30" start-time-utc="2026-04-16T14:30:00Z" end-time-utc="2026-04-17T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the early morning. Light winds becoming south to southeasterly 15 to 20 km/h in the morning then tending east to southeasterly in the early afternoon. Overnight temperatures falling to around 12 with daytime temperatures reaching around 19.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 2:40pm, UV Index predicted to reach 5 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-18T00:00:00+09:30" end-time-local="2026-04-19T00:00:00+09:30" start-time-utc="2026-04-17T14:30:00Z" end-time-utc="2026-04-18T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds easterly 15 to 20 km/h turning north to northeasterly 15 to 25 km/h during the day. Overnight temperatures falling to between 8 and 11 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-19T00:00:00+09:30" end-time-local="2026-04-20T00:00:00+09:30" start-time-utc="2026-04-18T14:30:00Z" end-time-utc="2026-04-19T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the morning. The chance of a thunderstorm in the morning. Winds northerly 15 to 20 km/h increasing to 25 km/h before shifting south to southwesterly 15 to 20 km/h during the afternoon. Overnight temperatures falling to around 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-20T00:00:00+09:30" end-time-local="2026-04-21T00:00:00+09:30" start-time-utc="2026-04-19T14:30:00Z" end-time-utc="2026-04-20T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds southerly 15 to 20 km/h tending southeasterly during the morning then becoming light during the evening. Overnight temperatures falling to around 12 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
        </area>
