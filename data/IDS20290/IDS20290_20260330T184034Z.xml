    <warning>
        <warning-info>
            <text type="warning_title">Fire Weather Warning</text>
            <text type="warning_area_summary">Mount Lofty Ranges fire weather district</text>
            <text type="warning_advice">
                <p>The Country Fire Service advises you to:</p>
                <p>Action your Bushfire Survival Plan now.</p>
                <p>Monitor the fire and weather situation through your local radio station, www.cfs.sa.gov.au, and www.bom.gov.au.</p>
                <p>Call 000 (Triple Zero) in an emergency.</p>
            </text>
            <text type="warning_next_issue">No further warnings will be issued for this event, but the situation will continue to be monitored and further warnings issued if necessary.</text>
        </warning-info>
