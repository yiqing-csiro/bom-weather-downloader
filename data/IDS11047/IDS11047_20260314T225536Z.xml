    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-15T09:25:36+10:30" end-time-local="2026-03-15T09:25:36+10:30" start-time-utc="2026-03-14T22:55:36Z" end-time-utc="2026-03-14T22:55:36Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A trough over inland WA is expected to move across western and northern SA today and continue northeast early in the week. A ridge of high pressure persists over the south. A cold front clips the southeast early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW007" description="Murraylands" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-15T00:00:00+10:30" end-time-local="2026-03-16T00:00:00+10:30" start-time-utc="2026-03-14T13:30:00Z" end-time-utc="2026-03-15T13:30:00Z">
                <text type="forecast">Partly cloudy. Light winds becoming south to southwesterly 15 to 20 km/h in the late afternoon. Daytime maximum temperatures in the low to mid 30s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:50am to 4:40pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-16T00:00:00+10:30" end-time-local="2026-03-17T00:00:00+10:30" start-time-utc="2026-03-15T13:30:00Z" end-time-utc="2026-03-16T13:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain. Winds south to southwesterly 15 to 20 km/h becoming light in the morning. Overnight temperatures falling to around 16 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-17T00:00:00+10:30" end-time-local="2026-03-18T00:00:00+10:30" start-time-utc="2026-03-16T13:30:00Z" end-time-utc="2026-03-17T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower in the morning. Light winds becoming southeasterly 15 to 25 km/h during the morning then becoming light during the evening. Overnight temperatures falling to between 13 and 16 with daytime temperatures reaching the mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-18T00:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-17T13:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower, most likely in the morning and afternoon. Light winds becoming east to southeasterly 15 to 20 km/h during the morning then tending south to southeasterly 15 to 25 km/h during the afternoon. Overnight temperatures falling to around 15 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
