            <forecast-period index="0" start-time-local="2026-04-29T21:00:00+09:30" end-time-local="2026-04-30T00:00:00+09:30" start-time-utc="2026-04-29T11:30:00Z" end-time-utc="2026-04-29T14:30:00Z">
                <text type="forecast">Mostly clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-30T00:00:00+09:30" end-time-local="2026-05-01T00:00:00+09:30" start-time-utc="2026-04-29T14:30:00Z" end-time-utc="2026-04-30T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds north to northeasterly 15 to 25 km/h increasing to 25 to 35 km/h in the middle of the day. Overnight temperatures falling to between 12 and 15 with daytime temperatures reaching the high 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">##</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-01T00:00:00+09:30" end-time-local="2026-05-02T00:00:00+09:30" start-time-utc="2026-04-30T14:30:00Z" end-time-utc="2026-05-01T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds north to northeasterly 20 to 30 km/h increasing to 25 to 40 km/h in the middle of the day. Overnight temperatures falling to between 11 and 14 with daytime temperatures reaching the high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-02T00:00:00+09:30" end-time-local="2026-05-03T00:00:00+09:30" start-time-utc="2026-05-01T14:30:00Z" end-time-utc="2026-05-02T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely in the afternoon and evening. The chance of a thunderstorm in the evening. Winds north to northeasterly 25 to 40 km/h tending north to northwesterly 25 to 35 km/h during the morning then becoming light during the evening. Overnight temperatures falling to around 18 with daytime temperatures reaching the mid 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-03T00:00:00+09:30" end-time-local="2026-05-04T00:00:00+09:30" start-time-utc="2026-05-02T14:30:00Z" end-time-utc="2026-05-03T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the morning. The chance of a thunderstorm near the eastern border in the morning. Winds northerly 15 to 20 km/h turning northwesterly 15 to 25 km/h during the morning. Overnight temperatures falling to around 10 with daytime temperatures reaching around 20.</text>
            </forecast-period>
        </area>
