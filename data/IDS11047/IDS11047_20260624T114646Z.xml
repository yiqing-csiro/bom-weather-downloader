            <forecast-period index="0" start-time-local="2026-06-24T21:00:00+09:30" end-time-local="2026-06-25T00:00:00+09:30" start-time-utc="2026-06-24T11:30:00Z" end-time-utc="2026-06-24T14:30:00Z">
