        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-24T21:16:46+09:30" end-time-local="2026-06-24T21:16:46+09:30" start-time-utc="2026-06-24T11:46:46Z" end-time-utc="2026-06-24T11:46:46Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system is located south of SA and is forecast to be centred over Tasmania on Thursday. The high will continue to extend a ridge over SA through to Saturday then a low pressure trough is expected to reach far western areas of the state on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
