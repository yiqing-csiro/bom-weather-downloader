    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-04T21:18:54+10:30" end-time-local="2026-04-04T21:18:54+10:30" start-time-utc="2026-04-04T10:48:54Z" end-time-utc="2026-04-04T10:48:54Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over Tasmania will continue to move southeastwards to be centred southeast of Tasmania by Sunday allowing a trough over WA to link to a weak front south of the Bight to move over western and southern parts of SA later Sunday into Monday. Another high pressure system is expected to follow early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-04T21:00:00+10:30" end-time-local="2026-04-05T00:00:00+10:30" start-time-utc="2026-04-04T10:30:00Z" end-time-utc="2026-04-04T13:30:00Z">
                <text type="forecast">Clear. Winds southeasterly 20 to 30 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-05T00:00:00+10:30" end-time-local="2026-04-06T00:00:00+09:30" start-time-utc="2026-04-04T13:30:00Z" end-time-utc="2026-04-05T14:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Yunta at night. Near zero chance of rain elsewhere. Winds east to southeasterly 25 to 35 km/h. Overnight temperatures falling to between 13 and 22 with daytime temperatures reaching 28 to 36.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:10am to 3:20pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-06T00:00:00+09:30" end-time-local="2026-04-07T00:00:00+09:30" start-time-utc="2026-04-05T14:30:00Z" end-time-utc="2026-04-06T14:30:00Z">
                <text type="forecast">Mostly sunny. Medium chance of showers south of Yunta in the early morning. Near zero chance of rain elsewhere. Winds northeast to southeasterly 15 to 25 km/h tending northwest to northeasterly in the middle of the day then tending southeast to southwesterly 15 to 20 km/h in the early afternoon. Overnight temperatures falling to between 16 and 21 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-07T00:00:00+09:30" end-time-local="2026-04-08T00:00:00+09:30" start-time-utc="2026-04-06T14:30:00Z" end-time-utc="2026-04-07T14:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Yunta, near zero chance elsewhere. Winds northeast to southeasterly 15 to 20 km/h tending southeast to southwesterly during the afternoon then tending southeasterly during the evening. Overnight temperatures falling to between 17 and 21 with daytime temperatures reaching 29 to 36.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-08T00:00:00+09:30" end-time-local="2026-04-09T00:00:00+09:30" start-time-utc="2026-04-07T14:30:00Z" end-time-utc="2026-04-08T14:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Yunta, most likely in the morning and afternoon. Near zero chance of rain elsewhere. Winds northeast to southeasterly 15 to 25 km/h tending northwest to northeasterly during the day then tending northeast to southeasterly 15 to 20 km/h during the evening. Overnight temperatures falling to between 15 and 21 with daytime temperatures reaching 29 to 37.</text>
            </forecast-period>
        </area>
