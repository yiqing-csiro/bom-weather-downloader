        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-18T15:55:55+10:30" end-time-local="2026-03-18T15:55:55+10:30" start-time-utc="2026-03-18T05:25:55Z" end-time-utc="2026-03-18T05:25:55Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A low and trough over northeast SA will continue to move northeastwards clearing the State by Thursday. A ridge of high pressure persists to the south.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-18T15:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-18T04:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers east of Leigh Creek, near zero chance elsewhere. The chance of a thunderstorm east of Leigh Creek. Thunderstorms possibly severe with heavy rain which may lead to flash flooding near the eastern border. Winds southeast to southwesterly 25 to 40 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-19T00:00:00+10:30" end-time-local="2026-03-20T00:00:00+10:30" start-time-utc="2026-03-18T13:30:00Z" end-time-utc="2026-03-19T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Winds south to southeasterly 25 to 35 km/h. Overnight temperatures falling to between 17 and 22 with daytime temperatures reaching around 30.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:50am to 4:50pm, UV Index predicted to reach 10 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-20T00:00:00+10:30" end-time-local="2026-03-21T00:00:00+10:30" start-time-utc="2026-03-19T13:30:00Z" end-time-utc="2026-03-20T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Leigh Creek in the late morning and afternoon. Near zero chance of rain elsewhere. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to between 17 and 22 with daytime temperatures reaching 27 to 32.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-21T00:00:00+10:30" end-time-local="2026-03-22T00:00:00+10:30" start-time-utc="2026-03-20T13:30:00Z" end-time-utc="2026-03-21T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower about the Gammon Ranges in the morning and afternoon. Near zero chance of rain elsewhere. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to between 17 and 23 with daytime temperatures reaching 27 to 32.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-22T00:00:00+10:30" end-time-local="2026-03-23T00:00:00+10:30" start-time-utc="2026-03-21T13:30:00Z" end-time-utc="2026-03-22T13:30:00Z">
                <text type="forecast">Sunny. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to between 15 and 22 with daytime temperatures reaching 27 to 33.</text>
            </forecast-period>
