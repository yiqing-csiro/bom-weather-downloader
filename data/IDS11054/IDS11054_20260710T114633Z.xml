    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-10T21:16:33+09:30" end-time-local="2026-07-10T21:16:33+09:30" start-time-utc="2026-07-10T11:46:33Z" end-time-utc="2026-07-10T11:46:33Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A cold front in the Bight will move across the south of SA during Saturday followed by a weaker front on Monday. A high pressure system centred near southern WA will begin to dominate the weather pattern across SA mid next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-10T21:00:00+09:30" end-time-local="2026-07-11T00:00:00+09:30" start-time-utc="2026-07-10T11:30:00Z" end-time-utc="2026-07-10T14:30:00Z">
                <text type="forecast">Mostly clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-11T00:00:00+09:30" end-time-local="2026-07-12T00:00:00+09:30" start-time-utc="2026-07-10T14:30:00Z" end-time-utc="2026-07-11T14:30:00Z">
                <text type="forecast">Mostly sunny. The chance of morning fog north of Oodnadatta. Medium chance of showers east of Leigh Creek, near zero chance elsewhere. Winds west to northwesterly 20 to 30 km/h tending west to southwesterly 15 to 25 km/h in the evening. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching between 18 and 22.</text>
                <text type="uv_alert">Sun protection 11:10am to 1:30pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-12T00:00:00+09:30" end-time-local="2026-07-13T00:00:00+09:30" start-time-utc="2026-07-11T14:30:00Z" end-time-utc="2026-07-12T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds west to southwesterly 15 to 25 km/h tending south to southwesterly 15 to 20 km/h before dawn then becoming light in the evening. Overnight temperatures falling to between 5 and 9 with daytime temperatures reaching between 15 and 19.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-13T00:00:00+09:30" end-time-local="2026-07-14T00:00:00+09:30" start-time-utc="2026-07-12T14:30:00Z" end-time-utc="2026-07-13T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower about the Gammon Ranges, near zero chance elsewhere. Light winds becoming west to southwesterly 15 to 25 km/h during the morning then becoming light during the evening. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching between 16 and 19.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-14T00:00:00+09:30" end-time-local="2026-07-15T00:00:00+09:30" start-time-utc="2026-07-13T14:30:00Z" end-time-utc="2026-07-14T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower south of Yunta, near zero chance elsewhere. Winds west to southwesterly 15 to 20 km/h turning south to southeasterly 15 to 25 km/h during the morning. Overnight temperatures falling to around 7 with daytime temperatures reaching between 17 and 21.</text>
            </forecast-period>
        </area>
