    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-12T09:18:41+09:30" end-time-local="2026-05-12T09:18:41+09:30" start-time-utc="2026-05-11T23:48:41Z" end-time-utc="2026-05-11T23:48:41Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system near Tasmania is slowly moving east, reaching the Tasman Sea by tomorrow. A trough of low pressure lies across the northeast. Another trough moves into the far west late on Friday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-12T00:00:00+09:30" end-time-local="2026-05-13T00:00:00+09:30" start-time-utc="2026-05-11T14:30:00Z" end-time-utc="2026-05-12T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers north of Leigh Creek, near zero chance elsewhere. The chance of a thunderstorm north of Leigh Creek in the late morning and afternoon. Winds east to southeasterly 20 to 30 km/h. Daytime maximum temperatures 21 to 26.</text>
                <text type="uv_alert">Sun protection 10:10am to 2:10pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-13T00:00:00+09:30" end-time-local="2026-05-14T00:00:00+09:30" start-time-utc="2026-05-12T14:30:00Z" end-time-utc="2026-05-13T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers in the far northeast, medium chance elsewhere. The chance of a thunderstorm east of Leigh Creek in the morning and afternoon. Winds east to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 11 and 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-14T00:00:00+09:30" end-time-local="2026-05-15T00:00:00+09:30" start-time-utc="2026-05-13T14:30:00Z" end-time-utc="2026-05-14T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers in the far northeast, slight chance elsewhere. The chance of a thunderstorm east of Leigh Creek in the morning and afternoon. Winds east to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 11 and 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-15T00:00:00+09:30" end-time-local="2026-05-16T00:00:00+09:30" start-time-utc="2026-05-14T14:30:00Z" end-time-utc="2026-05-15T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers south of Yunta, medium chance elsewhere. The chance of a thunderstorm in the evening. Winds east to northeasterly 20 to 30 km/h tending north to northeasterly during the day then becoming light during the evening. Overnight temperatures falling to between 11 and 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
