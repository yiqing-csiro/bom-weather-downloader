    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-25T21:17:51+10:30" end-time-local="2026-03-25T21:17:51+10:30" start-time-utc="2026-03-25T10:47:51Z" end-time-utc="2026-03-25T10:47:51Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A broad trough lies over eastern SA. A cold front will clip the southeast tomorrow as a high pressure system starts to build south of the Bight. The high will become established south of SA by Friday before starting to move east towards the Tasman Sea on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-25T21:00:00+10:30" end-time-local="2026-03-26T00:00:00+10:30" start-time-utc="2026-03-25T10:30:00Z" end-time-utc="2026-03-25T13:30:00Z">
                <text type="forecast">Mostly clear. Slight chance of a shower south of Yunta, near zero chance elsewhere. The chance of a thunderstorm south of Yunta, possibly severe with damaging winds, large hail and heavy rain which may lead to flash flooding. Winds southeast to southwesterly 15 to 20 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-26T00:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-25T13:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers east of Leigh Creek in the morning and afternoon. Near zero chance of rain elsewhere. The chance of a thunderstorm in the morning and afternoon. Winds east to southeasterly 15 to 20 km/h turning southerly 30 to 45 km/h during the morning. Overnight temperatures falling to between 17 and 23 with daytime temperatures reaching 23 to 37.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 4:40pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Sunny. Winds south to southeasterly 30 to 45 km/h. Overnight temperatures falling to between 8 and 17 with daytime temperatures reaching between 18 and 25.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-28T00:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-27T13:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Sunny. Winds southeasterly 25 to 35 km/h. Overnight temperatures falling to between 8 and 13 with daytime temperatures reaching 20 to 25.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 10 and 13 with daytime temperatures reaching the low to high 20s.</text>
            </forecast-period>
        </area>
