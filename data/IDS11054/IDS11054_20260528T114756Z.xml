        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-28T21:17:57+09:30" end-time-local="2026-05-28T21:17:57+09:30" start-time-utc="2026-05-28T11:47:57Z" end-time-utc="2026-05-28T11:47:57Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A weak ridge of high pressure across SA on Thursday ahead of a series of cold fronts moving across the south on Friday and Saturday. A weak high pressure system moves across from west on Sunday, followed by a significant low pressure system moving south of the Bight Monday and into western Bass Strait on Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-28T21:00:00+09:30" end-time-local="2026-05-29T00:00:00+09:30" start-time-utc="2026-05-28T11:30:00Z" end-time-utc="2026-05-28T14:30:00Z">
                <text type="forecast">Mostly clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-29T00:00:00+09:30" end-time-local="2026-05-30T00:00:00+09:30" start-time-utc="2026-05-28T14:30:00Z" end-time-utc="2026-05-29T14:30:00Z">
                <text type="forecast">Mostly sunny. The chance of morning fog south of Leigh Creek. Light winds becoming west to northwesterly 15 to 25 km/h in the morning then becoming light in the evening. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching between 19 and 25.</text>
                <text type="uv_alert">Sun protection 10:30am to 1:50pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-30T00:00:00+09:30" end-time-local="2026-05-31T00:00:00+09:30" start-time-utc="2026-05-29T14:30:00Z" end-time-utc="2026-05-30T14:30:00Z">
                <text type="forecast">Mostly sunny. High chance of showers south of Yunta, most likely in the afternoon and evening. Near zero chance of rain elsewhere. Winds northwest to southwesterly 15 to 20 km/h becoming light in the early morning then becoming west to southwesterly 15 to 25 km/h in the morning. Overnight temperatures falling to between 8 and 11 with daytime temperatures reaching between 19 and 25.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-31T00:00:00+09:30" end-time-local="2026-06-01T00:00:00+09:30" start-time-utc="2026-05-30T14:30:00Z" end-time-utc="2026-05-31T14:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Yunta, near zero chance elsewhere. Winds west to southwesterly 15 to 20 km/h becoming light during the afternoon then becoming east to northeasterly 15 to 20 km/h during the evening. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching between 17 and 24.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-06-01T00:00:00+09:30" end-time-local="2026-06-02T00:00:00+09:30" start-time-utc="2026-05-31T14:30:00Z" end-time-utc="2026-06-01T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers south of Leigh Creek, near zero chance elsewhere. Winds north to northeasterly 20 to 30 km/h tending north to northwesterly 30 to 45 km/h during the day. Overnight temperatures falling to between 7 and 15 with daytime temperatures reaching 20 to 32.</text>
            </forecast-period>
        </area>
