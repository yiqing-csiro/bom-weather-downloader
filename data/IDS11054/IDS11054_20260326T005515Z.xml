            <forecast-period index="0" start-time-local="2026-03-26T00:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-25T13:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers east of Leigh Creek, becoming less likely in the late afternoon and evening. Near zero chance of rain elsewhere. The chance of a thunderstorm east of Leigh Creek in the late morning and afternoon. Winds southerly 25 to 40 km/h increasing to 30 to 45 km/h in the late afternoon. Daytime maximum temperatures 23 to 37.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 4:40pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Sunny. Winds south to southeasterly 30 to 45 km/h. Overnight temperatures falling to between 8 and 17 with daytime temperatures reaching between 19 and 25.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-28T00:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-27T13:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to between 8 and 13 with daytime temperatures reaching 20 to 25.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to southeasterly 20 to 30 km/h. Overnight temperatures falling to around 12 with daytime temperatures reaching the low to high 20s.</text>
