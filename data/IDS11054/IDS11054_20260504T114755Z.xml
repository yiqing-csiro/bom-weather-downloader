    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-04T21:17:56+09:30" end-time-local="2026-05-04T21:17:56+09:30" start-time-utc="2026-05-04T11:47:56Z" end-time-utc="2026-05-04T11:47:56Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A low pressure system in Bass Strait and associated trough will clear eastwards, weakening their influence of SA by Monday evening. A ridge of high pressure will begin to extend from the west on Tuesday and will be briefly be weakened as a cold front crosses the southeast on Wednesday afternoon. The ridge will begin to re-establish in the wake of the front and stabilise over SA with the slow moving high pressure centre sitting south of WA by Friday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-04T21:00:00+09:30" end-time-local="2026-05-05T00:00:00+09:30" start-time-utc="2026-05-04T11:30:00Z" end-time-utc="2026-05-04T14:30:00Z">
                <text type="forecast">Mostly clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-05T00:00:00+09:30" end-time-local="2026-05-06T00:00:00+09:30" start-time-utc="2026-05-04T14:30:00Z" end-time-utc="2026-05-05T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds southerly 15 to 20 km/h becoming light in the early morning then becoming south to southeasterly 15 to 25 km/h in the morning. Overnight temperatures falling to between 6 and 11 with daytime temperatures reaching between 19 and 23.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">##</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-06T00:00:00+09:30" end-time-local="2026-05-07T00:00:00+09:30" start-time-utc="2026-05-05T14:30:00Z" end-time-utc="2026-05-06T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower south of Yunta in the evening. Near zero chance of rain elsewhere. Light winds becoming south to southeasterly 15 to 25 km/h in the morning. Overnight temperatures falling to between 6 and 11 with daytime temperatures reaching between 19 and 23.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-07T00:00:00+09:30" end-time-local="2026-05-08T00:00:00+09:30" start-time-utc="2026-05-06T14:30:00Z" end-time-utc="2026-05-07T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds south to southeasterly 30 to 45 km/h. Overnight temperatures falling to between 6 and 11 with daytime temperatures reaching between 15 and 22.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Yunta, near zero chance elsewhere. Winds south to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 4 and 7 with daytime temperatures reaching around 18.</text>
            </forecast-period>
        </area>
