    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-01T10:24:42+10:30" end-time-local="2026-04-01T10:24:42+10:30" start-time-utc="2026-03-31T23:54:42Z" end-time-utc="2026-03-31T23:54:42Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system southwest of Perth extends a ridge over SA. The ridge will weaken overnight to allow the tail end of a cold front to brush the southeast of SA later Thursday. The high is forecast to move east on Friday to be southeast of Tasmania by Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-01T00:00:00+10:30" end-time-local="2026-04-02T00:00:00+10:30" start-time-utc="2026-03-31T13:30:00Z" end-time-utc="2026-04-01T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Yunta, becoming less likely in the afternoon. Near zero chance of rain elsewhere. The chance of a thunderstorm south of Leigh Creek in the late morning and early afternoon. Light winds becoming south to southeasterly 15 to 25 km/h in the late afternoon. Daytime maximum temperatures 28 to 36.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 4:30pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-02T00:00:00+10:30" end-time-local="2026-04-03T00:00:00+10:30" start-time-utc="2026-04-01T13:30:00Z" end-time-utc="2026-04-02T13:30:00Z">
                <text type="forecast">Sunny. Winds south to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 15 and 21 with daytime temperatures reaching 29 to 36.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-03T00:00:00+10:30" end-time-local="2026-04-04T00:00:00+10:30" start-time-utc="2026-04-02T13:30:00Z" end-time-utc="2026-04-03T13:30:00Z">
                <text type="forecast">Sunny. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to between 14 and 22 with daytime temperatures reaching 27 to 35.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-04T00:00:00+10:30" end-time-local="2026-04-05T00:00:00+10:30" start-time-utc="2026-04-03T13:30:00Z" end-time-utc="2026-04-04T13:30:00Z">
