    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-04T09:17:03+09:30" end-time-local="2026-07-04T09:17:03+09:30" start-time-utc="2026-07-03T23:47:03Z" end-time-utc="2026-07-03T23:47:03Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system southwest of the Bight extends a ridge the west. The high will dominate the weather pattern over the weekend as it slowly moves east, reaching the Tasman Sea by Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-04T00:00:00+09:30" end-time-local="2026-07-05T00:00:00+09:30" start-time-utc="2026-07-03T14:30:00Z" end-time-utc="2026-07-04T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower about the Gammon Ranges, near zero chance elsewhere. Winds southeasterly 15 to 25 km/h. Daytime maximum temperatures between 14 and 18.</text>
                <text type="uv_alert">Sun protection 11:40am to 12:50pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-05T00:00:00+09:30" end-time-local="2026-07-06T00:00:00+09:30" start-time-utc="2026-07-04T14:30:00Z" end-time-utc="2026-07-05T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower south of Yunta, near zero chance elsewhere. Winds southeasterly 25 to 35 km/h. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching between 13 and 18.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-06T00:00:00+09:30" end-time-local="2026-07-07T00:00:00+09:30" start-time-utc="2026-07-05T14:30:00Z" end-time-utc="2026-07-06T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog south of Yunta. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to between 3 and 7 with daytime temperatures reaching between 15 and 19.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-07T00:00:00+09:30" end-time-local="2026-07-08T00:00:00+09:30" start-time-utc="2026-07-06T14:30:00Z" end-time-utc="2026-07-07T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog south of Yunta. Slight chance of a shower west of Leigh Creek, most likely in the evening. Near zero chance of rain elsewhere. Winds east to southeasterly 25 to 35 km/h. Overnight temperatures falling to between 5 and 10 with daytime temperatures reaching between 16 and 23.</text>
            </forecast-period>
        </area>
