    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-24T09:43:56+10:30" end-time-local="2026-03-24T09:43:56+10:30" start-time-utc="2026-03-23T23:13:56Z" end-time-utc="2026-03-23T23:13:56Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over the Tasman sea, extends a ridge over southern SA. A broad trough moves over SA Tuesday, then a cold front clips the southeast as an upper trough moves up over SA Wednesday and Thursday. A new ridge develops south of the Bight late in the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-24T00:00:00+10:30" end-time-local="2026-03-25T00:00:00+10:30" start-time-utc="2026-03-23T13:30:00Z" end-time-utc="2026-03-24T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to northeasterly 15 to 25 km/h tending east to southeasterly 15 to 20 km/h in the evening. Daytime maximum temperatures 31 to 37.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:50am to 4:50pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-25T00:00:00+10:30" end-time-local="2026-03-26T00:00:00+10:30" start-time-utc="2026-03-24T13:30:00Z" end-time-utc="2026-03-25T13:30:00Z">
                <text type="forecast">Mostly sunny. Medium chance of showers south of Yunta in the afternoon and evening. Near zero chance of rain elsewhere. The chance of a thunderstorm south of Leigh Creek in the afternoon and evening. Winds northeast to southeasterly 15 to 20 km/h tending southeast to southwesterly 15 to 25 km/h in the late afternoon. Overnight temperatures falling to between 19 and 24 with daytime temperatures reaching the low to high 30s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-26T00:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-25T13:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers east of Leigh Creek, most likely in the morning and afternoon. Near zero chance of rain elsewhere. The chance of a thunderstorm east of Leigh Creek in the morning and afternoon. Winds south to southeasterly 25 to 35 km/h increasing to 25 to 40 km/h during the afternoon. Overnight temperatures falling to between 17 and 23 with daytime temperatures reaching 22 to 37.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Sunny. Winds south to southeasterly 30 to 45 km/h. Overnight temperatures falling to between 8 and 17 with daytime temperatures reaching between 18 and 25.</text>
            </forecast-period>
        </area>
