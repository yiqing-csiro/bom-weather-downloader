    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-29T21:19:10+09:30" end-time-local="2026-04-29T21:19:10+09:30" start-time-utc="2026-04-29T11:49:10Z" end-time-utc="2026-04-29T11:49:10Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system over the Tasman Sea will maintain a ridge across South Australia through to Friday. Northerly winds freshen on Friday ahead of a front that is forecast to move across the far west Friday afternoon, then continue across the state during the weekend. The low pressure system associated with this front is expected to cross south SA and bring a following trough across southern coasts late Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-29T21:00:00+09:30" end-time-local="2026-04-30T00:00:00+09:30" start-time-utc="2026-04-29T11:30:00Z" end-time-utc="2026-04-29T14:30:00Z">
                <text type="forecast">Mostly clear. Winds easterly 15 to 20 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-30T00:00:00+09:30" end-time-local="2026-05-01T00:00:00+09:30" start-time-utc="2026-04-29T14:30:00Z" end-time-utc="2026-04-30T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to northeasterly 20 to 30 km/h. Overnight temperatures falling to between 11 and 17 with daytime temperatures reaching 26 to 31.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">##</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-01T00:00:00+09:30" end-time-local="2026-05-02T00:00:00+09:30" start-time-utc="2026-04-30T14:30:00Z" end-time-utc="2026-05-01T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds east to northeasterly 15 to 20 km/h turning northerly 25 to 35 km/h during the morning then tending northeasterly 15 to 25 km/h in the late afternoon. Overnight temperatures falling to between 12 and 17 with daytime temperatures reaching 27 to 32.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-02T00:00:00+09:30" end-time-local="2026-05-03T00:00:00+09:30" start-time-utc="2026-05-01T14:30:00Z" end-time-utc="2026-05-02T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers south of Yunta, slight chance elsewhere. The chance of a thunderstorm in the evening, possibly severe with damaging winds south of Leigh Creek. Winds north to northeasterly 20 to 30 km/h increasing to 25 to 40 km/h during the morning then shifting south to southwesterly 20 to 30 km/h during the day. Overnight temperatures falling to between 17 and 21 with daytime temperatures reaching 26 to 33.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-03T00:00:00+09:30" end-time-local="2026-05-04T00:00:00+09:30" start-time-utc="2026-05-02T14:30:00Z" end-time-utc="2026-05-03T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the morning and afternoon. The chance of a thunderstorm east of Leigh Creek. Winds south to southwesterly 20 to 30 km/h. Overnight temperatures falling to between 9 and 17 with daytime temperatures reaching between 19 and 27.</text>
            </forecast-period>
        </area>
