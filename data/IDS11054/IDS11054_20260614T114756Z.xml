    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-14T21:17:56+09:30" end-time-local="2026-06-14T21:17:56+09:30" start-time-utc="2026-06-14T11:47:56Z" end-time-utc="2026-06-14T11:47:56Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A weak high pressure system to the east extends a ridge over SA. A northerly flow across South Australia will increase ahead of a slow-moving low pressure system that is expected to track along the SA coast this week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-14T21:00:00+09:30" end-time-local="2026-06-15T00:00:00+09:30" start-time-utc="2026-06-14T11:30:00Z" end-time-utc="2026-06-14T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower about the Gammon Ranges, near zero chance elsewhere. Winds east to southeasterly 15 to 20 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-15T00:00:00+09:30" end-time-local="2026-06-16T00:00:00+09:30" start-time-utc="2026-06-14T14:30:00Z" end-time-utc="2026-06-15T14:30:00Z">
                <text type="forecast">Partly cloudy. Patchy fog south of Yunta in the early morning. Medium chance of showers south of Yunta, most likely in the afternoon and evening. Near zero chance of rain elsewhere. Winds easterly 15 to 20 km/h turning northeasterly 20 to 30 km/h during the morning. Overnight temperatures falling to between 10 and 16 with daytime temperatures reaching 22 to 29.</text>
                <text type="uv_alert">Sun protection 11:00am to 1:40pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-16T00:00:00+09:30" end-time-local="2026-06-17T00:00:00+09:30" start-time-utc="2026-06-15T14:30:00Z" end-time-utc="2026-06-16T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers south of Yunta, most likely in the early morning. Near zero chance of rain elsewhere. Winds northeasterly 25 to 35 km/h. Overnight temperatures falling to between 13 and 17 with daytime temperatures reaching 22 to 29.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-17T00:00:00+09:30" end-time-local="2026-06-18T00:00:00+09:30" start-time-utc="2026-06-16T14:30:00Z" end-time-utc="2026-06-17T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers south of Leigh Creek, high chance elsewhere. The chance of a thunderstorm in the evening. Winds north to northeasterly 30 to 45 km/h tending northwest to southwesterly 15 to 25 km/h during the evening. Overnight temperatures falling to between 13 and 19 with daytime temperatures reaching 23 to 29.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-06-18T00:00:00+09:30" end-time-local="2026-06-19T00:00:00+09:30" start-time-utc="2026-06-17T14:30:00Z" end-time-utc="2026-06-18T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers in the far northeast, medium chance elsewhere. Winds west to northwesterly 25 to 35 km/h. Overnight temperatures falling to between 8 and 15 with daytime temperatures reaching between 17 and 21.</text>
            </forecast-period>
        </area>
