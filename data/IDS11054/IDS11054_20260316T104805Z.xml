        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-16T21:18:05+10:30" end-time-local="2026-03-16T21:18:05+10:30" start-time-utc="2026-03-16T10:48:05Z" end-time-utc="2026-03-16T10:48:05Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A trough over eastern and northern SA will continue to move northeastwards clearing the State by Thursday. A ridge of high pressure persists to the south.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW014" description="North East Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-16T21:00:00+10:30" end-time-local="2026-03-17T00:00:00+10:30" start-time-utc="2026-03-16T10:30:00Z" end-time-utc="2026-03-16T13:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain west of Leigh Creek, medium chance elsewhere. The chance of a thunderstorm, possibly severe with heavy rain which may lead to flash flooding west of Leigh Creek. Winds northeast to southeasterly 20 to 30 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-17T00:00:00+10:30" end-time-local="2026-03-18T00:00:00+10:30" start-time-utc="2026-03-16T13:30:00Z" end-time-utc="2026-03-17T13:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain, most likely in the morning. The chance of a thunderstorm north of Leigh Creek, possibly severe with heavy rain which may lead to flash flooding. Winds northeast to southeasterly 25 to 35 km/h tending southeast to southwesterly 20 to 30 km/h in the evening then tending northeast to southeasterly in the late evening. Overnight temperatures falling to between 17 and 25 with daytime temperatures reaching 22 to 30.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:40am to 5:00pm, UV Index predicted to reach 11 [Extreme]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-18T00:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-17T13:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain in the far northeast, medium chance elsewhere. The chance of a thunderstorm north of Leigh Creek in the early morning. Winds northeast to southeasterly 20 to 30 km/h tending southeast to southwesterly 25 to 35 km/h in the early morning. Overnight temperatures falling to between 18 and 22 with daytime temperatures reaching 23 to 29.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-19T00:00:00+10:30" end-time-local="2026-03-20T00:00:00+10:30" start-time-utc="2026-03-18T13:30:00Z" end-time-utc="2026-03-19T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Winds south to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 17 and 22 with daytime temperatures reaching 25 to 30.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-20T00:00:00+10:30" end-time-local="2026-03-21T00:00:00+10:30" start-time-utc="2026-03-19T13:30:00Z" end-time-utc="2026-03-20T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to between 17 and 22 with daytime temperatures reaching 28 to 33.</text>
            </forecast-period>
        </area>
