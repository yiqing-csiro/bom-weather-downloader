    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-09T09:17:56+09:30" end-time-local="2026-04-09T09:17:56+09:30" start-time-utc="2026-04-08T23:47:56Z" end-time-utc="2026-04-08T23:47:56Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A cold front sweeps across southern SA today. This front will push the inland trough into the far north, exiting the state early Friday. A cooler southwest to southerly flow will gradually moderate in the wake of the front as a strong high pressure system moves in from the west from Friday, establishing in the Bight on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW002" description="Yorke Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-09T00:00:00+09:30" end-time-local="2026-04-10T00:00:00+09:30" start-time-utc="2026-04-08T14:30:00Z" end-time-utc="2026-04-09T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, becoming less likely in the afternoon. The chance of a thunderstorm in the late morning and afternoon. Winds westerly 25 to 35 km/h increasing to 25 to 40 km/h in the late evening. Daytime maximum temperatures in the low to mid 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:40am to 3:00pm, UV Index predicted to reach 6 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-10T00:00:00+09:30" end-time-local="2026-04-11T00:00:00+09:30" start-time-utc="2026-04-09T14:30:00Z" end-time-utc="2026-04-10T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers, most likely in the late afternoon and evening. Winds westerly 30 to 45 km/h turning southwesterly 25 to 40 km/h in the late afternoon. Overnight temperatures falling to around 14 with daytime temperatures reaching around 20.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-11T00:00:00+09:30" end-time-local="2026-04-12T00:00:00+09:30" start-time-utc="2026-04-10T14:30:00Z" end-time-utc="2026-04-11T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, most likely in the morning. Winds southwesterly 25 to 35 km/h. Overnight temperatures falling to around 11 with daytime temperatures reaching around 19.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-12T00:00:00+09:30" end-time-local="2026-04-13T00:00:00+09:30" start-time-utc="2026-04-11T14:30:00Z" end-time-utc="2026-04-12T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. Winds southwesterly 20 to 30 km/h becoming light during the evening. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching around 20.</text>
            </forecast-period>
        </area>
