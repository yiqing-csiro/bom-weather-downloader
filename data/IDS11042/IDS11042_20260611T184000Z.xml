    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-12T04:10:07+09:30" end-time-local="2026-06-12T04:10:07+09:30" start-time-utc="2026-06-11T18:40:07Z" end-time-utc="2026-06-11T18:40:07Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system in the Tasman Sea maintains a ridge over SA. A cold front will move across the Bight on Friday with a weak high pressure system developing over southern Australia over the weekend. A trough of low pressure moves into the far west on Monday as an associated low pressure system moves into the Bight.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW002" description="Yorke Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-12T00:00:00+09:30" end-time-local="2026-06-13T00:00:00+09:30" start-time-utc="2026-06-11T14:30:00Z" end-time-utc="2026-06-12T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower, most likely later tonight. Winds northerly 30 to 45 km/h. Daytime maximum temperatures in the low 20s.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-13T00:00:00+09:30" end-time-local="2026-06-14T00:00:00+09:30" start-time-utc="2026-06-12T14:30:00Z" end-time-utc="2026-06-13T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain, most likely in the morning and afternoon. Winds north to northwesterly 25 to 40 km/h shifting southerly 15 to 20 km/h in the early afternoon. Overnight temperatures falling to around 12 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-14T00:00:00+09:30" end-time-local="2026-06-15T00:00:00+09:30" start-time-utc="2026-06-13T14:30:00Z" end-time-utc="2026-06-14T14:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming easterly 15 to 25 km/h during the morning then tending northeasterly 15 to 20 km/h during the evening. Overnight temperatures falling to around 8 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-15T00:00:00+09:30" end-time-local="2026-06-16T00:00:00+09:30" start-time-utc="2026-06-14T14:30:00Z" end-time-utc="2026-06-15T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds northeasterly 15 to 20 km/h turning northerly 20 to 30 km/h during the morning. Overnight temperatures falling to around 9 with daytime temperatures reaching around 18.</text>
            </forecast-period>
        </area>
