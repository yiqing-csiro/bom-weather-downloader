    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-02T15:55:06+09:30" end-time-local="2026-06-02T15:55:06+09:30" start-time-utc="2026-06-02T06:25:06Z" end-time-utc="2026-06-02T06:25:06Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A significant low pressure system west of TAS extends a trough over SA. A second weak low pressure system moves over waters to the south on Wednesday extending a cold front over coastal parts late Wednesday into Thursday. A high pressure system develops over western and northern parts on Friday and a cold front embedded in the southwesterly flow clips the south.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW002" description="Yorke Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-02T15:00:00+09:30" end-time-local="2026-06-03T00:00:00+09:30" start-time-utc="2026-06-02T05:30:00Z" end-time-utc="2026-06-02T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers. The chance of a thunderstorm in the south early this evening. Winds westerly 35 to 55 km/h decreasing to 25 to 40 km/h in the late evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-03T00:00:00+09:30" end-time-local="2026-06-04T00:00:00+09:30" start-time-utc="2026-06-02T14:30:00Z" end-time-utc="2026-06-03T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. The chance of a thunderstorm in the evening. Winds westerly 25 to 35 km/h. Overnight temperatures falling to around 10 with daytime temperatures reaching around 17.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-04T00:00:00+09:30" end-time-local="2026-06-05T00:00:00+09:30" start-time-utc="2026-06-03T14:30:00Z" end-time-utc="2026-06-04T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers, most likely in the early morning. Winds westerly 25 to 35 km/h turning southwesterly before dawn. Overnight temperatures falling to around 9 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-05T00:00:00+09:30" end-time-local="2026-06-06T00:00:00+09:30" start-time-utc="2026-06-04T14:30:00Z" end-time-utc="2026-06-05T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the morning. Winds southwesterly 15 to 25 km/h turning westerly 15 to 20 km/h during the afternoon. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-06-06T00:00:00+09:30" end-time-local="2026-06-07T00:00:00+09:30" start-time-utc="2026-06-05T14:30:00Z" end-time-utc="2026-06-06T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog in the north. Medium chance of showers, most likely in the morning and afternoon. Winds west to northwesterly 15 to 20 km/h becoming light during the afternoon. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching around 18.</text>
            </forecast-period>
        </area>
