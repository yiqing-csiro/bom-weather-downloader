    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-13T09:19:44+10:30" end-time-local="2026-03-13T09:19:44+10:30" start-time-utc="2026-03-12T22:49:44Z" end-time-utc="2026-03-12T22:49:44Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure extends from a high south of Perth, across waters well south of SA. The high slowly moves eastwards to be centred well south of the Bight later and over the Tasman Sea by Saturday afternoon, with further high pressure systems building well south of the Bight. A trough over inland WA is expected to move across western and northern SA on Sunday and into the new week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW002" description="Yorke Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-13T00:00:00+10:30" end-time-local="2026-03-14T00:00:00+10:30" start-time-utc="2026-03-12T13:30:00Z" end-time-utc="2026-03-13T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds southeasterly 25 to 35 km/h. Daytime maximum temperatures 21 to 26.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 4:50pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-14T00:00:00+10:30" end-time-local="2026-03-15T00:00:00+10:30" start-time-utc="2026-03-13T13:30:00Z" end-time-utc="2026-03-14T13:30:00Z">
                <text type="forecast">Sunny. Winds east to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 12 and 15 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-15T00:00:00+10:30" end-time-local="2026-03-16T00:00:00+10:30" start-time-utc="2026-03-14T13:30:00Z" end-time-utc="2026-03-15T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to southeasterly 15 to 25 km/h tending south to southeasterly during the afternoon. Overnight temperatures falling to around 16 with daytime temperatures reaching 28 to 33.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-16T00:00:00+10:30" end-time-local="2026-03-17T00:00:00+10:30" start-time-utc="2026-03-15T13:30:00Z" end-time-utc="2026-03-16T13:30:00Z">
                <text type="forecast">Cloudy. High chance of showers, most likely in the morning and afternoon. Winds southeasterly 15 to 25 km/h. Overnight temperatures falling to around 17 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
        </area>
