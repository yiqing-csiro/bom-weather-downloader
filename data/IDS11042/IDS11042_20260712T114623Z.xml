        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-12T21:16:23+09:30" end-time-local="2026-07-12T21:16:23+09:30" start-time-utc="2026-07-12T11:46:23Z" end-time-utc="2026-07-12T11:46:23Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure lies over northern SA. A cold front will pass across southeastern SA on Monday before a strong high pressure system moves east mid week and begins to dominate the weather pattern.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW002" description="Yorke Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-12T21:00:00+09:30" end-time-local="2026-07-13T00:00:00+09:30" start-time-utc="2026-07-12T11:30:00Z" end-time-utc="2026-07-12T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Winds west to northwesterly 20 to 30 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-13T00:00:00+09:30" end-time-local="2026-07-14T00:00:00+09:30" start-time-utc="2026-07-12T14:30:00Z" end-time-utc="2026-07-13T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the late morning and afternoon. Winds northwesterly 25 to 35 km/h turning westerly in the late morning. Overnight temperatures falling to around 10 with daytime temperatures reaching around 16.</text>
                <text type="uv_alert">Sun protection 12:30pm to 1:30pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-14T00:00:00+09:30" end-time-local="2026-07-15T00:00:00+09:30" start-time-utc="2026-07-13T14:30:00Z" end-time-utc="2026-07-14T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers in the morning and afternoon. Winds westerly 15 to 25 km/h tending southwesterly in the middle of the day then becoming light in the late afternoon. Overnight temperatures falling to around 10 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-15T00:00:00+09:30" end-time-local="2026-07-16T00:00:00+09:30" start-time-utc="2026-07-14T14:30:00Z" end-time-utc="2026-07-15T14:30:00Z">
                <text type="forecast">The chance of morning fog. Mostly sunny afternoon. Light winds. Overnight temperatures falling to around 6 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-16T00:00:00+09:30" end-time-local="2026-07-17T00:00:00+09:30" start-time-utc="2026-07-15T14:30:00Z" end-time-utc="2026-07-16T14:30:00Z">
                <text type="forecast">Mostly sunny. Light winds. Overnight temperatures falling to between 3 and 6 with daytime temperatures reaching around 15.</text>
            </forecast-period>
