            <forecast-period index="3" start-time-local="2026-05-07T00:00:00+09:30" end-time-local="2026-05-08T00:00:00+09:30" start-time-utc="2026-05-06T14:30:00Z" end-time-utc="2026-05-07T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. Winds southerly 25 to 40 km/h turning southwesterly 20 to 30 km/h during the afternoon. Overnight temperatures falling to around 9 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers. Winds southwesterly 25 to 35 km/h turning southerly 15 to 25 km/h during the afternoon. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching around 20.</text>
            </forecast-period>
