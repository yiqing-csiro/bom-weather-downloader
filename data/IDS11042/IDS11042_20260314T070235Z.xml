        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-14T17:32:35+10:30" end-time-local="2026-03-14T17:32:35+10:30" start-time-utc="2026-03-14T07:02:35Z" end-time-utc="2026-03-14T07:02:35Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A trough over inland WA is expected to move across western and northern SA on Sunday and continues northeast early in the week. A ridge of high pressure persists over the south. A cold front clips the southeast early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW002" description="Yorke Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-14T15:00:00+10:30" end-time-local="2026-03-15T00:00:00+10:30" start-time-utc="2026-03-14T04:30:00Z" end-time-utc="2026-03-14T13:30:00Z">
                <text type="forecast">Clear. Winds southeasterly 15 to 25 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-15T00:00:00+10:30" end-time-local="2026-03-16T00:00:00+10:30" start-time-utc="2026-03-14T13:30:00Z" end-time-utc="2026-03-15T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the south in the evening. Near zero chance of rain elsewhere. Winds east to southeasterly 15 to 25 km/h tending south to southeasterly in the middle of the day. Overnight temperatures falling to around 16 with daytime temperatures reaching 28 to 33.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 4:50pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-16T00:00:00+10:30" end-time-local="2026-03-17T00:00:00+10:30" start-time-utc="2026-03-15T13:30:00Z" end-time-utc="2026-03-16T13:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely in the morning and afternoon. Winds southerly 15 to 25 km/h turning southeasterly 15 to 20 km/h in the morning. Overnight temperatures falling to around 17 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-17T00:00:00+10:30" end-time-local="2026-03-18T00:00:00+10:30" start-time-utc="2026-03-16T13:30:00Z" end-time-utc="2026-03-17T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the north in the morning. Near zero chance of rain elsewhere. Winds southeasterly 25 to 35 km/h. Overnight temperatures falling to around 16 with daytime temperatures reaching the low to high 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-18T00:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-17T13:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to around 16 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
