    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-23T16:37:52+09:30" end-time-local="2026-04-23T16:37:52+09:30" start-time-utc="2026-04-23T07:07:52Z" end-time-utc="2026-04-23T07:07:52Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system east of Tasmania will maintain a ridge over SA this week. A cold front will pass over the south on Saturday, weakening and clearing in the east early Sunday. A new high pressure system will develop in the Bight on Sunday, slowly drifting to the southeast on Monday while continuing to extend a ridge over SA.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW002" description="Yorke Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-23T15:00:00+09:30" end-time-local="2026-04-24T00:00:00+09:30" start-time-utc="2026-04-23T05:30:00Z" end-time-utc="2026-04-23T14:30:00Z">
                <text type="forecast">Mostly clear. Winds northerly 15 to 25 km/h turning northeasterly in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-24T00:00:00+09:30" end-time-local="2026-04-25T00:00:00+09:30" start-time-utc="2026-04-23T14:30:00Z" end-time-utc="2026-04-24T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds north to northeasterly 20 to 30 km/h. Overnight temperatures falling to between 13 and 17 with daytime temperatures reaching the mid to high 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 2:20pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-25T00:00:00+09:30" end-time-local="2026-04-26T00:00:00+09:30" start-time-utc="2026-04-24T14:30:00Z" end-time-utc="2026-04-25T14:30:00Z">
                <text type="forecast">Mostly sunny morning. High chance of showers in the late afternoon and evening. The chance of a thunderstorm in the evening. Winds northerly 25 to 35 km/h shifting west to southwesterly 15 to 25 km/h in the late afternoon. Overnight temperatures falling to between 14 and 17 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-26T00:00:00+09:30" end-time-local="2026-04-27T00:00:00+09:30" start-time-utc="2026-04-25T14:30:00Z" end-time-utc="2026-04-26T14:30:00Z">
                <text type="forecast">Medium chance of showers, most likely in the morning. The chance of a thunderstorm in the morning. Mostly sunny afternoon. Winds southwesterly 15 to 25 km/h turning south to southeasterly 15 to 20 km/h during the afternoon. Overnight temperatures falling to around 12 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-27T00:00:00+09:30" end-time-local="2026-04-28T00:00:00+09:30" start-time-utc="2026-04-26T14:30:00Z" end-time-utc="2026-04-27T14:30:00Z">
                <text type="forecast">Mostly sunny. The chance of morning fog in the north. Winds southeasterly 15 to 20 km/h tending southerly during the afternoon then becoming light during the evening. Overnight temperatures falling to around 11 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
        </area>
