    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-19T04:10:10+09:30" end-time-local="2026-06-19T04:10:10+09:30" start-time-utc="2026-06-18T18:40:10Z" end-time-utc="2026-06-18T18:40:10Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A low pressure system south of the Bight will drift to the south east while a trough extends across western coasts. This trough will linger along the coastline into Friday, developing into the cold front that will clear into the east early Saturday. A high pressure system will begin to move in from the west on Saturday, cross the Bight, slowly drifting to eastern SA by Monday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW002" description="Yorke Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-19T00:00:00+09:30" end-time-local="2026-06-20T00:00:00+09:30" start-time-utc="2026-06-18T14:30:00Z" end-time-utc="2026-06-19T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds west to southwesterly 25 to 40 km/h tending south to southwesterly 15 to 20 km/h during the day. Daytime maximum temperatures around 16.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-20T00:00:00+09:30" end-time-local="2026-06-21T00:00:00+09:30" start-time-utc="2026-06-19T14:30:00Z" end-time-utc="2026-06-20T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the early morning. Winds southerly 15 to 25 km/h becoming light in the late evening. Overnight temperatures falling to around 8 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-21T00:00:00+09:30" end-time-local="2026-06-22T00:00:00+09:30" start-time-utc="2026-06-20T14:30:00Z" end-time-utc="2026-06-21T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog in the north. Medium chance of showers in the south, slight chance elsewhere. Light winds. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-22T00:00:00+09:30" end-time-local="2026-06-23T00:00:00+09:30" start-time-utc="2026-06-21T14:30:00Z" end-time-utc="2026-06-22T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the south, near zero chance elsewhere. Light winds becoming northwesterly 15 to 20 km/h during the day then becoming light during the afternoon. Overnight temperatures falling to around 5 with daytime temperatures reaching around 15.</text>
            </forecast-period>
        </area>
