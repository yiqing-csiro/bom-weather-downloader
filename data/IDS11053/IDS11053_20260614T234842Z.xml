    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-15T09:18:43+09:30" end-time-local="2026-06-15T09:18:43+09:30" start-time-utc="2026-06-14T23:48:43Z" end-time-utc="2026-06-14T23:48:43Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A weak high pressure system to the east extends a ridge over SA. A northerly flow across South Australia will increase ahead of a slow-moving low pressure system that is expected to track along the SA coast this week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-15T00:00:00+09:30" end-time-local="2026-06-16T00:00:00+09:30" start-time-utc="2026-06-14T14:30:00Z" end-time-utc="2026-06-15T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers in the far west, high chance elsewhere. The chance of a thunderstorm west of Coober Pedy. Winds northerly 25 to 35 km/h. Daytime maximum temperatures in the low to mid 20s.</text>
                <text type="uv_alert">Sun protection 11:00am to 2:00pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-16T00:00:00+09:30" end-time-local="2026-06-17T00:00:00+09:30" start-time-utc="2026-06-15T14:30:00Z" end-time-utc="2026-06-16T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain. The chance of a thunderstorm. Winds northwest to northeasterly 25 to 35 km/h. Overnight temperatures falling to around 14 with daytime temperatures reaching 20 to 27.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-17T00:00:00+09:30" end-time-local="2026-06-18T00:00:00+09:30" start-time-utc="2026-06-16T14:30:00Z" end-time-utc="2026-06-17T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers east of Coober Pedy, medium chance elsewhere. The chance of a thunderstorm in the morning. Winds northwest to northeasterly 15 to 25 km/h tending west to northwesterly 25 to 35 km/h during the morning. Overnight temperatures falling to between 7 and 16 with daytime temperatures reaching between 15 and 21.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-18T00:00:00+09:30" end-time-local="2026-06-19T00:00:00+09:30" start-time-utc="2026-06-17T14:30:00Z" end-time-utc="2026-06-18T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers south of Coober Pedy, slight chance elsewhere. Winds west to northwesterly 25 to 40 km/h tending west to southwesterly during the day then decreasing to 20 to 30 km/h during the afternoon. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching between 13 and 18.</text>
            </forecast-period>
        </area>
