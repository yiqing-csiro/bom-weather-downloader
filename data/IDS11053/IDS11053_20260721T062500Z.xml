    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-21T15:55:55+09:30" end-time-local="2026-07-21T15:55:55+09:30" start-time-utc="2026-07-21T06:25:55Z" end-time-utc="2026-07-21T06:25:55Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A trough crosses South Australia on Tuesday evening, followed by a series of weak cold fronts that cross the south of the State during Wednesday. A ridge of high pressure will build over the west of the State from later Wednesday, with the high centre expected to cross South Australia on Friday and Saturday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-21T15:00:00+09:30" end-time-local="2026-07-22T00:00:00+09:30" start-time-utc="2026-07-21T05:30:00Z" end-time-utc="2026-07-21T14:30:00Z">
                <text type="forecast">Mostly clear. Winds northwest to southwesterly 15 to 20 km/h tending southeast to southwesterly in the late afternoon.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-22T00:00:00+09:30" end-time-local="2026-07-23T00:00:00+09:30" start-time-utc="2026-07-21T14:30:00Z" end-time-utc="2026-07-22T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower south of Woomera, near zero chance elsewhere. The chance of morning fog south of Coober Pedy. Winds south to southwesterly 15 to 25 km/h. Overnight temperatures falling to between 5 and 9 with daytime temperatures reaching between 17 and 21.</text>
                <text type="uv_alert">Sun protection 10:20am to 2:50pm, UV Index predicted to reach 5 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-23T00:00:00+09:30" end-time-local="2026-07-24T00:00:00+09:30" start-time-utc="2026-07-22T14:30:00Z" end-time-utc="2026-07-23T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the far west, near zero chance elsewhere. Winds south to southeasterly 20 to 30 km/h. Overnight temperatures falling to around 6 with daytime temperatures reaching between 15 and 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-24T00:00:00+09:30" end-time-local="2026-07-25T00:00:00+09:30" start-time-utc="2026-07-23T14:30:00Z" end-time-utc="2026-07-24T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to around 5 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-25T00:00:00+09:30" end-time-local="2026-07-26T00:00:00+09:30" start-time-utc="2026-07-24T14:30:00Z" end-time-utc="2026-07-25T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds east to southeasterly 15 to 20 km/h becoming light during the afternoon. Overnight temperatures falling to between 2 and 5 with daytime temperatures reaching around 15.</text>
            </forecast-period>
        </area>
