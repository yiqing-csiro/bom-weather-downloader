    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-28T15:55:51+10:30" end-time-local="2026-03-28T15:55:51+10:30" start-time-utc="2026-03-28T05:25:51Z" end-time-utc="2026-03-28T05:25:51Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of Kangaroo Island will move slowly eastwards this weekend to be centred over the Tasman Sea on Monday. A trough is forecast to move across the west and south later Tuesday, pushing into the northeast of SA on Wednesday. Another high pressure system is expected to become established south of the Bight later next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-28T15:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-28T04:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Mostly clear. Winds east to northeasterly 15 to 25 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Mostly sunny morning. The chance of a thunderstorm in the far west in the afternoon and evening. Winds east to northeasterly 15 to 25 km/h tending north to northeasterly 25 to 40 km/h during the morning then decreasing to 20 to 30 km/h in the early afternoon. Overnight temperatures falling to between 11 and 18 with daytime temperatures reaching 26 to 31.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 4:50pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-30T00:00:00+10:30" end-time-local="2026-03-31T00:00:00+10:30" start-time-utc="2026-03-29T13:30:00Z" end-time-utc="2026-03-30T13:30:00Z">
                <text type="forecast">Mostly sunny. The chance of a thunderstorm south of Coober Pedy. Winds north to northeasterly 20 to 30 km/h. Overnight temperatures falling to between 13 and 20 with daytime temperatures reaching 28 to 35.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-31T00:00:00+10:30" end-time-local="2026-04-01T00:00:00+10:30" start-time-utc="2026-03-30T13:30:00Z" end-time-utc="2026-03-31T13:30:00Z">
                <text type="forecast">Mostly sunny. Medium chance of showers west of Coober Pedy in the afternoon and evening. Near zero chance of rain elsewhere. The chance of a thunderstorm west of Coober Pedy in the afternoon and evening. Winds north to northeasterly 25 to 40 km/h tending north to northwesterly during the day then shifting south to southwesterly 15 to 20 km/h during the afternoon. Overnight temperatures falling to between 15 and 22 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-01T00:00:00+10:30" end-time-local="2026-04-02T00:00:00+10:30" start-time-utc="2026-03-31T13:30:00Z" end-time-utc="2026-04-01T13:30:00Z">
                <text type="forecast">Slight chance of a shower in the morning. The chance of a thunderstorm south of Woomera in the morning. Mostly sunny day. Winds south to southeasterly 15 to 25 km/h. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching 27 to 34.</text>
            </forecast-period>
        </area>
