    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-28T15:56:07+09:30" end-time-local="2026-04-28T15:56:07+09:30" start-time-utc="2026-04-28T06:26:07Z" end-time-utc="2026-04-28T06:26:07Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system over the Tasman Sea extends a ridge across South Australia through to Friday. Northerly winds freshen on Friday ahead of a trough that is forecast to move across the far west Friday afternoon, then continue across the state during the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-28T15:00:00+09:30" end-time-local="2026-04-29T00:00:00+09:30" start-time-utc="2026-04-28T05:30:00Z" end-time-utc="2026-04-28T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds northwest to northeasterly 15 to 20 km/h becoming light in the late afternoon then becoming east to northeasterly 15 to 20 km/h in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-29T00:00:00+09:30" end-time-local="2026-04-30T00:00:00+09:30" start-time-utc="2026-04-28T14:30:00Z" end-time-utc="2026-04-29T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to northeasterly 15 to 20 km/h tending north to northeasterly 20 to 30 km/h during the morning. Overnight temperatures falling to between 13 and 17 with daytime temperatures reaching around 30.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">##</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-30T00:00:00+09:30" end-time-local="2026-05-01T00:00:00+09:30" start-time-utc="2026-04-29T14:30:00Z" end-time-utc="2026-04-30T14:30:00Z">
                <text type="forecast">Sunny. Winds north to northeasterly 25 to 35 km/h. Overnight temperatures falling to between 14 and 17 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-01T00:00:00+09:30" end-time-local="2026-05-02T00:00:00+09:30" start-time-utc="2026-04-30T14:30:00Z" end-time-utc="2026-05-01T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers in the far west, most likely in the evening. Near zero chance of rain elsewhere. The chance of a thunderstorm west of Coober Pedy in the evening. Winds north to northeasterly 25 to 40 km/h. Overnight temperatures falling to between 14 and 19 with daytime temperatures reaching the low 30s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-02T00:00:00+09:30" end-time-local="2026-05-03T00:00:00+09:30" start-time-utc="2026-05-01T14:30:00Z" end-time-utc="2026-05-02T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers south of Coober Pedy, medium chance elsewhere. The chance of a thunderstorm. Winds northwest to northeasterly 25 to 35 km/h tending west to southwesterly during the morning then decreasing to 15 to 20 km/h during the evening. Overnight temperatures falling to between 10 and 19 with daytime temperatures reaching between 19 and 27.</text>
            </forecast-period>
        </area>
