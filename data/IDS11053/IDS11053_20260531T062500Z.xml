    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-31T15:55:51+09:30" end-time-local="2026-05-31T15:55:51+09:30" start-time-utc="2026-05-31T06:25:51Z" end-time-utc="2026-05-31T06:25:51Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A weak high pressure system moves into the eastern states overnight. A significant low pressure system moves over waters to the south of SA on Monday and Tuesday reaching western Bass Strait Tuesday afternoon. A another low pressure moves over waters to the south on Wednesday. A ridge of high pressure develops over western and northern parts as a series of troughs and fronts move over the south later in the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-31T15:00:00+09:30" end-time-local="2026-06-01T00:00:00+09:30" start-time-utc="2026-05-31T05:30:00Z" end-time-utc="2026-05-31T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers east of Coober Pedy, most likely later this evening. Near zero chance of rain elsewhere. Winds northerly 20 to 30 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-01T00:00:00+09:30" end-time-local="2026-06-02T00:00:00+09:30" start-time-utc="2026-05-31T14:30:00Z" end-time-utc="2026-06-01T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers south of Coober Pedy, most likely in the morning. Near zero chance of rain elsewhere. The chance of a thunderstorm south of Woomera. Damaging winds possible south of Woomera. Winds northerly 25 to 35 km/h turning west to northwesterly 40 to 60 km/h during the morning. Overnight temperatures falling to between 13 and 17 with daytime temperatures reaching 23 to 30.</text>
                <text type="uv_alert">Sun protection 10:40am to 2:10pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-02T00:00:00+09:30" end-time-local="2026-06-03T00:00:00+09:30" start-time-utc="2026-06-01T14:30:00Z" end-time-utc="2026-06-02T14:30:00Z">
                <text type="forecast">Mostly sunny. Medium chance of showers south of Woomera, most likely in the morning and afternoon. Near zero chance of rain elsewhere. Damaging winds possible south of Woomera. Winds west to southwesterly 35 to 50 km/h. Overnight temperatures falling to between 10 and 14 with daytime temperatures reaching around 20.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-03T00:00:00+09:30" end-time-local="2026-06-04T00:00:00+09:30" start-time-utc="2026-06-02T14:30:00Z" end-time-utc="2026-06-03T14:30:00Z">
                <text type="forecast">Mostly sunny. Medium chance of showers south of Woomera, most likely in the afternoon and evening. Near zero chance of rain elsewhere. Winds westerly 25 to 35 km/h. Overnight temperatures falling to between 5 and 10 with daytime temperatures reaching between 19 and 22.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-06-04T00:00:00+09:30" end-time-local="2026-06-05T00:00:00+09:30" start-time-utc="2026-06-03T14:30:00Z" end-time-utc="2026-06-04T14:30:00Z">
                <text type="forecast">Mostly sunny. Medium chance of showers south of Woomera, most likely in the morning and afternoon. Near zero chance of rain elsewhere. Winds westerly 20 to 30 km/h turning southwesterly 25 to 35 km/h during the day then decreasing to 15 to 25 km/h during the evening. Overnight temperatures falling to between 5 and 10 with daytime temperatures reaching around 19.</text>
            </forecast-period>
        </area>
