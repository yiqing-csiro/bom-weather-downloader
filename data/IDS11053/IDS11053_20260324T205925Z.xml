    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-25T07:29:26+10:30" end-time-local="2026-03-25T07:29:26+10:30" start-time-utc="2026-03-24T20:59:26Z" end-time-utc="2026-03-24T20:59:26Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A broad trough lies over SA. A cold front clips the southeast as an upper trough moves up over SA today and tomorrow. A high pressure system develops south of the Bight late in the week and persists over the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-25T00:00:00+10:30" end-time-local="2026-03-26T00:00:00+10:30" start-time-utc="2026-03-24T13:30:00Z" end-time-utc="2026-03-25T13:30:00Z">
                <text type="forecast">Mostly sunny. Medium chance of showers south of Woomera, most likely in the afternoon. Near zero chance of rain elsewhere. The chance of a thunderstorm south of Coober Pedy. Thunderstorms possibly severe with damaging winds, large hail and heavy rain which may lead to flash flooding south of Woomera in the late morning and afternoon. Winds northwest to northeasterly 15 to 25 km/h tending southeast to southwesterly 25 to 35 km/h in the late afternoon. Daytime maximum temperatures in the mid to high 30s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 5:00pm, UV Index predicted to reach 10 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-26T00:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-25T13:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower south of Woomera in the morning. Near zero chance of rain elsewhere. The chance of a thunderstorm south of Woomera in the early morning. Winds south to southeasterly 25 to 40 km/h. Overnight temperatures falling to between 16 and 22 with daytime temperatures reaching 25 to 34.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds southeasterly 25 to 35 km/h. Overnight temperatures falling to between 11 and 15 with daytime temperatures reaching 21 to 26.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-28T00:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-27T13:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to southeasterly 20 to 30 km/h. Overnight temperatures falling to around 12 with daytime temperatures reaching the low to high 20s.</text>
            </forecast-period>
        </area>
