        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-17T21:17:55+10:30" end-time-local="2026-03-17T21:17:55+10:30" start-time-utc="2026-03-17T10:47:55Z" end-time-utc="2026-03-17T10:47:55Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A low and trough over northeast SA will continue to move northeastwards clearing the State by Thursday. A ridge of high pressure persists to the south.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-17T21:00:00+10:30" end-time-local="2026-03-18T00:00:00+10:30" start-time-utc="2026-03-17T10:30:00Z" end-time-utc="2026-03-17T13:30:00Z">
                <text type="forecast">Cloudy. Winds southerly 15 to 25 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-18T00:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-17T13:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. Winds southerly 20 to 30 km/h. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching the low to high 20s.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 10:00am to 5:10pm, UV Index predicted to reach 10 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-19T00:00:00+10:30" end-time-local="2026-03-20T00:00:00+10:30" start-time-utc="2026-03-18T13:30:00Z" end-time-utc="2026-03-19T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. Winds southerly 15 to 25 km/h turning southeasterly 20 to 30 km/h in the late morning and early afternoon. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-20T00:00:00+10:30" end-time-local="2026-03-21T00:00:00+10:30" start-time-utc="2026-03-19T13:30:00Z" end-time-utc="2026-03-20T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower north of Coober Pedy in the morning. Near zero chance of rain elsewhere. Winds southeasterly 15 to 25 km/h. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-21T00:00:00+10:30" end-time-local="2026-03-22T00:00:00+10:30" start-time-utc="2026-03-20T13:30:00Z" end-time-utc="2026-03-21T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower north of Marla, most likely in the morning and afternoon. Near zero chance of rain elsewhere. Winds southeasterly 15 to 25 km/h. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching around 30.</text>
            </forecast-period>
        </area>
