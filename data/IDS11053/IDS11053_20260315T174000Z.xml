    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-16T04:10:52+10:30" end-time-local="2026-03-16T04:10:52+10:30" start-time-utc="2026-03-15T17:40:52Z" end-time-utc="2026-03-15T17:40:52Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A trough over western and northern SA will continue to move northeast early in the week. A ridge of high pressure persists over the south. A cold front clips the southeast on Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-16T00:00:00+10:30" end-time-local="2026-03-17T00:00:00+10:30" start-time-utc="2026-03-15T13:30:00Z" end-time-utc="2026-03-16T13:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain. The chance of a thunderstorm from late this morning, possibly severe with heavy rain which may lead to flash flooding north of Coober Pedy. Winds east to southeasterly 15 to 25 km/h tending south to southeasterly 20 to 30 km/h during the afternoon and evening. Daytime maximum temperatures 22 to 27.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 10:00am to 5:20pm, UV Index predicted to reach 12 [Extreme]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-17T00:00:00+10:30" end-time-local="2026-03-18T00:00:00+10:30" start-time-utc="2026-03-16T13:30:00Z" end-time-utc="2026-03-17T13:30:00Z">
                <text type="forecast">Cloudy. High chance of rain east of the Stuart Highway, medium chance elsewhere. The chance of a thunderstorm. Heavy falls possible. Winds south to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 16 and 20 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-18T00:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-17T13:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. The chance of a thunderstorm north of Marla in the morning. Winds south to southeasterly 20 to 30 km/h. Overnight temperatures falling to between 15 and 20 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-19T00:00:00+10:30" end-time-local="2026-03-20T00:00:00+10:30" start-time-utc="2026-03-18T13:30:00Z" end-time-utc="2026-03-19T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower east of Stuart Highway, near zero chance elsewhere. Winds southeasterly 15 to 25 km/h. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching around 30.</text>
            </forecast-period>
        </area>
