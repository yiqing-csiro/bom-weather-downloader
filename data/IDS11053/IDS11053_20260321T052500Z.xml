    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-21T15:55:49+10:30" end-time-local="2026-03-21T15:55:49+10:30" start-time-utc="2026-03-21T05:25:49Z" end-time-utc="2026-03-21T05:25:49Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over the Tasman sea, extends a ridge over southern SA. A broad trough moves over SA early next week, then a cold front clips the southeast and an upper trough moves up over SA Wednesday and Thursday. A new ridge develops south of the Bight mid next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-21T15:00:00+10:30" end-time-local="2026-03-22T00:00:00+10:30" start-time-utc="2026-03-21T04:30:00Z" end-time-utc="2026-03-21T13:30:00Z">
                <text type="forecast">Clear. Winds east to southeasterly 15 to 20 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-22T00:00:00+10:30" end-time-local="2026-03-23T00:00:00+10:30" start-time-utc="2026-03-21T13:30:00Z" end-time-utc="2026-03-22T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to southeasterly 15 to 20 km/h becoming light before dawn then becoming easterly 15 to 20 km/h in the morning. Overnight temperatures falling to between 17 and 20 with daytime temperatures reaching the low to mid 30s.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 10:00am to 5:10pm, UV Index predicted to reach 10 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-23T00:00:00+10:30" end-time-local="2026-03-24T00:00:00+10:30" start-time-utc="2026-03-22T13:30:00Z" end-time-utc="2026-03-23T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to northeasterly 15 to 25 km/h becoming light in the early afternoon then becoming east to southeasterly 15 to 20 km/h in the late evening. Overnight temperatures falling to around 20 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-24T00:00:00+10:30" end-time-local="2026-03-25T00:00:00+10:30" start-time-utc="2026-03-23T13:30:00Z" end-time-utc="2026-03-24T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to northeasterly 15 to 20 km/h becoming light during the day then becoming northeast to southeasterly 15 to 20 km/h during the evening. Overnight temperatures falling to around 20 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-25T00:00:00+10:30" end-time-local="2026-03-26T00:00:00+10:30" start-time-utc="2026-03-24T13:30:00Z" end-time-utc="2026-03-25T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Woomera in the afternoon. Near zero chance of rain elsewhere. The chance of a thunderstorm east of Coober Pedy in the afternoon. Winds northeast to southeasterly 15 to 20 km/h tending south to southeasterly 20 to 30 km/h during the afternoon. Overnight temperatures falling to around 20 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
        </area>
