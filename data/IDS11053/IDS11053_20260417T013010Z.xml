    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-17T11:00:10+09:30" end-time-local="2026-04-17T11:00:10+09:30" start-time-utc="2026-04-17T01:30:10Z" end-time-utc="2026-04-17T01:30:10Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of the Bight extends a ridge over SA. The high will move east during today and Saturday ahead of a weakening trough that is expected to brush the west and south on the weekend. The high is forecast to be over the Tasman Sea by Monday, extending a ridge over South Australia through until Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW013" description="North West Pastoral" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-17T00:00:00+09:30" end-time-local="2026-04-18T00:00:00+09:30" start-time-utc="2026-04-16T14:30:00Z" end-time-utc="2026-04-17T14:30:00Z">
                <text type="forecast">Mostly sunny. The chance of a thunderstorm in the far west in the afternoon and evening. Light winds becoming northeast to southeasterly 15 to 20 km/h in the early afternoon. Daytime maximum temperatures around 30.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 9:40am to 3:20pm, UV Index predicted to reach 7 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-18T00:00:00+09:30" end-time-local="2026-04-19T00:00:00+09:30" start-time-utc="2026-04-17T14:30:00Z" end-time-utc="2026-04-18T14:30:00Z">
                <text type="forecast">Mostly sunny. The chance of a thunderstorm in the far west. Winds northeasterly 15 to 20 km/h tending northwest to northeasterly 25 to 35 km/h in the early morning then becoming northeasterly 15 to 25 km/h in the evening. Overnight temperatures falling to between 13 and 20 with daytime temperatures reaching 30 to 36.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-19T00:00:00+09:30" end-time-local="2026-04-20T00:00:00+09:30" start-time-utc="2026-04-18T14:30:00Z" end-time-utc="2026-04-19T14:30:00Z">
                <text type="forecast">The chance of a thunderstorm south of Coober Pedy in the morning. Sunny afternoon. Winds northwest to northeasterly 15 to 25 km/h tending northeast to southeasterly during the afternoon. Overnight temperatures falling to between 15 and 18 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-20T00:00:00+09:30" end-time-local="2026-04-21T00:00:00+09:30" start-time-utc="2026-04-19T14:30:00Z" end-time-utc="2026-04-20T14:30:00Z">
                <text type="forecast">Sunny. Winds northeast to southeasterly 15 to 25 km/h becoming northeasterly 15 to 20 km/h during the evening. Overnight temperatures falling to between 13 and 17 with daytime temperatures reaching 28 to 34.</text>
            </forecast-period>
        </area>
