    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-26T11:25:24+10:30" end-time-local="2026-03-26T11:25:24+10:30" start-time-utc="2026-03-26T00:55:24Z" end-time-utc="2026-03-26T00:55:24Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A broad trough lies over eastern SA. A cold front will clip the southeast tomorrow as a high pressure system starts to build south of the Bight. The high will become established south of SA by Friday before starting to move east towards the Tasman Sea on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW008" description="Mid North" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-26T00:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-25T13:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, becoming less likely in the afternoon. Winds southerly 25 to 40 km/h. Daytime maximum temperatures between 17 and 21.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 4:30pm, UV Index predicted to reach 7 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Cloudy. Winds southerly 20 to 30 km/h. Overnight temperatures falling to between 6 and 11 with daytime temperatures reaching between 17 and 20.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-28T00:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-27T13:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds southeasterly 15 to 25 km/h becoming light during the evening. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching between 17 and 22.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming east to northeasterly 15 to 20 km/h during the morning then becoming light during the day. Overnight temperatures falling to around 10 with daytime temperatures reaching 21 to 26.</text>
            </forecast-period>
        </area>
