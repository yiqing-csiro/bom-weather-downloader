    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-09T15:55:34+09:30" end-time-local="2026-06-09T15:55:34+09:30" start-time-utc="2026-06-09T06:25:34Z" end-time-utc="2026-06-09T06:25:34Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over the Tasman Sea is responsible for a ridge hovering over the north of the state. A cold front will slide over the south of SA overnight, while the ridge persists into Thursday. Northerly winds will freshen ahead of a second cold front expected overnight Friday or Saturday morning.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW008" description="Mid North" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-09T15:00:00+09:30" end-time-local="2026-06-10T00:00:00+09:30" start-time-utc="2026-06-09T05:30:00Z" end-time-utc="2026-06-09T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower later tonight. Winds northerly 20 to 30 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-10T00:00:00+09:30" end-time-local="2026-06-11T00:00:00+09:30" start-time-utc="2026-06-09T14:30:00Z" end-time-utc="2026-06-10T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the early morning. Winds north to northwesterly 20 to 30 km/h turning westerly 15 to 25 km/h during the morning then becoming light in the late afternoon. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching between 16 and 19.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-11T00:00:00+09:30" end-time-local="2026-06-12T00:00:00+09:30" start-time-utc="2026-06-10T14:30:00Z" end-time-utc="2026-06-11T14:30:00Z">
                <text type="forecast">Mostly sunny. The chance of morning fog in the east. Winds east to northeasterly 15 to 20 km/h tending north to northeasterly in the late morning. Overnight temperatures falling to around 6 with daytime temperatures reaching between 16 and 21.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-12T00:00:00+09:30" end-time-local="2026-06-13T00:00:00+09:30" start-time-utc="2026-06-11T14:30:00Z" end-time-utc="2026-06-12T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the evening. Winds northeasterly 15 to 25 km/h turning northerly 25 to 35 km/h during the morning. Overnight temperatures falling to between 10 and 13 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-06-13T00:00:00+09:30" end-time-local="2026-06-14T00:00:00+09:30" start-time-utc="2026-06-12T14:30:00Z" end-time-utc="2026-06-13T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely in the morning. Winds north to northwesterly 20 to 30 km/h tending northwest to southwesterly during the morning then becoming light during the afternoon. Overnight temperatures falling to around 12 with daytime temperatures reaching between 16 and 19.</text>
            </forecast-period>
        </area>
