                <text type="forecast">Mostly clear. Winds southerly 15 to 25 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-28T00:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-27T13:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds south to southeasterly 15 to 20 km/h becoming light before dawn then becoming southeasterly 15 to 25 km/h in the early morning. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching between 17 and 23.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 4:30pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Partly cloudy. Light winds becoming north to northeasterly 15 to 20 km/h in the morning then becoming light in the early afternoon. Overnight temperatures falling to around 10 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-30T00:00:00+10:30" end-time-local="2026-03-31T00:00:00+10:30" start-time-utc="2026-03-29T13:30:00Z" end-time-utc="2026-03-30T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds north to northeasterly 15 to 20 km/h tending north to northwesterly during the day then becoming light during the afternoon. Overnight temperatures falling to between 12 and 16 with daytime temperatures reaching the low to high 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-31T00:00:00+10:30" end-time-local="2026-04-01T00:00:00+10:30" start-time-utc="2026-03-30T13:30:00Z" end-time-utc="2026-03-31T13:30:00Z">
