    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-28T21:17:18+09:30" end-time-local="2026-05-28T21:17:18+09:30" start-time-utc="2026-05-28T11:47:18Z" end-time-utc="2026-05-28T11:47:18Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A weak ridge of high pressure across SA on Thursday ahead of a series of cold fronts moving across the south on Friday and Saturday. A weak high pressure system moves across from west on Sunday, followed by a significant low pressure system moving south of the Bight Monday and into western Bass Strait on Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW008" description="Mid North" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-28T21:00:00+09:30" end-time-local="2026-05-29T00:00:00+09:30" start-time-utc="2026-05-28T11:30:00Z" end-time-utc="2026-05-28T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-29T00:00:00+09:30" end-time-local="2026-05-30T00:00:00+09:30" start-time-utc="2026-05-28T14:30:00Z" end-time-utc="2026-05-29T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Medium chance of showers, most likely in the evening. Winds north to northwesterly 15 to 20 km/h tending west to northwesterly 20 to 30 km/h in the late morning. Overnight temperatures falling to around 8 with daytime temperatures reaching between 16 and 20.</text>
                <text type="uv_alert">Sun protection 11:30am to 12:40pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-30T00:00:00+09:30" end-time-local="2026-05-31T00:00:00+09:30" start-time-utc="2026-05-29T14:30:00Z" end-time-utc="2026-05-30T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely in the late morning and afternoon. Winds westerly 20 to 30 km/h. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching between 13 and 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-31T00:00:00+09:30" end-time-local="2026-06-01T00:00:00+09:30" start-time-utc="2026-05-30T14:30:00Z" end-time-utc="2026-05-31T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the morning. Winds westerly 20 to 30 km/h becoming light during the afternoon. Overnight temperatures falling to around 7 with daytime temperatures reaching between 13 and 17.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-06-01T00:00:00+09:30" end-time-local="2026-06-02T00:00:00+09:30" start-time-utc="2026-05-31T14:30:00Z" end-time-utc="2026-06-01T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers. The chance of a thunderstorm in the south in the afternoon and evening. Winds northerly 15 to 25 km/h increasing to 25 to 40 km/h during the morning then turning northwesterly 25 to 35 km/h during the afternoon. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching between 17 and 21.</text>
            </forecast-period>
        </area>
