    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-05T21:17:43+09:30" end-time-local="2026-05-05T21:17:43+09:30" start-time-utc="2026-05-05T11:47:43Z" end-time-utc="2026-05-05T11:47:43Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure over SA will weaken briefly as a cold front crosses the southeast on Wednesday afternoon. The ridge will begin to re-establish in the wake of the front and stabilise over SA with the strong high pressure centre moving into the Bight over the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW008" description="Mid North" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-05T21:00:00+09:30" end-time-local="2026-05-06T00:00:00+09:30" start-time-utc="2026-05-05T11:30:00Z" end-time-utc="2026-05-05T14:30:00Z">
                <text type="forecast">Clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-06T00:00:00+09:30" end-time-local="2026-05-07T00:00:00+09:30" start-time-utc="2026-05-05T14:30:00Z" end-time-utc="2026-05-06T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely from the late morning. Light winds becoming west to southwesterly 15 to 25 km/h in the morning then tending south to southwesterly in the late afternoon. Overnight temperatures falling to between 3 and 7 with daytime temperatures reaching between 16 and 20.</text>
                <text type="uv_alert">Sun protection 10:30am to 1:50pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-07T00:00:00+09:30" end-time-local="2026-05-08T00:00:00+09:30" start-time-utc="2026-05-06T14:30:00Z" end-time-utc="2026-05-07T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. Winds southerly 20 to 30 km/h becoming light in the evening. Overnight temperatures falling to between 3 and 8 with daytime temperatures reaching between 12 and 16.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers in the south, slight chance elsewhere. Winds southwesterly 20 to 30 km/h becoming light during the evening. Overnight temperatures falling to between 3 and 8 with daytime temperatures reaching between 14 and 19.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-09T00:00:00+09:30" end-time-local="2026-05-10T00:00:00+09:30" start-time-utc="2026-05-08T14:30:00Z" end-time-utc="2026-05-09T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower. Light winds becoming south to southeasterly 15 to 20 km/h during the morning then becoming light during the evening. Overnight temperatures falling to between 5 and 9 with daytime temperatures reaching between 15 and 19.</text>
            </forecast-period>
        </area>
