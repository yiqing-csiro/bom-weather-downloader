    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-26T17:41:50+09:30" end-time-local="2026-05-26T17:41:50+09:30" start-time-utc="2026-05-26T08:11:50Z" end-time-utc="2026-05-26T08:11:50Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A low pressure system lies north of Kangaroo Island and is expected to move north and over the Eyre Peninsula and towards the Flinders district today, weakening as it moves into NSW on Wednesday. A weak ridge of high pressure begins to move across SA mid week. A cold front is expected to move over the west and southeast of SA on Friday. A high pressure system moves into the west on Saturday and then moves into the north on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-26T17:40:53+09:30" end-time-local="2026-05-27T00:00:00+09:30" start-time-utc="2026-05-26T08:10:53Z" end-time-utc="2026-05-26T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers. The chance of a thunderstorm in the late afternoon and evening. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-27T00:00:00+09:30" end-time-local="2026-05-28T00:00:00+09:30" start-time-utc="2026-05-26T14:30:00Z" end-time-utc="2026-05-27T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers in the morning and afternoon. Light winds becoming southeasterly 15 to 20 km/h in the morning then becoming light in the late afternoon. Overnight temperatures falling to around 11 with daytime temperatures reaching around 18.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-28T00:00:00+09:30" end-time-local="2026-05-29T00:00:00+09:30" start-time-utc="2026-05-27T14:30:00Z" end-time-utc="2026-05-28T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Slight chance of a shower in the south, near zero chance elsewhere. Light winds. Overnight temperatures falling to around 7 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-29T00:00:00+09:30" end-time-local="2026-05-30T00:00:00+09:30" start-time-utc="2026-05-28T14:30:00Z" end-time-utc="2026-05-29T14:30:00Z">
                <text type="forecast">Cloudy. The chance of morning fog. High chance of showers, most likely in the afternoon and evening. Light winds becoming northerly 15 to 20 km/h during the morning then tending northwesterly during the afternoon. Overnight temperatures falling to around 7 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-30T00:00:00+09:30" end-time-local="2026-05-31T00:00:00+09:30" start-time-utc="2026-05-29T14:30:00Z" end-time-utc="2026-05-30T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers. Winds westerly 20 to 30 km/h. Overnight temperatures falling to between 8 and 11 with daytime temperatures reaching around 17.</text>
            </forecast-period>
        </area>
