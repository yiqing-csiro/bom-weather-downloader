    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-01T04:10:19+09:30" end-time-local="2026-07-01T04:10:19+09:30" start-time-utc="2026-06-30T18:40:19Z" end-time-utc="2026-06-30T18:40:19Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A series of low pressure systems passing through the Bight will extend cold fronts that will cross over SA through to the end of the week. A high pressure system is then forecast to move into the Bight from late Friday and extend a ridge across the state over the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <warning-summary type="sheep_graziers_warning" start-time-local="2026-07-01T04:05:00+09:30" end-time-local="2026-07-03T00:00:00+09:30" start-time-utc="2026-06-30T18:35:00Z" end-time-utc="2026-07-02T14:30:00Z">Warning to Sheep Graziers</warning-summary>
            <forecast-period index="0" start-time-local="2026-07-01T00:00:00+09:30" end-time-local="2026-07-02T00:00:00+09:30" start-time-utc="2026-06-30T14:30:00Z" end-time-utc="2026-07-01T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely during this afternoon and evening. The chance of a thunderstorm during this afternoon and evening. Winds northerly 25 to 35 km/h turning northwesterly in the evening. Daytime maximum temperatures around 16.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 1 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-02T00:00:00+09:30" end-time-local="2026-07-03T00:00:00+09:30" start-time-utc="2026-07-01T14:30:00Z" end-time-utc="2026-07-02T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, with possible small hail in the late afternoon and evening. The chance of a thunderstorm near the coast in the late morning and afternoon. Damaging winds possible. Winds northwesterly 30 to 45 km/h turning westerly during the afternoon and evening. Overnight temperatures falling to around 9 with daytime temperatures reaching around 14.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-03T00:00:00+09:30" end-time-local="2026-07-04T00:00:00+09:30" start-time-utc="2026-07-02T14:30:00Z" end-time-utc="2026-07-03T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers, most likely in the morning. Damaging winds possible in the south. Winds west to southwesterly 30 to 45 km/h. Overnight temperatures falling to around 7 with daytime temperatures reaching around 14.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-04T00:00:00+09:30" end-time-local="2026-07-05T00:00:00+09:30" start-time-utc="2026-07-03T14:30:00Z" end-time-utc="2026-07-04T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers. Winds southwesterly 15 to 20 km/h increasing to 25 km/h before turning south to southeasterly 15 to 20 km/h during the day. Overnight temperatures falling to between 6 and 9 with daytime temperatures reaching around 14.</text>
            </forecast-period>
        </area>
