            <forecast-period index="4" start-time-local="2026-05-12T00:00:00+09:30" end-time-local="2026-05-13T00:00:00+09:30" start-time-utc="2026-05-11T14:30:00Z" end-time-utc="2026-05-12T14:30:00Z">
