            <forecast-period index="2" start-time-local="2026-05-06T00:00:00+09:30" end-time-local="2026-05-07T00:00:00+09:30" start-time-utc="2026-05-05T14:30:00Z" end-time-utc="2026-05-06T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, with possible small hail in the evening. Winds northwesterly 15 to 20 km/h increasing to 20 to 30 km/h in the morning then turning southwesterly 25 to 40 km/h in the early afternoon. Overnight temperatures falling to around 9 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-07T00:00:00+09:30" end-time-local="2026-05-08T00:00:00+09:30" start-time-utc="2026-05-06T14:30:00Z" end-time-utc="2026-05-07T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, with possible small hail in the morning. Winds southwesterly 25 to 40 km/h. Overnight temperatures falling to between 4 and 7 with daytime temperatures reaching between 13 and 16.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
