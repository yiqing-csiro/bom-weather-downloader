        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-11T22:25:01+09:30" end-time-local="2026-05-11T22:25:01+09:30" start-time-utc="2026-05-11T12:55:01Z" end-time-utc="2026-05-11T12:55:01Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system south of SA is slowly moving east, reaching the Tasman Sea by Wednesday. A trough of low pressure lies across the northeast. Another trough moves into the far west late on Friday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-11T21:00:00+09:30" end-time-local="2026-05-12T00:00:00+09:30" start-time-utc="2026-05-11T11:30:00Z" end-time-utc="2026-05-11T14:30:00Z">
                <text type="forecast">Clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-12T00:00:00+09:30" end-time-local="2026-05-13T00:00:00+09:30" start-time-utc="2026-05-11T14:30:00Z" end-time-utc="2026-05-12T14:30:00Z">
                <text type="forecast">Mostly sunny. Patchy morning fog. Light winds becoming east to northeasterly 15 to 20 km/h in the morning then becoming light in the early afternoon. Overnight temperatures falling to around 6 with daytime temperatures reaching the low 20s.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-13T00:00:00+09:30" end-time-local="2026-05-14T00:00:00+09:30" start-time-utc="2026-05-12T14:30:00Z" end-time-utc="2026-05-13T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds becoming northeasterly 15 to 20 km/h in the morning then becoming light in the early afternoon. Overnight temperatures falling to around 11 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-14T00:00:00+09:30" end-time-local="2026-05-15T00:00:00+09:30" start-time-utc="2026-05-13T14:30:00Z" end-time-utc="2026-05-14T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Light winds becoming northeasterly 15 to 20 km/h during the morning. Overnight temperatures falling to around 11 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-15T00:00:00+09:30" end-time-local="2026-05-16T00:00:00+09:30" start-time-utc="2026-05-14T14:30:00Z" end-time-utc="2026-05-15T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers, most likely in the afternoon and evening. Winds northeasterly 15 to 25 km/h. Overnight temperatures falling to around 12 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
        </area>
