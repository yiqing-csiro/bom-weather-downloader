    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-30T09:19:23+10:30" end-time-local="2026-03-30T09:19:23+10:30" start-time-utc="2026-03-29T22:49:23Z" end-time-utc="2026-03-29T22:49:23Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over NSW extends a ridge over SA. The ridge will ease as the high moves further away into the Tasman Sea this morning. A trough is forecast to move across the west and south later Tuesday, pushing into the northeast of SA on Wednesday. Another high pressure system is expected to become established south of the Bight later in the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-30T00:00:00+10:30" end-time-local="2026-03-31T00:00:00+10:30" start-time-utc="2026-03-29T13:30:00Z" end-time-utc="2026-03-30T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds northerly 15 to 25 km/h becoming light in the evening. Daytime maximum temperatures in the high 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 4:10pm, UV Index predicted to reach 7 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-31T00:00:00+10:30" end-time-local="2026-04-01T00:00:00+10:30" start-time-utc="2026-03-30T13:30:00Z" end-time-utc="2026-03-31T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds northeasterly 20 to 30 km/h tending northerly 25 to 35 km/h in the middle of the day then decreasing to 15 to 20 km/h in the evening. Overnight temperatures falling to around 13 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-01T00:00:00+10:30" end-time-local="2026-04-02T00:00:00+10:30" start-time-utc="2026-03-31T13:30:00Z" end-time-utc="2026-04-01T13:30:00Z">
                <text type="forecast">High chance of showers in the morning. Sunny afternoon. Winds north to northwesterly 15 to 20 km/h tending northwest to southwesterly 15 to 25 km/h during the morning then becoming light during the evening. Overnight temperatures falling to around 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-02T00:00:00+10:30" end-time-local="2026-04-03T00:00:00+10:30" start-time-utc="2026-04-01T13:30:00Z" end-time-utc="2026-04-02T13:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Slight chance of a shower in the south, near zero chance elsewhere. Light winds becoming westerly 15 to 25 km/h during the day then tending southwesterly 15 to 20 km/h during the evening. Overnight temperatures falling to around 8 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
        </area>
