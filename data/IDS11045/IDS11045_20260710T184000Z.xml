        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-11T04:10:20+09:30" end-time-local="2026-07-11T04:10:20+09:30" start-time-utc="2026-07-10T18:40:20Z" end-time-utc="2026-07-10T18:40:20Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A cold front in the Bight will move across the south of SA today followed by a weaker front on Monday. A high pressure system centred near southern WA will begin to dominate the weather pattern across SA mid next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <warning-summary type="sheep_graziers_warning" start-time-local="2026-07-10T22:15:00+09:30" end-time-local="2026-07-12T00:00:00+09:30" start-time-utc="2026-07-10T12:45:00Z" end-time-utc="2026-07-11T14:30:00Z">Warning to Sheep Graziers</warning-summary>
            <forecast-period index="0" start-time-local="2026-07-11T00:00:00+09:30" end-time-local="2026-07-12T00:00:00+09:30" start-time-utc="2026-07-10T14:30:00Z" end-time-utc="2026-07-11T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely from late this morning. The chance of a thunderstorm in the south from late this morning. Winds northerly 20 to 30 km/h increasing to 25 to 40 km/h in the morning then turning westerly in the middle of the day. Daytime maximum temperatures around 14.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 1 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-12T00:00:00+09:30" end-time-local="2026-07-13T00:00:00+09:30" start-time-utc="2026-07-11T14:30:00Z" end-time-utc="2026-07-12T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds westerly 30 to 45 km/h. Overnight temperatures falling to around 6 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-13T00:00:00+09:30" end-time-local="2026-07-14T00:00:00+09:30" start-time-utc="2026-07-12T14:30:00Z" end-time-utc="2026-07-13T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds westerly 25 to 40 km/h. Overnight temperatures falling to around 10 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-14T00:00:00+09:30" end-time-local="2026-07-15T00:00:00+09:30" start-time-utc="2026-07-13T14:30:00Z" end-time-utc="2026-07-14T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the morning. Winds westerly 25 to 35 km/h becoming light during the evening. Overnight temperatures falling to around 9 with daytime temperatures reaching around 16.</text>
            </forecast-period>
