        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-12T21:17:18+09:30" end-time-local="2026-05-12T21:17:18+09:30" start-time-utc="2026-05-12T11:47:18Z" end-time-utc="2026-05-12T11:47:18Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system near Tasmania is slowly moving east, reaching the Tasman Sea by tomorrow. A trough of low pressure lies across the northeast. Another trough moves into the far west late on Friday and continues across SA over the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-12T21:00:00+09:30" end-time-local="2026-05-13T00:00:00+09:30" start-time-utc="2026-05-12T11:30:00Z" end-time-utc="2026-05-12T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-13T00:00:00+09:30" end-time-local="2026-05-14T00:00:00+09:30" start-time-utc="2026-05-12T14:30:00Z" end-time-utc="2026-05-13T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds northeasterly 15 to 25 km/h tending easterly 15 to 20 km/h in the late afternoon then becoming light in the evening. Overnight temperatures falling to around 11 with daytime temperatures reaching the low 20s.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-14T00:00:00+09:30" end-time-local="2026-05-15T00:00:00+09:30" start-time-utc="2026-05-13T14:30:00Z" end-time-utc="2026-05-14T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Light winds becoming northeasterly 15 to 20 km/h in the morning. Overnight temperatures falling to around 10 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-15T00:00:00+09:30" end-time-local="2026-05-16T00:00:00+09:30" start-time-utc="2026-05-14T14:30:00Z" end-time-utc="2026-05-15T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the afternoon and evening. Winds northeasterly 15 to 25 km/h. Overnight temperatures falling to around 12 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-16T00:00:00+09:30" end-time-local="2026-05-17T00:00:00+09:30" start-time-utc="2026-05-15T14:30:00Z" end-time-utc="2026-05-16T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds northerly 15 to 25 km/h becoming light during the afternoon. Overnight temperatures falling to around 12 with daytime temperatures reaching around 20.</text>
            </forecast-period>
        </area>
