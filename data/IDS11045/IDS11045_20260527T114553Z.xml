    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-27T21:15:53+09:30" end-time-local="2026-05-27T21:15:53+09:30" start-time-utc="2026-05-27T11:45:53Z" end-time-utc="2026-05-27T11:45:53Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A weak low pressure system lies over the North East Pastoral district and is expected to weaken further as it moves into east into NSW this evening. A weak ridge of high pressure begins to move across SA on Thursday ahead of a cold front moving across the south on Friday. Another weak high pressure system moves across from the west over the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-27T21:00:00+09:30" end-time-local="2026-05-28T00:00:00+09:30" start-time-utc="2026-05-27T11:30:00Z" end-time-utc="2026-05-27T14:30:00Z">
                <text type="forecast">Mostly clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-28T00:00:00+09:30" end-time-local="2026-05-29T00:00:00+09:30" start-time-utc="2026-05-27T14:30:00Z" end-time-utc="2026-05-28T14:30:00Z">
                <text type="forecast">Partly cloudy. Patchy morning fog. Slight chance of a shower in the south, near zero chance elsewhere. Light winds. Overnight temperatures falling to around 7 with daytime temperatures reaching around 17.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-29T00:00:00+09:30" end-time-local="2026-05-30T00:00:00+09:30" start-time-utc="2026-05-28T14:30:00Z" end-time-utc="2026-05-29T14:30:00Z">
                <text type="forecast">Cloudy. The chance of morning fog. Very high chance of showers, most likely in the afternoon and evening. Light winds becoming northerly 15 to 25 km/h in the morning then tending northwesterly in the early afternoon. Overnight temperatures falling to around 6 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-30T00:00:00+09:30" end-time-local="2026-05-31T00:00:00+09:30" start-time-utc="2026-05-29T14:30:00Z" end-time-utc="2026-05-30T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers. Winds westerly 20 to 30 km/h. Overnight temperatures falling to around 9 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-31T00:00:00+09:30" end-time-local="2026-06-01T00:00:00+09:30" start-time-utc="2026-05-30T14:30:00Z" end-time-utc="2026-05-31T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the morning and afternoon. Winds westerly 20 to 30 km/h becoming light during the evening. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching around 16.</text>
            </forecast-period>
        </area>
