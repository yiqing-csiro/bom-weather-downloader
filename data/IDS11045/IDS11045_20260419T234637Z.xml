    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-20T09:16:37+09:30" end-time-local="2026-04-20T09:16:37+09:30" start-time-utc="2026-04-19T23:46:37Z" end-time-utc="2026-04-19T23:46:37Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system east of Tasmania will maintain a ridge over SA this week. A cold front is expected to weaken and slide across western and southern coasts during Tuesday and Wednesday. A second cold front may pass over the south again on Saturday with a high pressure system to follow over waters south of the Bight on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-20T00:00:00+09:30" end-time-local="2026-04-21T00:00:00+09:30" start-time-utc="2026-04-19T14:30:00Z" end-time-utc="2026-04-20T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds becoming southerly 15 to 20 km/h in the early afternoon then becoming light in the late afternoon. Daytime maximum temperatures around 20.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 10:00am to 2:10pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-21T00:00:00+09:30" end-time-local="2026-04-22T00:00:00+09:30" start-time-utc="2026-04-20T14:30:00Z" end-time-utc="2026-04-21T14:30:00Z">
                <text type="forecast">The chance of morning fog. Mostly sunny afternoon. Light winds becoming north to northeasterly 15 to 20 km/h in the morning. Overnight temperatures falling to around 7 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-22T00:00:00+09:30" end-time-local="2026-04-23T00:00:00+09:30" start-time-utc="2026-04-21T14:30:00Z" end-time-utc="2026-04-22T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the morning and afternoon. Winds northerly 15 to 25 km/h shifting south to southeasterly 15 to 20 km/h during the afternoon. Overnight temperatures falling to around 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-23T00:00:00+09:30" end-time-local="2026-04-24T00:00:00+09:30" start-time-utc="2026-04-22T14:30:00Z" end-time-utc="2026-04-23T14:30:00Z">
                <text type="forecast">The chance of morning fog. Mostly sunny afternoon. Light winds becoming northerly 15 to 20 km/h during the day then becoming light during the afternoon. Overnight temperatures falling to around 9 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
