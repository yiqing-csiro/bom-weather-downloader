    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-24T15:55:20+09:30" end-time-local="2026-07-24T15:55:20+09:30" start-time-utc="2026-07-24T06:25:20Z" end-time-utc="2026-07-24T06:25:20Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system centred over the Bight will slowly drift northeastwards on Saturday. A weak trough embedded in the southwesterly flow around the high will clip the southeast of the State early Saturday. The high will move north over South Australia on Sunday and eastern states early next week, with a cold front pushing over the west of the State on Monday and move over remaining parts on Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW005" description="Lower South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-24T15:00:00+09:30" end-time-local="2026-07-25T00:00:00+09:30" start-time-utc="2026-07-24T05:30:00Z" end-time-utc="2026-07-24T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers in the south, slight chance elsewhere. Winds westerly 20 to 30 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-25T00:00:00+09:30" end-time-local="2026-07-26T00:00:00+09:30" start-time-utc="2026-07-24T14:30:00Z" end-time-utc="2026-07-25T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers. Winds westerly 15 to 25 km/h. Overnight temperatures falling to around 10 with daytime temperatures reaching around 16.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-26T00:00:00+09:30" end-time-local="2026-07-27T00:00:00+09:30" start-time-utc="2026-07-25T14:30:00Z" end-time-utc="2026-07-26T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog in the north. Medium chance of showers, most likely in the late morning and afternoon. Winds westerly 15 to 20 km/h turning north to northwesterly in the evening. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-27T00:00:00+09:30" end-time-local="2026-07-28T00:00:00+09:30" start-time-utc="2026-07-26T14:30:00Z" end-time-utc="2026-07-27T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the afternoon and evening. Winds northerly 15 to 25 km/h increasing to 25 to 35 km/h during the morning then tending northwesterly during the day. Overnight temperatures falling to around 7 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-28T00:00:00+09:30" end-time-local="2026-07-29T00:00:00+09:30" start-time-utc="2026-07-27T14:30:00Z" end-time-utc="2026-07-28T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers, most likely in the morning and afternoon. Winds west to northwesterly 15 to 25 km/h turning southwesterly 25 to 35 km/h during the morning then decreasing to 15 to 25 km/h during the afternoon. Overnight temperatures falling to around 9 with daytime temperatures reaching around 15.</text>
            </forecast-period>
        </area>
