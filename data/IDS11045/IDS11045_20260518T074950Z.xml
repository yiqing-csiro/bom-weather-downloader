            <forecast-period index="4" start-time-local="2026-05-22T00:00:00+09:30" end-time-local="2026-05-23T00:00:00+09:30" start-time-utc="2026-05-21T14:30:00Z" end-time-utc="2026-05-22T14:30:00Z">
