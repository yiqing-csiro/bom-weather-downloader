    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-08T17:04:28+09:30" end-time-local="2026-04-08T17:04:28+09:30" start-time-utc="2026-04-08T07:34:28Z" end-time-utc="2026-04-08T07:34:28Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A trough will linger inland over the west until a cold front sweeps across southern SA on Thursday. This front will push the inland trough into the far north, exiting the state early Friday. A cooler southwest to southerly flow will gradually moderate in the wake of the front as a strong high pressure system moves in from the west from Friday, establishing in the Bight on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW004" description="Upper South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-08T15:00:00+09:30" end-time-local="2026-04-09T00:00:00+09:30" start-time-utc="2026-04-08T05:30:00Z" end-time-utc="2026-04-08T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers. The chance of a thunderstorm. Winds north to northeasterly 15 to 20 km/h becoming light in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-09T00:00:00+09:30" end-time-local="2026-04-10T00:00:00+09:30" start-time-utc="2026-04-08T14:30:00Z" end-time-utc="2026-04-09T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the evening. The chance of a thunderstorm in the morning and afternoon. Winds north to northwesterly 15 to 20 km/h tending west to northwesterly 25 to 35 km/h during the morning. Overnight temperatures falling to around 14 with daytime temperatures reaching the low to mid 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:30am to 2:40pm, UV Index predicted to reach 5 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-10T00:00:00+09:30" end-time-local="2026-04-11T00:00:00+09:30" start-time-utc="2026-04-09T14:30:00Z" end-time-utc="2026-04-10T14:30:00Z">
                <text type="forecast">Cloudy. High chance of showers, most likely in the late afternoon and evening. Winds westerly 30 to 45 km/h. Overnight temperatures falling to between 9 and 13 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-11T00:00:00+09:30" end-time-local="2026-04-12T00:00:00+09:30" start-time-utc="2026-04-10T14:30:00Z" end-time-utc="2026-04-11T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the morning and afternoon. Winds southwesterly 25 to 40 km/h. Overnight temperatures falling to between 5 and 10 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-12T00:00:00+09:30" end-time-local="2026-04-13T00:00:00+09:30" start-time-utc="2026-04-11T14:30:00Z" end-time-utc="2026-04-12T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower in the morning and afternoon. Winds southwesterly 15 to 25 km/h becoming light during the evening. Overnight temperatures falling to between 6 and 11 with daytime temperatures reaching around 18.</text>
            </forecast-period>
        </area>
