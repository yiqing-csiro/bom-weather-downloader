    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-26T15:55:16+10:30" end-time-local="2026-03-26T15:55:16+10:30" start-time-utc="2026-03-26T05:25:16Z" end-time-utc="2026-03-26T05:25:16Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">An upper level trough over southeast SA will continue to move eastwards, as a high pressure system starts to build southwest of the Bight. The high will become established south of SA by Friday, then moving eastwards over the weekend to be centred over the Tasman Sea on Monday. A low pressure system well to the south will link to a trough over the far west late Monday and into Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW004" description="Upper South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-26T15:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-26T04:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Mostly clear. Slight chance of a shower near the coast, near zero chance elsewhere. Winds southwesterly 35 to 45 km/h turning southerly 30 to 45 km/h in the late afternoon then decreasing to 25 to 35 km/h in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower near the coast, near zero chance elsewhere. Winds southerly 25 to 40 km/h. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching around 19.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 4:10pm, UV Index predicted to reach 7 [High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-28T00:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-27T13:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower in the morning and early afternoon. Winds south to southwesterly 15 to 20 km/h becoming light before dawn then becoming southerly 15 to 25 km/h in the morning. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming south to southeasterly 15 to 20 km/h during the afternoon then becoming light during the evening. Overnight temperatures falling to around 9 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-30T00:00:00+10:30" end-time-local="2026-03-31T00:00:00+10:30" start-time-utc="2026-03-29T13:30:00Z" end-time-utc="2026-03-30T13:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming northerly 15 to 20 km/h during the day then becoming light during the afternoon. Overnight temperatures falling to around 12 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
