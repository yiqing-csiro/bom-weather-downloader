            <forecast-period index="0" start-time-local="2026-04-20T21:00:00+09:30" end-time-local="2026-04-21T00:00:00+09:30" start-time-utc="2026-04-20T11:30:00Z" end-time-utc="2026-04-20T14:30:00Z">
                <text type="forecast">Clear. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-21T00:00:00+09:30" end-time-local="2026-04-22T00:00:00+09:30" start-time-utc="2026-04-20T14:30:00Z" end-time-utc="2026-04-21T14:30:00Z">
                <text type="forecast">The chance of morning fog. Mostly sunny afternoon. Winds east to northeasterly 15 to 20 km/h turning northerly 15 to 25 km/h in the morning then tending northeasterly 15 to 20 km/h in the evening. Overnight temperatures falling to around 8 with daytime temperatures reaching around 30.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 2:10pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-22T00:00:00+09:30" end-time-local="2026-04-23T00:00:00+09:30" start-time-utc="2026-04-21T14:30:00Z" end-time-utc="2026-04-22T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds northerly 15 to 25 km/h shifting south to southeasterly 15 to 20 km/h in the afternoon. Overnight temperatures falling to around 16 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-23T00:00:00+09:30" end-time-local="2026-04-24T00:00:00+09:30" start-time-utc="2026-04-22T14:30:00Z" end-time-utc="2026-04-23T14:30:00Z">
                <text type="forecast">The chance of morning fog. Sunny afternoon. Light winds becoming northerly 15 to 25 km/h during the morning then becoming light during the evening. Overnight temperatures falling to around 10 with daytime temperatures reaching the high 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-24T00:00:00+09:30" end-time-local="2026-04-25T00:00:00+09:30" start-time-utc="2026-04-23T14:30:00Z" end-time-utc="2026-04-24T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds northerly 15 to 25 km/h. Overnight temperatures falling to around 12 with daytime temperatures reaching the high 20s.</text>
            </forecast-period>
