    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-17T16:25:29+09:30" end-time-local="2026-04-17T16:25:29+09:30" start-time-utc="2026-04-17T06:55:29Z" end-time-utc="2026-04-17T06:55:29Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of the Bight extends a ridge over SA. The high will slowly move east over the weekend ahead of a cold front which will slip to the south of SA and weaken. The high will remain near stationary in the southern Tasman Sea, maintaining a ridge across the state early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW004" description="Upper South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-17T15:00:00+09:30" end-time-local="2026-04-18T00:00:00+09:30" start-time-utc="2026-04-17T05:30:00Z" end-time-utc="2026-04-17T14:30:00Z">
                <text type="forecast">Clear. Winds southerly 15 to 20 km/h becoming light in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-18T00:00:00+09:30" end-time-local="2026-04-19T00:00:00+09:30" start-time-utc="2026-04-17T14:30:00Z" end-time-utc="2026-04-18T14:30:00Z">
                <text type="forecast">Sunny. The chance of morning frost near the eastern border. Light winds becoming northeasterly 15 to 20 km/h in the morning. Overnight temperatures falling to around 4 with daytime temperatures reaching between 19 and 22.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 9:50am to 2:20pm, UV Index predicted to reach 5 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-19T00:00:00+09:30" end-time-local="2026-04-20T00:00:00+09:30" start-time-utc="2026-04-18T14:30:00Z" end-time-utc="2026-04-19T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers in the morning. The chance of a thunderstorm in the morning. Winds northeasterly 15 to 20 km/h tending northerly before dawn then becoming light in the evening. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching the mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-20T00:00:00+09:30" end-time-local="2026-04-21T00:00:00+09:30" start-time-utc="2026-04-19T14:30:00Z" end-time-utc="2026-04-20T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds becoming south to southwesterly 15 to 20 km/h during the afternoon then becoming light during the evening. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-21T00:00:00+09:30" end-time-local="2026-04-22T00:00:00+09:30" start-time-utc="2026-04-20T14:30:00Z" end-time-utc="2026-04-21T14:30:00Z">
                <text type="forecast">The chance of morning fog. Mostly sunny day. Light winds becoming north to northeasterly 15 to 25 km/h during the morning. Overnight temperatures falling to around 9 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
