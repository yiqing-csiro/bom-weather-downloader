    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-16T09:17:52+09:30" end-time-local="2026-06-16T09:17:52+09:30" start-time-utc="2026-06-15T23:47:52Z" end-time-utc="2026-06-15T23:47:52Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system centred over the Tasman Sea extends a ridge over the northeast of SA. A low pressure system will develop over the Bight on Monday then will remain slow-moving until later Thursday when it will move eastwards. An associated cold front will move across SA during Wednesday followed by a second front later Thursday. A high pressure ridge will move across from the west over the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW004" description="Upper South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-16T00:00:00+09:30" end-time-local="2026-06-17T00:00:00+09:30" start-time-utc="2026-06-15T14:30:00Z" end-time-utc="2026-06-16T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain. Winds northerly 15 to 25 km/h turning northeasterly 15 to 20 km/h in the evening. Daytime maximum temperatures around 18.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-17T00:00:00+09:30" end-time-local="2026-06-18T00:00:00+09:30" start-time-utc="2026-06-16T14:30:00Z" end-time-utc="2026-06-17T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain, most likely from the late morning. Winds north to northeasterly 20 to 30 km/h. Overnight temperatures falling to around 13 with daytime temperatures reaching around 20.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-18T00:00:00+09:30" end-time-local="2026-06-19T00:00:00+09:30" start-time-utc="2026-06-17T14:30:00Z" end-time-utc="2026-06-18T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers, most likely in the morning. Winds north to northwesterly 20 to 30 km/h. Overnight temperatures falling to around 11 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-19T00:00:00+09:30" end-time-local="2026-06-20T00:00:00+09:30" start-time-utc="2026-06-18T14:30:00Z" end-time-utc="2026-06-19T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers, most likely in the morning and afternoon. Winds north to northwesterly 15 to 25 km/h turning west to southwesterly 20 to 30 km/h during the morning. Overnight temperatures falling to around 9 with daytime temperatures reaching around 16.</text>
            </forecast-period>
        </area>
