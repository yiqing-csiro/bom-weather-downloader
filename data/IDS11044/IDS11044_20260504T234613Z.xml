    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-05T09:16:13+09:30" end-time-local="2026-05-05T09:16:13+09:30" start-time-utc="2026-05-04T23:46:13Z" end-time-utc="2026-05-04T23:46:13Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure will begin to extend from the west on Tuesday and will be briefly be weakened as a cold front crosses the southeast on Wednesday afternoon. The ridge will begin to re-establish in the wake of the front and stabilise over SA with the slow moving high pressure centre sitting south of WA by Friday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW004" description="Upper South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-05T00:00:00+09:30" end-time-local="2026-05-06T00:00:00+09:30" start-time-utc="2026-05-04T14:30:00Z" end-time-utc="2026-05-05T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower near the eastern border, near zero chance elsewhere. Winds southwesterly 15 to 20 km/h becoming light in the late afternoon. Daytime maximum temperatures around 18.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">##</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-06T00:00:00+09:30" end-time-local="2026-05-07T00:00:00+09:30" start-time-utc="2026-05-05T14:30:00Z" end-time-utc="2026-05-06T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely from the late morning. Possible small hail near the eastern border in the evening. Winds northwesterly and light increasing to 20 to 30 km/h in the morning then turning southwesterly 25 to 40 km/h in the afternoon. Overnight temperatures falling to around 8 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-07T00:00:00+09:30" end-time-local="2026-05-08T00:00:00+09:30" start-time-utc="2026-05-06T14:30:00Z" end-time-utc="2026-05-07T14:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower, with possible small hail south of Keith in the morning. Winds southwesterly 25 to 40 km/h. Overnight temperatures falling to between 4 and 9 with daytime temperatures reaching around 15.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, most likely in the morning and afternoon. Winds southwesterly 25 to 40 km/h. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching around 18.</text>
            </forecast-period>
        </area>
