    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-16T14:46:55+09:30" end-time-local="2026-04-16T14:46:55+09:30" start-time-utc="2026-04-16T05:16:55Z" end-time-utc="2026-04-16T05:16:55Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of the Bight extends a ridge over SA. The high will move east during Friday and Saturday ahead of a weakening trough that is expected to brush the west and south on the weekend. The high is forecast to be over the Tasman Sea by Monday, extending a ridge over South Australia through until Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW004" description="Upper South East" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-16T14:46:05+09:30" end-time-local="2026-04-17T00:00:00+09:30" start-time-utc="2026-04-16T05:16:05Z" end-time-utc="2026-04-16T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower, most likely in the late afternoon and evening. The chance of a thunderstorm near the eastern border in the late afternoon and evening. Winds west to southwesterly 20 to 30 km/h becoming light in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-17T00:00:00+09:30" end-time-local="2026-04-18T00:00:00+09:30" start-time-utc="2026-04-16T14:30:00Z" end-time-utc="2026-04-17T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the morning. Light winds becoming southerly 15 to 25 km/h in the morning then becoming light in the evening. Overnight temperatures falling to between 9 and 12 with daytime temperatures reaching around 20.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 9:40am to 2:30pm, UV Index predicted to reach 5 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-18T00:00:00+09:30" end-time-local="2026-04-19T00:00:00+09:30" start-time-utc="2026-04-17T14:30:00Z" end-time-utc="2026-04-18T14:30:00Z">
                <text type="forecast">Sunny. The chance of morning frost near the eastern border. Light winds becoming northeasterly 15 to 20 km/h in the morning. Overnight temperatures falling to around 4 with daytime temperatures reaching between 19 and 22.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-19T00:00:00+09:30" end-time-local="2026-04-20T00:00:00+09:30" start-time-utc="2026-04-18T14:30:00Z" end-time-utc="2026-04-19T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers in the morning and afternoon. The chance of a thunderstorm in the morning and afternoon. Winds northeasterly 15 to 20 km/h tending northerly during the morning then becoming light during the afternoon. Overnight temperatures falling to between 7 and 11 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-20T00:00:00+09:30" end-time-local="2026-04-21T00:00:00+09:30" start-time-utc="2026-04-19T14:30:00Z" end-time-utc="2026-04-20T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds. Overnight temperatures falling to around 10 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
