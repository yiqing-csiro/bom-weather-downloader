    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-05T16:30:45+09:30" end-time-local="2026-05-05T16:30:45+09:30" start-time-utc="2026-05-05T07:00:45Z" end-time-utc="2026-05-05T07:00:45Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure over SA will weaken briefly as a cold front crosses the southeast on Wednesday afternoon. The ridge will begin to re-establish in the wake of the front and stabilise over SA with the strong high pressure centre moving into the Bight over the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW009" description="Flinders" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-05T15:00:00+09:30" end-time-local="2026-05-06T00:00:00+09:30" start-time-utc="2026-05-05T05:30:00Z" end-time-utc="2026-05-05T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds south to southwesterly 15 to 20 km/h becoming light in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-06T00:00:00+09:30" end-time-local="2026-05-07T00:00:00+09:30" start-time-utc="2026-05-05T14:30:00Z" end-time-utc="2026-05-06T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers near the coast, most likely in the late afternoon and evening. Near zero chance of rain elsewhere. Light winds becoming south to southwesterly 15 to 25 km/h in the morning. Overnight temperatures falling to between 4 and 9 with daytime temperatures reaching between 17 and 21.</text>
                <text type="uv_alert">Sun protection 10:20am to 2:10pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-07T00:00:00+09:30" end-time-local="2026-05-08T00:00:00+09:30" start-time-utc="2026-05-06T14:30:00Z" end-time-utc="2026-05-07T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds south to southeasterly 20 to 30 km/h becoming light in the late evening. Overnight temperatures falling to between 4 and 9 with daytime temperatures reaching between 13 and 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-08T00:00:00+09:30" end-time-local="2026-05-09T00:00:00+09:30" start-time-utc="2026-05-07T14:30:00Z" end-time-utc="2026-05-08T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower near the coast, near zero chance elsewhere. Winds southerly 15 to 25 km/h. Overnight temperatures falling to between 3 and 6 with daytime temperatures reaching between 15 and 19.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-09T00:00:00+09:30" end-time-local="2026-05-10T00:00:00+09:30" start-time-utc="2026-05-08T14:30:00Z" end-time-utc="2026-05-09T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower on and east of the ranges, near zero chance elsewhere. Winds southerly 15 to 20 km/h turning southeasterly 15 to 25 km/h during the day. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching between 15 and 20.</text>
            </forecast-period>
        </area>
