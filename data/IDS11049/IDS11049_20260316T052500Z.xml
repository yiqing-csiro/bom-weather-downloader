        <area aac="SA_PW009" description="Flinders" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-16T15:00:00+10:30" end-time-local="2026-03-17T00:00:00+10:30" start-time-utc="2026-03-16T04:30:00Z" end-time-utc="2026-03-16T13:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain. Winds east to northeasterly and light increasing to 15 to 20 km/h in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-17T00:00:00+10:30" end-time-local="2026-03-18T00:00:00+10:30" start-time-utc="2026-03-16T13:30:00Z" end-time-utc="2026-03-17T13:30:00Z">
                <text type="forecast">Cloudy. High chance of showers, most likely in the early morning. Winds east to southeasterly 15 to 25 km/h. Overnight temperatures falling to between 16 and 20 with daytime temperatures reaching 20 to 26.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 4:50pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-18T00:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-17T13:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, most likely in the morning and early afternoon. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to between 16 and 20 with daytime temperatures reaching 22 to 27.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-19T00:00:00+10:30" end-time-local="2026-03-20T00:00:00+10:30" start-time-utc="2026-03-18T13:30:00Z" end-time-utc="2026-03-19T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower on and east of the ranges in the morning and afternoon. Near zero chance of rain elsewhere. Winds east to southeasterly 15 to 25 km/h. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching 23 to 28.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-20T00:00:00+10:30" end-time-local="2026-03-21T00:00:00+10:30" start-time-utc="2026-03-19T13:30:00Z" end-time-utc="2026-03-20T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the morning and afternoon. Winds east to southeasterly 15 to 20 km/h becoming light during the morning then becoming southeast to southwesterly 15 to 20 km/h during the afternoon. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
