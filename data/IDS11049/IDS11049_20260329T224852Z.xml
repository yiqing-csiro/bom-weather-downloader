    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-30T09:18:52+10:30" end-time-local="2026-03-30T09:18:52+10:30" start-time-utc="2026-03-29T22:48:52Z" end-time-utc="2026-03-29T22:48:52Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over NSW extends a ridge over SA. The ridge will ease as the high moves further away into the Tasman Sea this morning. A trough is forecast to move across the west and south later Tuesday, pushing into the northeast of SA on Wednesday. Another high pressure system is expected to become established south of the Bight later in the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW009" description="Flinders" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-30T00:00:00+10:30" end-time-local="2026-03-31T00:00:00+10:30" start-time-utc="2026-03-29T13:30:00Z" end-time-utc="2026-03-30T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds north to northeasterly 15 to 20 km/h becoming light in the middle of the day then becoming east to northeasterly 15 to 20 km/h in the late afternoon. Daytime maximum temperatures in the mid to high 20s.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 10:10am to 4:30pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-31T00:00:00+10:30" end-time-local="2026-04-01T00:00:00+10:30" start-time-utc="2026-03-30T13:30:00Z" end-time-utc="2026-03-31T13:30:00Z">
                <text type="forecast">Sunny. Winds east to northeasterly 15 to 20 km/h turning northerly 25 to 35 km/h during the morning then tending northwest to northeasterly 15 to 20 km/h in the late evening. Overnight temperatures falling to between 11 and 16 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-01T00:00:00+10:30" end-time-local="2026-04-02T00:00:00+10:30" start-time-utc="2026-03-31T13:30:00Z" end-time-utc="2026-04-01T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower south of Hawker, most likely in the morning. Near zero chance of rain elsewhere. Winds northwest to northeasterly 15 to 20 km/h tending northwest to southwesterly during the morning then tending southeast to southwesterly 15 to 25 km/h during the afternoon. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-02T00:00:00+10:30" end-time-local="2026-04-03T00:00:00+10:30" start-time-utc="2026-04-01T13:30:00Z" end-time-utc="2026-04-02T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds southeast to southwesterly 15 to 20 km/h becoming light during the day then becoming southeast to southwesterly 20 to 30 km/h during the afternoon. Overnight temperatures falling to between 12 and 17 with daytime temperatures reaching 25 to 30.</text>
            </forecast-period>
        </area>
