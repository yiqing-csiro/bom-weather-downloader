    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-29T21:18:26+09:30" end-time-local="2026-06-29T21:18:26+09:30" start-time-utc="2026-06-29T11:48:26Z" end-time-utc="2026-06-29T11:48:26Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A low pressure trough over central districts will move southeastwards and slip south of SA from early Tuesday. A series of low pressure systems passing through the Bight during the week will extend cold fronts that will cross over SA through to the end of the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW009" description="Flinders" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-29T21:00:00+09:30" end-time-local="2026-06-30T00:00:00+09:30" start-time-utc="2026-06-29T11:30:00Z" end-time-utc="2026-06-29T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers. Winds north to northwesterly 15 to 20 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-30T00:00:00+09:30" end-time-local="2026-07-01T00:00:00+09:30" start-time-utc="2026-06-29T14:30:00Z" end-time-utc="2026-06-30T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers west of the ranges, slight chance elsewhere. Winds west to northwesterly 15 to 20 km/h turning northerly 15 to 25 km/h during the day. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching between 14 and 18.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-01T00:00:00+09:30" end-time-local="2026-07-02T00:00:00+09:30" start-time-utc="2026-06-30T14:30:00Z" end-time-utc="2026-07-01T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers, most likely in the morning and afternoon. The chance of a thunderstorm in the morning, possibly severe with damaging winds. Winds northerly 25 to 35 km/h turning northwesterly 30 to 45 km/h in the morning. Overnight temperatures falling to between 7 and 12 with daytime temperatures reaching between 13 and 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-02T00:00:00+09:30" end-time-local="2026-07-03T00:00:00+09:30" start-time-utc="2026-07-01T14:30:00Z" end-time-utc="2026-07-02T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers near the coast, medium chance elsewhere. Winds northwesterly 25 to 40 km/h turning westerly during the afternoon. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching between 12 and 17.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-03T00:00:00+09:30" end-time-local="2026-07-04T00:00:00+09:30" start-time-utc="2026-07-02T14:30:00Z" end-time-utc="2026-07-03T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Winds westerly 20 to 30 km/h tending southwesterly 15 to 25 km/h during the day then becoming light during the evening. Overnight temperatures falling to between 4 and 8 with daytime temperatures reaching between 11 and 15.</text>
            </forecast-period>
        </area>
