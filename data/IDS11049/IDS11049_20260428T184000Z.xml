    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-29T04:10:40+09:30" end-time-local="2026-04-29T04:10:40+09:30" start-time-utc="2026-04-28T18:40:40Z" end-time-utc="2026-04-28T18:40:40Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system over the Tasman Sea will maintain a ridge across South Australia through to Friday. Northerly winds freshen on Friday ahead of a trough that is forecast to move across the far west Friday afternoon, then continue across the state during the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW009" description="Flinders" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-29T00:00:00+09:30" end-time-local="2026-04-30T00:00:00+09:30" start-time-utc="2026-04-28T14:30:00Z" end-time-utc="2026-04-29T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to northeasterly 15 to 25 km/h tending north to northeasterly 15 to 20 km/h in the middle of the day then tending east to northeasterly in the late afternoon. Daytime maximum temperatures 24 to 29.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">##</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-30T00:00:00+09:30" end-time-local="2026-05-01T00:00:00+09:30" start-time-utc="2026-04-29T14:30:00Z" end-time-utc="2026-04-30T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds east to northeasterly 15 to 20 km/h turning northerly 15 to 25 km/h during the morning then tending northeasterly in the late afternoon. Overnight temperatures falling to between 11 and 17 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-01T00:00:00+09:30" end-time-local="2026-05-02T00:00:00+09:30" start-time-utc="2026-04-30T14:30:00Z" end-time-utc="2026-05-01T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds north to northeasterly 25 to 40 km/h. Overnight temperatures falling to between 10 and 17 with daytime temperatures reaching 25 to 30.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-02T00:00:00+09:30" end-time-local="2026-05-03T00:00:00+09:30" start-time-utc="2026-05-01T14:30:00Z" end-time-utc="2026-05-02T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the morning and afternoon. The chance of a thunderstorm in the evening. Winds northerly 20 to 30 km/h turning westerly during the morning. Overnight temperatures falling to between 13 and 19 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
        </area>
