        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-07T15:55:38+09:30" end-time-local="2026-07-07T15:55:38+09:30" start-time-utc="2026-07-07T06:25:38Z" end-time-utc="2026-07-07T06:25:38Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system centred near Tasmania extends a ridge over SA. A weak trough will remain over northern SA, slowly moving east later this week ahead of a cold front moving across the Bight.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW009" description="Flinders" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-07T15:00:00+09:30" end-time-local="2026-07-08T00:00:00+09:30" start-time-utc="2026-07-07T05:30:00Z" end-time-utc="2026-07-07T14:30:00Z">
                <text type="forecast">Mostly clear. Winds easterly 15 to 25 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-08T00:00:00+09:30" end-time-local="2026-07-09T00:00:00+09:30" start-time-utc="2026-07-07T14:30:00Z" end-time-utc="2026-07-08T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog on and east of the ranges. Slight chance of a shower. Winds east to northeasterly 15 to 25 km/h becoming light in the early afternoon then becoming easterly 15 to 20 km/h in the evening. Overnight temperatures falling to between 4 and 8 with daytime temperatures reaching between 13 and 18.</text>
                <text type="uv_alert">Sun protection 11:20am to 1:20pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-09T00:00:00+09:30" end-time-local="2026-07-10T00:00:00+09:30" start-time-utc="2026-07-08T14:30:00Z" end-time-utc="2026-07-09T14:30:00Z">
                <text type="forecast">Cloudy. The chance of morning fog on and east of the ranges. Medium chance of showers, most likely in the morning. Winds east to northeasterly 15 to 20 km/h becoming light in the early morning. Overnight temperatures falling to between 5 and 9 with daytime temperatures reaching between 12 and 16.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-10T00:00:00+09:30" end-time-local="2026-07-11T00:00:00+09:30" start-time-utc="2026-07-09T14:30:00Z" end-time-utc="2026-07-10T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Slight chance of a shower. Light winds becoming north to northwesterly 15 to 20 km/h during the day. Overnight temperatures falling to between 4 and 7 with daytime temperatures reaching between 14 and 17.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-11T00:00:00+09:30" end-time-local="2026-07-12T00:00:00+09:30" start-time-utc="2026-07-10T14:30:00Z" end-time-utc="2026-07-11T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the afternoon and evening. Winds north to northwesterly 20 to 30 km/h turning westerly during the afternoon. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching between 14 and 18.</text>
            </forecast-period>
        </area>
