        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-18T19:18:28+10:30" end-time-local="2026-03-18T19:18:28+10:30" start-time-utc="2026-03-18T08:48:28Z" end-time-utc="2026-03-18T08:48:28Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A low and trough over northeast SA will continue to move northeastwards clearing the State by Thursday. A ridge of high pressure persists to the south.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW009" description="Flinders" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-18T15:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-18T04:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers on and east of the ranges, slight chance elsewhere. The chance of a thunderstorm south of Hawker early this evening. Winds southeasterly 20 to 30 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-19T00:00:00+10:30" end-time-local="2026-03-20T00:00:00+10:30" start-time-utc="2026-03-18T13:30:00Z" end-time-utc="2026-03-19T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers on and east of the ranges, slight chance elsewhere. Winds southeasterly 15 to 25 km/h. Overnight temperatures falling to between 16 and 20 with daytime temperatures reaching 23 to 28.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:00am to 4:50pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-20T00:00:00+10:30" end-time-local="2026-03-21T00:00:00+10:30" start-time-utc="2026-03-19T13:30:00Z" end-time-utc="2026-03-20T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the late morning and afternoon. Winds east to southeasterly 15 to 20 km/h becoming light in the morning then becoming south to southeasterly 15 to 20 km/h in the early afternoon. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-21T00:00:00+10:30" end-time-local="2026-03-22T00:00:00+10:30" start-time-utc="2026-03-20T13:30:00Z" end-time-utc="2026-03-21T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower north of Hawker in the morning and afternoon. Near zero chance of rain elsewhere. Winds south to southeasterly 15 to 25 km/h tending east to southeasterly during the evening. Overnight temperatures falling to between 15 and 19 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-22T00:00:00+10:30" end-time-local="2026-03-23T00:00:00+10:30" start-time-utc="2026-03-21T13:30:00Z" end-time-utc="2026-03-22T13:30:00Z">
                <text type="forecast">Sunny. Winds east to southeasterly 15 to 20 km/h becoming light during the morning then becoming east to southeasterly 15 to 20 km/h during the day. Overnight temperatures falling to between 13 and 18 with daytime temperatures reaching 25 to 30.</text>
            </forecast-period>
        </area>
