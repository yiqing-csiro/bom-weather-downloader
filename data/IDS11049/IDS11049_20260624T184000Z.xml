    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-25T04:10:37+09:30" end-time-local="2026-06-25T04:10:37+09:30" start-time-utc="2026-06-24T18:40:37Z" end-time-utc="2026-06-24T18:40:37Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of SA is forecast to be centred over Tasmania later today. The high will continue to extend a ridge over SA through to Saturday then a low pressure trough is expected to reach far western areas of the state on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW009" description="Flinders" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-25T00:00:00+09:30" end-time-local="2026-06-26T00:00:00+09:30" start-time-utc="2026-06-24T14:30:00Z" end-time-utc="2026-06-25T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers north of Hawker, most likely this evening. Near zero chance of rain elsewhere. The chance of a thunderstorm north of Hawker during this afternoon and evening. Winds east to southeasterly 15 to 25 km/h. Daytime maximum temperatures between 13 and 17.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-26T00:00:00+09:30" end-time-local="2026-06-27T00:00:00+09:30" start-time-utc="2026-06-25T14:30:00Z" end-time-utc="2026-06-26T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower on and east of the ranges, most likely in the early morning. Near zero chance of rain elsewhere. The chance of morning fog south of Hawker. Winds east to southeasterly 15 to 25 km/h. Overnight temperatures falling to between 4 and 7 with daytime temperatures reaching between 12 and 18.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-27T00:00:00+09:30" end-time-local="2026-06-28T00:00:00+09:30" start-time-utc="2026-06-26T14:30:00Z" end-time-utc="2026-06-27T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog on and east of the ranges. Slight chance of a shower on and east of the ranges, near zero chance elsewhere. Winds easterly 15 to 25 km/h. Overnight temperatures falling to between 4 and 8 with daytime temperatures reaching between 12 and 18.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-28T00:00:00+09:30" end-time-local="2026-06-29T00:00:00+09:30" start-time-utc="2026-06-27T14:30:00Z" end-time-utc="2026-06-28T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers, most likely in the afternoon and evening. Winds easterly 15 to 25 km/h turning northeasterly during the morning. Overnight temperatures falling to between 6 and 10 with daytime temperatures reaching between 13 and 18.</text>
            </forecast-period>
        </area>
