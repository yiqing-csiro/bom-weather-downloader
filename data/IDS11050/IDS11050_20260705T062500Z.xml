        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-05T15:55:43+09:30" end-time-local="2026-07-05T15:55:43+09:30" start-time-utc="2026-07-05T06:25:43Z" end-time-utc="2026-07-05T06:25:43Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system centred near Tasmania on Sunday and Monday will extend a ridge over SA. The ridge will weaken mid-week as a trough moves over the west and north of SA then a cold front will move across the south late Friday and early Saturday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-05T15:00:00+09:30" end-time-local="2026-07-06T00:00:00+09:30" start-time-utc="2026-07-05T05:30:00Z" end-time-utc="2026-07-05T14:30:00Z">
                <text type="forecast">Cloudy. Winds east to northeasterly 15 to 20 km/h becoming light in the late afternoon then becoming easterly 15 to 20 km/h in the late evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-06T00:00:00+09:30" end-time-local="2026-07-07T00:00:00+09:30" start-time-utc="2026-07-05T14:30:00Z" end-time-utc="2026-07-06T14:30:00Z">
                <text type="forecast">Cloudy. Winds east to northeasterly 15 to 20 km/h tending east to southeasterly in the early afternoon. Overnight temperatures falling to between 4 and 7 with daytime temperatures reaching between 13 and 16.</text>
                <text type="uv_alert">Sun protection 12:00pm to 1:10pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-07T00:00:00+09:30" end-time-local="2026-07-08T00:00:00+09:30" start-time-utc="2026-07-06T14:30:00Z" end-time-utc="2026-07-07T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of fog and frost east of Ceduna in the morning. Slight chance of a shower in the evening. Light winds becoming east to northeasterly 15 to 20 km/h in the middle of the day then becoming light in the early afternoon. Overnight temperatures falling to between 2 and 6 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-08T00:00:00+09:30" end-time-local="2026-07-09T00:00:00+09:30" start-time-utc="2026-07-07T14:30:00Z" end-time-utc="2026-07-08T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog south of Streaky Bay. Medium chance of showers. Light winds. Overnight temperatures falling to between 5 and 8 with daytime temperatures reaching around 17.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-09T00:00:00+09:30" end-time-local="2026-07-10T00:00:00+09:30" start-time-utc="2026-07-08T14:30:00Z" end-time-utc="2026-07-09T14:30:00Z">
