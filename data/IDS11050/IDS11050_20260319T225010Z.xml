    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-20T09:20:10+10:30" end-time-local="2026-03-20T09:20:10+10:30" start-time-utc="2026-03-19T22:50:10Z" end-time-utc="2026-03-19T22:50:10Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure will persist across the state. The high pressure centre will become established in the Tasman Sea over the weekend ahead of a cold front early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-20T00:00:00+10:30" end-time-local="2026-03-21T00:00:00+10:30" start-time-utc="2026-03-19T13:30:00Z" end-time-utc="2026-03-20T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower east of Ceduna in the late morning and afternoon. Near zero chance of rain elsewhere. Light winds becoming southerly 15 to 25 km/h in the middle of the day. Daytime maximum temperatures in the mid to high 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 5:10pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-21T00:00:00+10:30" end-time-local="2026-03-22T00:00:00+10:30" start-time-utc="2026-03-20T13:30:00Z" end-time-utc="2026-03-21T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds southeasterly 15 to 20 km/h becoming light in the early morning then becoming south to southeasterly 15 to 25 km/h in the early afternoon. Overnight temperatures falling to around 15 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-22T00:00:00+10:30" end-time-local="2026-03-23T00:00:00+10:30" start-time-utc="2026-03-21T13:30:00Z" end-time-utc="2026-03-22T13:30:00Z">
                <text type="forecast">Sunny. The chance of morning fog south of Streaky Bay. Winds southeasterly 15 to 20 km/h becoming light during the morning then becoming south to southeasterly 15 to 20 km/h during the afternoon. Overnight temperatures falling to between 13 and 16 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-23T00:00:00+10:30" end-time-local="2026-03-24T00:00:00+10:30" start-time-utc="2026-03-22T13:30:00Z" end-time-utc="2026-03-23T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower south of Streaky Bay in the afternoon. Near zero chance of rain elsewhere. Winds east to northeasterly 15 to 20 km/h tending northwest to northeasterly during the morning then tending south to southeasterly during the afternoon. Overnight temperatures falling to around 18 with daytime temperatures reaching the low 30s.</text>
            </forecast-period>
        </area>
