    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-01T10:24:22+10:30" end-time-local="2026-04-01T10:24:22+10:30" start-time-utc="2026-03-31T23:54:22Z" end-time-utc="2026-03-31T23:54:22Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system southwest of Perth extends a ridge over SA. The ridge will weaken overnight to allow the tail end of a cold front to brush the southeast of SA later Thursday. The high is forecast to move east on Friday to be southeast of Tasmania by Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-01T00:00:00+10:30" end-time-local="2026-04-02T00:00:00+10:30" start-time-utc="2026-03-31T13:30:00Z" end-time-utc="2026-04-01T13:30:00Z">
                <text type="forecast">Sunny. Winds south to southwesterly 15 to 25 km/h tending south to southeasterly 15 to 20 km/h in the evening. Daytime maximum temperatures in the low to mid 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:30am to 4:40pm, UV Index predicted to reach 7 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-02T00:00:00+10:30" end-time-local="2026-04-03T00:00:00+10:30" start-time-utc="2026-04-01T13:30:00Z" end-time-utc="2026-04-02T13:30:00Z">
                <text type="forecast">Mostly sunny. Light winds becoming east to southeasterly 15 to 20 km/h in the morning then tending south to southeasterly 20 to 30 km/h in the middle of the day. Overnight temperatures falling to around 12 with daytime temperatures reaching the low to high 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-03T00:00:00+10:30" end-time-local="2026-04-04T00:00:00+10:30" start-time-utc="2026-04-02T13:30:00Z" end-time-utc="2026-04-03T13:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers west of Nullarbor, near zero chance elsewhere. Winds southeasterly 15 to 25 km/h. Overnight temperatures falling to between 12 and 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-04T00:00:00+10:30" end-time-local="2026-04-05T00:00:00+10:30" start-time-utc="2026-04-03T13:30:00Z" end-time-utc="2026-04-04T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers west of Ceduna, most likely in the morning. Near zero chance of rain elsewhere. Winds east to southeasterly 15 to 20 km/h tending east to northeasterly 15 to 25 km/h during the morning then tending east to southeasterly during the evening. Overnight temperatures falling to around 15 with daytime temperatures reaching around 30.</text>
            </forecast-period>
        </area>
