    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-19T16:40:13+09:30" end-time-local="2026-04-19T16:40:13+09:30" start-time-utc="2026-04-19T07:10:13Z" end-time-utc="2026-04-19T07:10:13Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system is centred over the Bight and a weakening trough lies over the eastern districts. The trough will clear to the east this evening and the high will move southeastwards overnight to be centred southeast of Tasmania late Monday morning. The high will continue to extend a ridge over SA early next week ahead of a cold front expected to move across the south of SA late Tuesday and early Wednesday. Another high will move across waters to the south later Wednesday and will be centred southeast of Tasmania late Thursday morning.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-19T15:00:00+09:30" end-time-local="2026-04-20T00:00:00+09:30" start-time-utc="2026-04-19T05:30:00Z" end-time-utc="2026-04-19T14:30:00Z">
                <text type="forecast">Clear. Winds south to southeasterly 20 to 30 km/h decreasing to 15 to 20 km/h in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-20T00:00:00+09:30" end-time-local="2026-04-21T00:00:00+09:30" start-time-utc="2026-04-19T14:30:00Z" end-time-utc="2026-04-20T14:30:00Z">
                <text type="forecast">Cloud clearing. The chance of morning fog south of Streaky Bay. Winds southeasterly 15 to 20 km/h tending northeast to southeasterly 15 to 25 km/h in the morning. Overnight temperatures falling to around 12 with daytime temperatures reaching around 30.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 10:00am to 3:10pm, UV Index predicted to reach 6 [High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-21T00:00:00+09:30" end-time-local="2026-04-22T00:00:00+09:30" start-time-utc="2026-04-20T14:30:00Z" end-time-utc="2026-04-21T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower west of Nullarbor in the evening. Near zero chance of rain elsewhere. The chance of a thunderstorm west of Nullarbor in the evening. Winds east to northeasterly 15 to 20 km/h turning northerly 30 to 45 km/h early in the morning. Overnight temperatures falling to between 14 and 20 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-22T00:00:00+09:30" end-time-local="2026-04-23T00:00:00+09:30" start-time-utc="2026-04-21T14:30:00Z" end-time-utc="2026-04-22T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds south to southeasterly 20 to 30 km/h turning easterly 15 to 20 km/h during the afternoon. Overnight temperatures falling to around 15 with daytime temperatures reaching 24 to 29.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-23T00:00:00+09:30" end-time-local="2026-04-24T00:00:00+09:30" start-time-utc="2026-04-22T14:30:00Z" end-time-utc="2026-04-23T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds easterly 15 to 20 km/h turning north to northeasterly 25 to 35 km/h during the morning. Overnight temperatures falling to around 14 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
        </area>
