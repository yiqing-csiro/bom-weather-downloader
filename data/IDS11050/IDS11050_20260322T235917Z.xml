    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-23T10:29:17+10:30" end-time-local="2026-03-23T10:29:17+10:30" start-time-utc="2026-03-22T23:59:17Z" end-time-utc="2026-03-22T23:59:17Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over the Tasman sea, extends a ridge over southern SA. A broad trough moves over SA early in the week, then a cold front clips the southeast and an upper trough moves up over SA Wednesday and Thursday. A new ridge develops south of the Bight mid next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-23T00:00:00+10:30" end-time-local="2026-03-24T00:00:00+10:30" start-time-utc="2026-03-22T13:30:00Z" end-time-utc="2026-03-23T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds north to northeasterly 15 to 25 km/h turning east to southeasterly 15 to 20 km/h in the afternoon. Daytime maximum temperatures in the low to mid 30s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:20am to 5:00pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-24T00:00:00+10:30" end-time-local="2026-03-25T00:00:00+10:30" start-time-utc="2026-03-23T13:30:00Z" end-time-utc="2026-03-24T13:30:00Z">
                <text type="forecast">Sunny. Winds east to northeasterly 15 to 20 km/h tending northwest to northeasterly in the morning then tending southeast to southwesterly 15 to 25 km/h in the early afternoon. Overnight temperatures falling to between 18 and 21 with daytime temperatures reaching the low to mid 30s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-25T00:00:00+10:30" end-time-local="2026-03-26T00:00:00+10:30" start-time-utc="2026-03-24T13:30:00Z" end-time-utc="2026-03-25T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower south of Streaky Bay in the afternoon and evening. Near zero chance of rain elsewhere. The chance of a thunderstorm in the afternoon. Winds south to southeasterly 25 to 40 km/h. Overnight temperatures falling to around 18 with daytime temperatures reaching 24 to 31.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-26T00:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-25T13:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the morning. Winds south to southeasterly 25 to 40 km/h. Overnight temperatures falling to between 13 and 17 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
        </area>
