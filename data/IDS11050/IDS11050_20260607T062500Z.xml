        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-07T15:55:41+09:30" end-time-local="2026-06-07T15:55:41+09:30" start-time-utc="2026-06-07T06:25:41Z" end-time-utc="2026-06-07T06:25:41Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over NSW will continue to move eastwards to be centred over the Tasman Sea by Monday. Northerly winds freshen over the state on Tuesday ahead of a weakening cold front mid-week, with a second cold front expected late in the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-07T15:00:00+09:30" end-time-local="2026-06-08T00:00:00+09:30" start-time-utc="2026-06-07T05:30:00Z" end-time-utc="2026-06-07T14:30:00Z">
                <text type="forecast">Clear. Winds northerly 15 to 25 km/h turning northeasterly in the late afternoon.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-06-08T00:00:00+09:30" end-time-local="2026-06-09T00:00:00+09:30" start-time-utc="2026-06-07T14:30:00Z" end-time-utc="2026-06-08T14:30:00Z">
                <text type="forecast">Sunny. Winds north to northeasterly 25 to 35 km/h. Overnight temperatures falling to between 5 and 9 with daytime temperatures reaching between 18 and 25.</text>
                <text type="uv_alert">Sun protection 11:30am to 1:40pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-09T00:00:00+09:30" end-time-local="2026-06-10T00:00:00+09:30" start-time-utc="2026-06-08T14:30:00Z" end-time-utc="2026-06-09T14:30:00Z">
                <text type="forecast">Cloudy. Very high chance of showers, most likely from the late morning. The chance of a thunderstorm west of Nullarbor in the late afternoon and evening. Winds northerly 25 to 40 km/h turning northwesterly 20 to 30 km/h during the afternoon and evening. Overnight temperatures falling to between 9 and 15 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-10T00:00:00+09:30" end-time-local="2026-06-11T00:00:00+09:30" start-time-utc="2026-06-09T14:30:00Z" end-time-utc="2026-06-10T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers east of Ceduna, most likely in the morning. Near zero chance of rain elsewhere. Winds west to northwesterly 15 to 25 km/h tending west to southwesterly 15 to 20 km/h during the day then becoming light during the afternoon. Overnight temperatures falling to between 6 and 11 with daytime temperatures reaching around 19.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-06-11T00:00:00+09:30" end-time-local="2026-06-12T00:00:00+09:30" start-time-utc="2026-06-10T14:30:00Z" end-time-utc="2026-06-11T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower west of Ceduna, most likely in the afternoon and evening. Near zero chance of rain elsewhere. Winds northeasterly 20 to 30 km/h. Overnight temperatures falling to around 7 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
        </area>
