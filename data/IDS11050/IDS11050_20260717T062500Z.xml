        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-17T15:00:00+09:30" end-time-local="2026-07-18T00:00:00+09:30" start-time-utc="2026-07-17T05:30:00Z" end-time-utc="2026-07-17T14:30:00Z">
                <text type="forecast">Clear. Winds northerly 15 to 25 km/h turning northeasterly 15 to 20 km/h in the late afternoon.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-18T00:00:00+09:30" end-time-local="2026-07-19T00:00:00+09:30" start-time-utc="2026-07-17T14:30:00Z" end-time-utc="2026-07-18T14:30:00Z">
                <text type="forecast">Sunny. Areas of morning frost south of Streaky Bay. Winds north to northeasterly 15 to 25 km/h. Overnight temperatures falling to between 1 and 6 with daytime temperatures reaching between 19 and 23.</text>
                <text type="uv_alert">Sun protection 11:10am to 2:10pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-19T00:00:00+09:30" end-time-local="2026-07-20T00:00:00+09:30" start-time-utc="2026-07-18T14:30:00Z" end-time-utc="2026-07-19T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds north to northeasterly 20 to 30 km/h. Overnight temperatures falling to between 5 and 9 with daytime temperatures reaching between 19 and 24.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-20T00:00:00+09:30" end-time-local="2026-07-21T00:00:00+09:30" start-time-utc="2026-07-19T14:30:00Z" end-time-utc="2026-07-20T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds northerly 15 to 20 km/h becoming light during the afternoon. Overnight temperatures falling to around 7 with daytime temperatures reaching between 19 and 22.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-21T00:00:00+09:30" end-time-local="2026-07-22T00:00:00+09:30" start-time-utc="2026-07-20T14:30:00Z" end-time-utc="2026-07-21T14:30:00Z">
                <text type="forecast">Partly cloudy. Winds northwest to northeasterly 15 to 20 km/h tending northwest to southwesterly during the afternoon then becoming light during the evening. Overnight temperatures falling to between 7 and 10 with daytime temperatures reaching between 18 and 21.</text>
            </forecast-period>
