        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-06-30T04:10:40+09:30" end-time-local="2026-06-30T04:10:40+09:30" start-time-utc="2026-06-29T18:40:40Z" end-time-utc="2026-06-29T18:40:40Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A low pressure trough over central districts will move southeastwards and slip south of SA early today. A series of low pressure systems passing through the Bight during the week will extend cold fronts that will cross over SA through to the end of the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-06-30T00:00:00+09:30" end-time-local="2026-07-01T00:00:00+09:30" start-time-utc="2026-06-29T14:30:00Z" end-time-utc="2026-06-30T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of fog east of Ceduna early this morning. Very high chance of showers west of Nullarbor, medium chance elsewhere. Winds northerly 25 to 35 km/h. Daytime maximum temperatures between 17 and 20.</text>
                <text type="uv_alert">Sun protection not recommended, UV Index predicted to reach 2 [Low]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-01T00:00:00+09:30" end-time-local="2026-07-02T00:00:00+09:30" start-time-utc="2026-06-30T14:30:00Z" end-time-utc="2026-07-01T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers east of Ceduna, medium chance elsewhere. The chance of a thunderstorm south of Streaky Bay in the morning. Winds north to northwesterly 20 to 30 km/h tending west to northwesterly 30 to 45 km/h during the morning then becoming northwesterly 25 to 35 km/h in the late afternoon. Overnight temperatures falling to around 9 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-02T00:00:00+09:30" end-time-local="2026-07-03T00:00:00+09:30" start-time-utc="2026-07-01T14:30:00Z" end-time-utc="2026-07-02T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers east of Ceduna, medium chance elsewhere. Winds northwesterly 25 to 35 km/h turning westerly during the morning. Overnight temperatures falling to around 9 with daytime temperatures reaching around 16.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-03T00:00:00+09:30" end-time-local="2026-07-04T00:00:00+09:30" start-time-utc="2026-07-02T14:30:00Z" end-time-utc="2026-07-03T14:30:00Z">
                <text type="forecast">Cloudy. Medium chance of showers. Winds westerly 15 to 20 km/h tending southwesterly during the day then becoming light during the afternoon. Overnight temperatures falling to around 8 with daytime temperatures reaching around 16.</text>
            </forecast-period>
