        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-05-19T21:16:04+09:30" end-time-local="2026-05-19T21:16:04+09:30" start-time-utc="2026-05-19T11:46:04Z" end-time-utc="2026-05-19T11:46:04Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over SA will remain dominant as it slowly moves east and into the Tasman Sea on Friday. A cold front will moves across the Bight on Saturday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-05-19T21:00:00+09:30" end-time-local="2026-05-20T00:00:00+09:30" start-time-utc="2026-05-19T11:30:00Z" end-time-utc="2026-05-19T14:30:00Z">
                <text type="forecast">Partly cloudy. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-05-20T00:00:00+09:30" end-time-local="2026-05-21T00:00:00+09:30" start-time-utc="2026-05-19T14:30:00Z" end-time-utc="2026-05-20T14:30:00Z">
                <text type="forecast">Partly cloudy. Patchy morning fog. Slight chance of a shower south of Streaky Bay, near zero chance elsewhere. Light winds becoming north to northeasterly 15 to 20 km/h in the morning then becoming light in the middle of the day. Overnight temperatures falling to between 5 and 9 with daytime temperatures reaching between 19 and 22.</text>
                <text type="uv_alert">Sun protection 10:50am to 2:10pm, UV Index predicted to reach 4 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-05-21T00:00:00+09:30" end-time-local="2026-05-22T00:00:00+09:30" start-time-utc="2026-05-20T14:30:00Z" end-time-utc="2026-05-21T14:30:00Z">
                <text type="forecast">Sunny. The chance of morning fog south of Streaky Bay. Winds northeasterly 15 to 25 km/h. Overnight temperatures falling to around 8 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-05-22T00:00:00+09:30" end-time-local="2026-05-23T00:00:00+09:30" start-time-utc="2026-05-21T14:30:00Z" end-time-utc="2026-05-22T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower west of Nullarbor, near zero chance elsewhere. Winds north to northeasterly 20 to 30 km/h. Overnight temperatures falling to between 9 and 13 with daytime temperatures reaching between 19 and 23.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-05-23T00:00:00+09:30" end-time-local="2026-05-24T00:00:00+09:30" start-time-utc="2026-05-22T14:30:00Z" end-time-utc="2026-05-23T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers. The chance of a thunderstorm west of Nullarbor in the afternoon and evening. Winds northwest to northeasterly 15 to 25 km/h tending northwest to southwesterly during the day then tending southeast to southwesterly 15 to 20 km/h during the afternoon. Overnight temperatures falling to around 10 with daytime temperatures reaching around 20.</text>
            </forecast-period>
        </area>
