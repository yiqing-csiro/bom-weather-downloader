        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-07-13T21:17:44+09:30" end-time-local="2026-07-13T21:17:44+09:30" start-time-utc="2026-07-13T11:47:44Z" end-time-utc="2026-07-13T11:47:44Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A ridge of high pressure lies over northern SA. A cold front will pass across southeastern SA today before a strong high pressure system moves east mid week and dominates the weather pattern until at least Friday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-07-13T21:00:00+09:30" end-time-local="2026-07-14T00:00:00+09:30" start-time-utc="2026-07-13T11:30:00Z" end-time-utc="2026-07-13T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower south of Streaky Bay, near zero chance elsewhere. Light winds.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-07-14T00:00:00+09:30" end-time-local="2026-07-15T00:00:00+09:30" start-time-utc="2026-07-13T14:30:00Z" end-time-utc="2026-07-14T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog west of Ceduna. Medium chance of showers in the morning and afternoon. Light winds. Overnight temperatures falling to around 8 with daytime temperatures reaching around 17.</text>
                <text type="uv_alert">Sun protection 11:10am to 2:00pm, UV Index predicted to reach 3 [Moderate]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-07-15T00:00:00+09:30" end-time-local="2026-07-16T00:00:00+09:30" start-time-utc="2026-07-14T14:30:00Z" end-time-utc="2026-07-15T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Light winds becoming east to northeasterly 15 to 25 km/h in the early morning. Overnight temperatures falling to between 4 and 8 with daytime temperatures reaching around 19.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-07-16T00:00:00+09:30" end-time-local="2026-07-17T00:00:00+09:30" start-time-utc="2026-07-15T14:30:00Z" end-time-utc="2026-07-16T14:30:00Z">
                <text type="forecast">Sunny. The chance of morning fog south of Streaky Bay. The chance of morning frost south of Streaky Bay. Winds northeasterly 20 to 30 km/h. Overnight temperatures falling to between 3 and 9 with daytime temperatures reaching between 17 and 20.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-07-17T00:00:00+09:30" end-time-local="2026-07-18T00:00:00+09:30" start-time-utc="2026-07-16T14:30:00Z" end-time-utc="2026-07-17T14:30:00Z">
