    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-26T15:55:41+10:30" end-time-local="2026-03-26T15:55:41+10:30" start-time-utc="2026-03-26T05:25:41Z" end-time-utc="2026-03-26T05:25:41Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">An upper level trough over southeast SA will continue to move eastwards, as a high pressure system starts to build southwest of the Bight. The high will become established south of SA by Friday, then moving eastwards over the weekend to be centred over the Tasman Sea on Monday. A low pressure system well to the south will link to a trough over the far west late Monday and into Tuesday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-26T15:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-26T04:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds south to southeasterly 25 to 40 km/h decreasing to 20 to 30 km/h in the late evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds east to southeasterly 25 to 35 km/h. Overnight temperatures falling to between 10 and 15 with daytime temperatures reaching the low 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:20am to 4:50pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-28T00:00:00+10:30" end-time-local="2026-03-29T00:00:00+10:30" start-time-utc="2026-03-27T13:30:00Z" end-time-utc="2026-03-28T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to southeasterly 15 to 25 km/h tending east to northeasterly 25 to 35 km/h during the morning. Overnight temperatures falling to between 10 and 13 with daytime temperatures reaching the low to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower west of Nullarbor, near zero chance elsewhere. Winds east to northeasterly 15 to 25 km/h turning northerly 25 to 40 km/h during the morning then tending north to northeasterly 20 to 30 km/h during the afternoon. Overnight temperatures falling to between 12 and 18 with daytime temperatures reaching 26 to 31.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-30T00:00:00+10:30" end-time-local="2026-03-31T00:00:00+10:30" start-time-utc="2026-03-29T13:30:00Z" end-time-utc="2026-03-30T13:30:00Z">
                <text type="forecast">Mostly sunny morning. The chance of a thunderstorm west of Nullarbor in the afternoon and evening. Winds north to northeasterly 20 to 30 km/h. Overnight temperatures falling to between 15 and 20 with daytime temperatures reaching around 30.</text>
            </forecast-period>
        </area>
