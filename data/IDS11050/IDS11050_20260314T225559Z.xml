    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-15T09:25:59+10:30" end-time-local="2026-03-15T09:25:59+10:30" start-time-utc="2026-03-14T22:55:59Z" end-time-utc="2026-03-14T22:55:59Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A trough over inland WA is expected to move across western and northern SA today and continue northeast early in the week. A ridge of high pressure persists over the south. A cold front clips the southeast early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-15T00:00:00+10:30" end-time-local="2026-03-16T00:00:00+10:30" start-time-utc="2026-03-14T13:30:00Z" end-time-utc="2026-03-15T13:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of rain west of Nullarbor, high chance elsewhere. The chance of a thunderstorm west of Ceduna from the late morning. Winds east to southeasterly 15 to 20 km/h tending south to southeasterly 20 to 30 km/h in the late morning and early afternoon. Daytime maximum temperatures 24 to 33.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 5:10pm, UV Index predicted to reach 10 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-16T00:00:00+10:30" end-time-local="2026-03-17T00:00:00+10:30" start-time-utc="2026-03-15T13:30:00Z" end-time-utc="2026-03-16T13:30:00Z">
                <text type="forecast">Cloudy. Very high chance of rain, most likely in the morning and afternoon. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to around 17 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-17T00:00:00+10:30" end-time-local="2026-03-18T00:00:00+10:30" start-time-utc="2026-03-16T13:30:00Z" end-time-utc="2026-03-17T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower west of Nullarbor, most likely in the morning. Near zero chance of rain elsewhere. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to around 17 with daytime temperatures reaching the low to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-18T00:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-17T13:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower west of Nullarbor, near zero chance elsewhere. Winds south to southeasterly 20 to 30 km/h. Overnight temperatures falling to around 17 with daytime temperatures reaching 24 to 29.</text>
            </forecast-period>
        </area>
