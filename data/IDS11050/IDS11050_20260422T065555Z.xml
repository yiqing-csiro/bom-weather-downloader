        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-22T16:25:56+09:30" end-time-local="2026-04-22T16:25:56+09:30" start-time-utc="2026-04-22T06:55:56Z" end-time-utc="2026-04-22T06:55:56Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A strong high pressure system east of Tasmania will maintain a ridge over SA this week. A cold front will pass over the south again on Saturday and weaken with a high pressure system to follow over waters south of the Bight on Sunday.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-22T15:00:00+09:30" end-time-local="2026-04-23T00:00:00+09:30" start-time-utc="2026-04-22T05:30:00Z" end-time-utc="2026-04-22T14:30:00Z">
                <text type="forecast">Clear. Winds east to southeasterly 20 to 30 km/h decreasing to 15 to 20 km/h in the evening.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-23T00:00:00+09:30" end-time-local="2026-04-24T00:00:00+09:30" start-time-utc="2026-04-22T14:30:00Z" end-time-utc="2026-04-23T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds easterly 15 to 20 km/h turning north to northeasterly 25 to 40 km/h early in the morning. Overnight temperatures falling to around 13 with daytime temperatures reaching the low to mid 30s.</text>
                <text type="fire_danger">High</text>
                <text type="uv_alert">Sun protection 10:00am to 3:00pm, UV Index predicted to reach 6 [High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-24T00:00:00+09:30" end-time-local="2026-04-25T00:00:00+09:30" start-time-utc="2026-04-23T14:30:00Z" end-time-utc="2026-04-24T14:30:00Z">
                <text type="forecast">Mostly sunny. Winds north to northeasterly 25 to 40 km/h. Overnight temperatures falling to between 16 and 20 with daytime temperatures reaching 29 to 35.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-25T00:00:00+09:30" end-time-local="2026-04-26T00:00:00+09:30" start-time-utc="2026-04-24T14:30:00Z" end-time-utc="2026-04-25T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower, most likely in the afternoon and evening. Winds north to northeasterly 15 to 25 km/h shifting south to southwesterly 20 to 30 km/h during the day. Overnight temperatures falling to between 15 and 18 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-04-26T00:00:00+09:30" end-time-local="2026-04-27T00:00:00+09:30" start-time-utc="2026-04-25T14:30:00Z" end-time-utc="2026-04-26T14:30:00Z">
                <text type="forecast">Slight chance of a shower, most likely in the morning. Mostly sunny afternoon. Winds southerly 20 to 30 km/h becoming light during the evening. Overnight temperatures falling to around 14 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
        </area>
