        <area aac="SA_PW010" description="West Coast" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-18T21:00:00+10:30" end-time-local="2026-03-19T00:00:00+10:30" start-time-utc="2026-03-18T10:30:00Z" end-time-utc="2026-03-18T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds south to southeasterly 15 to 25 km/h.</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-19T00:00:00+10:30" end-time-local="2026-03-20T00:00:00+10:30" start-time-utc="2026-03-18T13:30:00Z" end-time-utc="2026-03-19T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower west of Ceduna in the morning and afternoon. Near zero chance of rain elsewhere. Winds south to southeasterly 15 to 25 km/h becoming light in the early morning then becoming south to southeasterly 15 to 25 km/h in the morning. Overnight temperatures falling to around 16 with daytime temperatures reaching 22 to 27.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:10am to 5:10pm, UV Index predicted to reach 9 [Very High]</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-20T00:00:00+10:30" end-time-local="2026-03-21T00:00:00+10:30" start-time-utc="2026-03-19T13:30:00Z" end-time-utc="2026-03-20T13:30:00Z">
                <text type="forecast">Partly cloudy. The chance of morning fog. Light winds becoming south to southwesterly 15 to 25 km/h in the middle of the day then tending south to southeasterly in the evening. Overnight temperatures falling to around 16 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-21T00:00:00+10:30" end-time-local="2026-03-22T00:00:00+10:30" start-time-utc="2026-03-20T13:30:00Z" end-time-utc="2026-03-21T13:30:00Z">
                <text type="forecast">Cloud clearing. Winds southeasterly 15 to 20 km/h becoming light during the morning then becoming south to southeasterly 15 to 25 km/h during the afternoon. Overnight temperatures falling to around 14 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-03-22T00:00:00+10:30" end-time-local="2026-03-23T00:00:00+10:30" start-time-utc="2026-03-21T13:30:00Z" end-time-utc="2026-03-22T13:30:00Z">
                <text type="forecast">Sunny. The chance of morning fog west of Ceduna. Winds east to southeasterly 15 to 20 km/h tending east to northeasterly during the morning then turning south to southeasterly during the afternoon. Overnight temperatures falling to around 14 with daytime temperatures reaching around 30.</text>
            </forecast-period>
        </area>
