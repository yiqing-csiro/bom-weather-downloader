    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-16T04:10:56+09:30" end-time-local="2026-04-16T04:10:56+09:30" start-time-utc="2026-04-15T18:40:56Z" end-time-utc="2026-04-15T18:40:56Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system centred over eastern NSW will allow a cold front to move across the far southeast of SA today. A second high pressure system is expected to move south of the Bight during Friday and Saturday ahead of another trough expected to brush the west and south on the weekend.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW012" description="Lower Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-16T00:00:00+09:30" end-time-local="2026-04-17T00:00:00+09:30" start-time-utc="2026-04-15T14:30:00Z" end-time-utc="2026-04-16T14:30:00Z">
                <text type="forecast">Sunny. Light winds becoming northwest to southwesterly 15 to 20 km/h in the morning then tending south to southeasterly in the late afternoon. Daytime maximum temperatures in the mid to high 20s.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 9:50am to 2:50pm, UV Index predicted to reach 5 [Moderate]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-17T00:00:00+09:30" end-time-local="2026-04-18T00:00:00+09:30" start-time-utc="2026-04-16T14:30:00Z" end-time-utc="2026-04-17T14:30:00Z">
                <text type="forecast">Partly cloudy. The chance of fog in the early morning. Winds southeasterly 15 to 25 km/h turning easterly in the late afternoon. Overnight temperatures falling to around 12 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-18T00:00:00+09:30" end-time-local="2026-04-19T00:00:00+09:30" start-time-utc="2026-04-17T14:30:00Z" end-time-utc="2026-04-18T14:30:00Z">
                <text type="forecast">Mostly sunny day. The chance of a thunderstorm near the west coast in the evening. Winds east to northeasterly 15 to 25 km/h turning northerly 15 to 20 km/h during the day. Overnight temperatures falling to around 12 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-19T00:00:00+09:30" end-time-local="2026-04-20T00:00:00+09:30" start-time-utc="2026-04-18T14:30:00Z" end-time-utc="2026-04-19T14:30:00Z">
                <text type="forecast">Mostly sunny. Slight chance of a shower. The chance of a thunderstorm in the morning. Winds north to northwesterly 15 to 25 km/h shifting southerly during the afternoon. Overnight temperatures falling to around 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
        </area>
