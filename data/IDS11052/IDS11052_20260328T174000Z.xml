    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-29T04:10:48+10:30" end-time-local="2026-03-29T04:10:48+10:30" start-time-utc="2026-03-28T17:40:48Z" end-time-utc="2026-03-28T17:40:48Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system south of Kangaroo Island will move slowly eastwards this weekend to be centred over the Tasman Sea on Monday. A trough is forecast to move across the west and south later Tuesday, pushing into the northeast of SA on Wednesday. Another high pressure system is expected to become established south of the Bight later next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW012" description="Lower Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-29T00:00:00+10:30" end-time-local="2026-03-30T00:00:00+10:30" start-time-utc="2026-03-28T13:30:00Z" end-time-utc="2026-03-29T13:30:00Z">
                <text type="forecast">Mostly sunny. Winds east to northeasterly 15 to 20 km/h tending north to northeasterly 15 to 25 km/h during the morning. Daytime maximum temperatures in the mid to high 20s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:20am to 4:40pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-30T00:00:00+10:30" end-time-local="2026-03-31T00:00:00+10:30" start-time-utc="2026-03-29T13:30:00Z" end-time-utc="2026-03-30T13:30:00Z">
                <text type="forecast">Partly cloudy. Winds northerly 15 to 25 km/h tending northeasterly 15 to 20 km/h in the late evening. Overnight temperatures falling to around 18 with daytime temperatures reaching around 30.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-31T00:00:00+10:30" end-time-local="2026-04-01T00:00:00+10:30" start-time-utc="2026-03-30T13:30:00Z" end-time-utc="2026-03-31T13:30:00Z">
                <text type="forecast">Mostly sunny morning. High chance of showers in the afternoon and evening. The chance of a thunderstorm in the evening. Winds north to northeasterly 25 to 35 km/h increasing to 40 km/h before turning west to northwesterly 15 to 25 km/h during the afternoon. Overnight temperatures falling to around 18 with daytime temperatures reaching the low 30s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-01T00:00:00+10:30" end-time-local="2026-04-02T00:00:00+10:30" start-time-utc="2026-03-31T13:30:00Z" end-time-utc="2026-04-01T13:30:00Z">
                <text type="forecast">Slight chance of a shower in the morning. Sunny day. Winds westerly 15 to 20 km/h turning southerly 15 to 25 km/h during the afternoon. Overnight temperatures falling to around 15 with daytime temperatures reaching the low to mid 20s.</text>
            </forecast-period>
        </area>
