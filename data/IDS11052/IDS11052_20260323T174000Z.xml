    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-03-24T04:10:48+10:30" end-time-local="2026-03-24T04:10:48+10:30" start-time-utc="2026-03-23T17:40:48Z" end-time-utc="2026-03-23T17:40:48Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system over the Tasman sea, extends a ridge over southern SA. A broad trough moves over SA Tuesday, then a cold front clips the southeast as an upper trough moves up over SA Wednesday and Thursday. A new ridge develops south of the Bight late in the week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW012" description="Lower Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-03-24T00:00:00+10:30" end-time-local="2026-03-25T00:00:00+10:30" start-time-utc="2026-03-23T13:30:00Z" end-time-utc="2026-03-24T13:30:00Z">
                <text type="forecast">Sunny. Light winds becoming northwest to southwesterly 15 to 20 km/h in the morning then becoming light in the evening. Daytime maximum temperatures in the low to mid 30s.</text>
                <text type="fire_danger">Moderate</text>
                <text type="uv_alert">Sun protection 10:20am to 4:40pm, UV Index predicted to reach 8 [Very High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-03-25T00:00:00+10:30" end-time-local="2026-03-26T00:00:00+10:30" start-time-utc="2026-03-24T13:30:00Z" end-time-utc="2026-03-25T13:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely from the late morning. The chance of a thunderstorm in the afternoon. Winds southerly 25 to 35 km/h. Overnight temperatures falling to between 16 and 19 with daytime temperatures reaching 23 to 28.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-03-26T00:00:00+10:30" end-time-local="2026-03-27T00:00:00+10:30" start-time-utc="2026-03-25T13:30:00Z" end-time-utc="2026-03-26T13:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower in the morning. Winds southerly 25 to 40 km/h. Overnight temperatures falling to around 14 with daytime temperatures reaching between 19 and 22.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-03-27T00:00:00+10:30" end-time-local="2026-03-28T00:00:00+10:30" start-time-utc="2026-03-26T13:30:00Z" end-time-utc="2026-03-27T13:30:00Z">
                <text type="forecast">Cloudy. Slight chance of a shower near the east coast, near zero chance elsewhere. Winds southeasterly 20 to 30 km/h. Overnight temperatures falling to around 12 with daytime temperatures reaching around 19.</text>
            </forecast-period>
        </area>
