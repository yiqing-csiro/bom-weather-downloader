    <forecast>
        <area aac="SA_FA001" description="South Australia" type="region">
            <forecast-period start-time-local="2026-04-05T09:18:09+09:30" end-time-local="2026-04-05T09:18:09+09:30" start-time-utc="2026-04-04T23:48:09Z" end-time-utc="2026-04-04T23:48:09Z">
                <text type="warning_summary_footer">For latest warnings go to www.bom.gov.au, subscribe to RSS feeds, call 1300 659 210* or listen for warnings on relevant TV and radio broadcasts.</text>
                <text type="synoptic_situation">A high pressure system centred just south of Tasmania will move southeastwards during Sunday. This will allow a trough over WA to link to a weak front south of the Bight then move over western and southern parts of SA later Sunday into Monday. Another high pressure system is expected to follow early next week.</text>
                <text type="product_footer">* Calls to 1300 numbers cost around 27.5c incl. GST, higher from mobiles or public phones.</text>
            </forecast-period>
        </area>
        <area aac="SA_PW012" description="Lower Eyre Peninsula" type="public-district" parent-aac="SA_FA001">
            <forecast-period index="0" start-time-local="2026-04-05T00:00:00+10:30" end-time-local="2026-04-06T00:00:00+09:30" start-time-utc="2026-04-04T13:30:00Z" end-time-utc="2026-04-05T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, becoming less likely at night. The chance of a thunderstorm in the afternoon and evening. Winds north to northeasterly 15 to 25 km/h tending north to northwesterly in the early afternoon then becoming light in the evening. Daytime maximum temperatures around 30.</text>
                <text type="fire_danger">No Rating</text>
                <text type="uv_alert">Sun protection 9:40am to 3:20pm, UV Index predicted to reach 6 [High]</text>
            </forecast-period>
            <forecast-period index="1" start-time-local="2026-04-06T00:00:00+09:30" end-time-local="2026-04-07T00:00:00+09:30" start-time-utc="2026-04-05T14:30:00Z" end-time-utc="2026-04-06T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers. Winds north to northwesterly 15 to 25 km/h shifting southwesterly 25 to 35 km/h in the late afternoon. Overnight temperatures falling to around 16 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
            <forecast-period index="2" start-time-local="2026-04-07T00:00:00+09:30" end-time-local="2026-04-08T00:00:00+09:30" start-time-utc="2026-04-06T14:30:00Z" end-time-utc="2026-04-07T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Winds southerly 15 to 20 km/h tending southeasterly 15 to 25 km/h during the afternoon then becoming light during the evening. Overnight temperatures falling to around 12 with daytime temperatures reaching the low 20s.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-04-08T00:00:00+09:30" end-time-local="2026-04-09T00:00:00+09:30" start-time-utc="2026-04-07T14:30:00Z" end-time-utc="2026-04-08T14:30:00Z">
                <text type="forecast">Partly cloudy. High chance of showers, most likely in the morning and afternoon. Winds east to northeasterly 15 to 20 km/h shifting west to northwesterly during the afternoon then becoming light during the evening. Overnight temperatures falling to around 12 with daytime temperatures reaching the mid to high 20s.</text>
            </forecast-period>
        </area>
