            </forecast-period>
            <forecast-period index="2" start-time-local="2026-06-09T00:00:00+09:30" end-time-local="2026-06-10T00:00:00+09:30" start-time-utc="2026-06-08T14:30:00Z" end-time-utc="2026-06-09T14:30:00Z">
                <text type="forecast">Partly cloudy. Very high chance of showers, most likely in the evening. Winds northerly 20 to 30 km/h increasing to 25 to 40 km/h in the morning then turning northwesterly 25 to 35 km/h in the late evening. Overnight temperatures falling to around 9 with daytime temperatures reaching around 20.</text>
            </forecast-period>
            <forecast-period index="3" start-time-local="2026-06-10T00:00:00+09:30" end-time-local="2026-06-11T00:00:00+09:30" start-time-utc="2026-06-09T14:30:00Z" end-time-utc="2026-06-10T14:30:00Z">
                <text type="forecast">Partly cloudy. Medium chance of showers, most likely in the morning. Winds northwesterly 25 to 35 km/h tending westerly 20 to 30 km/h during the morning then becoming light during the afternoon. Overnight temperatures falling to around 10 with daytime temperatures reaching around 18.</text>
            </forecast-period>
            <forecast-period index="4" start-time-local="2026-06-11T00:00:00+09:30" end-time-local="2026-06-12T00:00:00+09:30" start-time-utc="2026-06-10T14:30:00Z" end-time-utc="2026-06-11T14:30:00Z">
                <text type="forecast">Partly cloudy. Slight chance of a shower. Light winds becoming northeasterly 15 to 20 km/h during the morning. Overnight temperatures falling to around 6 with daytime temperatures reaching around 19.</text>
            </forecast-period>
